<style>
html, body {
   overflow-x: hidden !important;
}

.menu-page-footer,
.menu-page-footer * {
   box-sizing: border-box;
}

.menu-page-footer {
   margin-top: 24px;
   padding: 16px 12px calc(20px + env(safe-area-inset-bottom));
   background:
      linear-gradient(180deg, rgba(255,255,255,0) 0%, rgba(241,248,243,0.92) 18%, #edf6f0 100%);
   border-top: 1px solid rgba(95,144,120,0.10);
   width: 100%;
   max-width: 100%;
}

.menu-page-footer-inner {
   max-width: 560px;
   margin: 0 auto;
   display: grid;
   grid-template-columns: 1fr 1fr;
   gap: 10px;
   width: 100%;
   padding: 8px;
   border-radius: 24px;
   background: linear-gradient(180deg, rgba(255,255,255,0.92), rgba(255,255,255,0.78));
   border: 1px solid rgba(255,255,255,0.72);
   box-shadow:
      0 18px 40px rgba(66,101,82,0.10),
      0 8px 18px rgba(66,101,82,0.06),
      inset 0 1px 0 rgba(255,255,255,0.75);
   overflow: hidden;
   box-sizing: border-box;
}

.feedback-submit[disabled] {
   opacity: 0.45;
   cursor: not-allowed;
   pointer-events: none;
   box-shadow: none;
}

.feedback-char-note {
   margin-top: 6px;
   font-size: 12px;
   font-weight: 700;
   color: #7e8d84;
}

.feedback-char-note.valid {
   color: #176b2c;
}

.menu-footer-btn {
   min-width: 0;
   width: 100%;
   height: 54px;
   display: flex;
   align-items: center;
   justify-content: center;
   gap: 8px;
   padding: 0 10px;
   border: 0;
   border-radius: 18px;
   text-decoration: none !important;
   font-size: 13px;
   font-weight: 800;
   line-height: 1;
   letter-spacing: -0.1px;
   cursor: pointer;
   transition: transform .18s ease, box-shadow .18s ease, opacity .18s ease, background .18s ease;
   -webkit-tap-highlight-color: transparent;
}

.menu-footer-btn:active {
   transform: scale(0.97);
}

.menu-footer-btn i {
   font-size: 17px;
   line-height: 1;
   flex: 0 0 auto;
}

.menu-footer-btn span {
   min-width: 0;
   overflow: hidden;
   text-overflow: ellipsis;
   white-space: nowrap;
}

.menu-footer-btn.feedback-btn {
   background: linear-gradient(180deg, rgba(245,250,247,0.96), rgba(235,244,239,0.96));
   color: #315645 !important;
   border: 1px solid rgba(95,144,120,0.14);
   box-shadow: 0 8px 18px rgba(66,101,82,0.06);
}

.menu-footer-btn.contact-btn {
   background: linear-gradient(135deg, #76b595 0%, #5f9078 100%);
   color: #ffffff !important;
   box-shadow: 0 10px 22px rgba(95,144,120,0.28);
}

.feedback-modal {
   position: fixed;
   inset: 0;
   z-index: 12000;
   display: none;
   align-items: flex-end;
   justify-content: center;
   padding: 0;
   background: rgba(18,28,22,0.26);
   backdrop-filter: blur(8px);
   -webkit-backdrop-filter: blur(8px);
}

.feedback-modal.open {
   display: flex;
}

body.feedback-modal-open .menu-order-bar,
body.feedback-modal-open .floating-waiter-btn,
body.feedback-modal-open .floating-home-btn {
   opacity: 0 !important;
   pointer-events: none !important;
}

.feedback-card {
   width: 100%;
   max-width: 100%;
   border-radius: 26px 26px 0 0;
   background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(250,253,251,0.98));
   box-shadow: 0 -18px 45px rgba(66,101,82,0.14);
   padding: 16px 16px calc(16px + env(safe-area-inset-bottom));
   position: relative;
   animation: feedbackSheetIn .22s ease;
   border-top: 1px solid rgba(255,255,255,0.82);
}

@keyframes feedbackSheetIn {
   from {
      transform: translateY(28px);
      opacity: 0;
   }
   to {
      transform: translateY(0);
      opacity: 1;
   }
}

.feedback-drag {
   width: 54px;
   height: 5px;
   border-radius: 999px;
   background: rgba(95,144,120,0.22);
   margin: 0 auto 14px;
}

.feedback-close {
   position: absolute;
   top: 12px;
   right: 12px;
   width: 36px;
   height: 36px;
   border: 0;
   border-radius: 50%;
   background: rgba(95,144,120,0.08);
   color: #315645;
   display: flex;
   align-items: center;
   justify-content: center;
   cursor: pointer;
}

.feedback-title {
   margin: 0 36px 6px 0;
   font-size: 22px;
   font-weight: 800;
   color: #2b483a;
   letter-spacing: -0.4px;
}

.feedback-subtitle {
   margin: 0 0 18px;
   font-size: 13px;
   line-height: 1.6;
   color: #6f8378;
}

.feedback-form-group {
   margin-bottom: 12px;
}

.feedback-label {
   display: block;
   margin-bottom: 7px;
   font-size: 13px;
   font-weight: 700;
   color: #355544;
}

.feedback-input,
.feedback-select,
.feedback-textarea {
   width: 100%;
   border: 1px solid rgba(95,144,120,0.14);
   background: #fff;
   border-radius: 16px;
   padding: 14px 14px;
   font-size: 15px;
   color: #22372c;
   outline: none;
   box-shadow: none;
   -webkit-appearance: none;
   appearance: none;
}

.feedback-textarea {
   min-height: 120px;
   resize: vertical;
}

.feedback-input:focus,
.feedback-select:focus,
.feedback-textarea:focus {
   border-color: rgba(95,144,120,0.55);
   box-shadow: 0 0 0 3px rgba(118,181,149,0.14);
}

.feedback-actions {
   display: flex;
   gap: 10px;
   margin-top: 10px;
}

.feedback-action-btn {
   flex: 1;
   height: 50px;
   border-radius: 16px;
   border: 1px solid rgba(95,144,120,0.10);
   font-size: 15px;
   font-weight: 800;
   cursor: pointer;
   transition: transform .18s ease;
}

.feedback-action-btn:active {
   transform: scale(0.98);
}

.feedback-cancel {
   background: #fff;
   color: #315645;
}

.feedback-submit {
   background: linear-gradient(135deg, #76b595 0%, #5f9078 100%);
   color: #fff;
   border-color: rgba(95,144,120,0.28);
   box-shadow: 0 8px 18px rgba(95,144,120,0.18);
}

.feedback-inline-error {
   display: none;
   margin: 0 0 12px;
   padding: 12px 14px;
   border-radius: 14px;
   background: #fff1f1;
   color: #b42318;
   font-size: 14px;
   font-weight: 700;
   line-height: 1.5;
}

.feedback-toast {
   position: fixed;
   left: 50%;
   top: calc(18px + env(safe-area-inset-top));
   transform: translateX(-50%);
   z-index: 3000;
   display: inline-flex;
   align-items: center;
   gap: 10px;
   min-width: 240px;
   max-width: calc(100% - 28px);
   padding: 14px 16px;
   border-radius: 16px;
   font-size: 14px;
   font-weight: 800;
   line-height: 1.4;
   box-shadow: 0 12px 32px rgba(0,0,0,0.16);
   backdrop-filter: blur(10px);
   -webkit-backdrop-filter: blur(10px);
   animation: feedbackToastIn .25s ease;
}

.feedback-toast i {
   font-size: 18px;
   flex: 0 0 auto;
}

.feedback-toast-success {
   background: rgba(236,248,238,0.96);
   color: #176b2c;
   border: 1px solid rgba(23,107,44,0.14);
}

.feedback-toast-error {
   background: rgba(255,241,241,0.97);
   color: #b42318;
   border: 1px solid rgba(180,35,24,0.14);
}

@keyframes feedbackToastIn {
   from {
      opacity: 0;
      transform: translateX(-50%) translateY(-10px);
   }
   to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
   }
}

@supports (-webkit-touch-callout: none) {
   .menu-page-footer-inner {
      -webkit-backdrop-filter: none !important;
      backdrop-filter: none !important;
      background: rgba(255,255,255,0.96);
   }

   .feedback-modal {
      -webkit-backdrop-filter: none !important;
      backdrop-filter: none !important;
      background: rgba(18,28,22,0.34);
   }
}

@media (min-width: 576px) {
   .feedback-modal {
      align-items: center;
      padding: 18px;
   }

   .feedback-card {
      max-width: 420px;
      border-radius: 24px;
      padding: 22px 18px 18px;
   }

   .feedback-drag {
      display: none;
   }
}
</style>

{% if success_message %}
<div class="feedback-toast feedback-toast-success" id="feedbackToast">
   <i class="feather-check-circle"></i>
   <span>{{ success_message }}</span>
</div>
{% endif %}

{% if error_message %}
<div class="feedback-toast feedback-toast-error" id="feedbackToast">
   <i class="feather-alert-circle"></i>
   <span>{{ error_message }}</span>
</div>
{% endif %}

<div class="menu-page-footer">
   <div class="menu-page-footer-inner">
      <button type="button" class="menu-footer-btn feedback-btn" onclick="openFeedbackModal()">
         <i class="feather-message-square"></i>
         <span>{{ text_feedback_button }}</span>
      </button>

      <a href="{{ whatsapp_link }}" target="_blank" rel="noopener" class="menu-footer-btn contact-btn">
         <i class="feather-message-circle"></i>
         <span>{{ text_whatsapp_button }}</span>
      </a>
   </div>
</div>

<div class="feedback-modal" id="feedbackModal" onclick="closeFeedbackModal(event)">
   <div class="feedback-card">
      <div class="feedback-drag"></div>

      <button type="button" class="feedback-close" aria-label="{{ text_modal_close }}" onclick="forceCloseFeedbackModal()">
         <i class="feather-x"></i>
      </button>

      <h3 class="feedback-title">{{ text_modal_title }}</h3>
      <p class="feedback-subtitle">{{ text_modal_subtitle }}</p>

      <div id="feedbackInlineError" class="feedback-inline-error"></div>

      <form action="{{ feedback_action }}" method="post" id="feedbackForm" novalidate>
         <div class="feedback-form-group">
            <label class="feedback-label" for="feedbackType">{{ text_feedback_type }}</label>
            <select id="feedbackType" name="feedback_type" class="feedback-select" required>
               <option value="oneri">{{ text_feedback_type_suggestion }}</option>
               <option value="sikayet">{{ text_feedback_type_complaint }}</option>
            </select>
         </div>

         <div class="feedback-form-group">
            <label class="feedback-label" for="feedbackName">{{ text_name }}</label>
            <input
               type="text"
               id="feedbackName"
               name="name"
               class="feedback-input"
               placeholder="{{ text_name_placeholder }}"
               required
               minlength="2"
               pattern="^[A-Za-zÇçĞğİıÖöŞşÜü\s]+$"
            >
         </div>

         <div class="feedback-form-group">
            <label class="feedback-label" for="feedbackPhone">{{ text_phone }}</label>
            <input
               type="tel"
               id="feedbackPhone"
               name="phone"
               class="feedback-input"
               placeholder="{{ text_phone_placeholder }}"
               required
               inputmode="numeric"
               maxlength="11"
               pattern="^[0-9]+$"
            >
         </div>

         <div class="feedback-form-group">
            <label class="feedback-label" for="feedbackMessage">{{ text_message }}</label>
            <textarea
               id="feedbackMessage"
               name="message"
               class="feedback-textarea"
               placeholder="{{ text_message_placeholder }}"
               required
               minlength="20"
            ></textarea>
            <div id="feedbackCharNote" class="feedback-char-note">{{ text_char_note }}</div>
         </div>

         <input type="hidden" name="page_url" value="{{ current_url }}">

         <div class="feedback-actions">
            <button type="button" class="feedback-action-btn feedback-cancel" onclick="forceCloseFeedbackModal()">{{ button_cancel }}</button>
            <button type="submit" class="feedback-action-btn feedback-submit" id="feedbackSubmitBtn" disabled>{{ button_submit }}</button>
         </div>
      </form>
   </div>
</div>

<script>
function openFeedbackModal() {
   var modal = document.getElementById('feedbackModal');
   if (!modal) return;

   modal.classList.add('open');
   document.body.classList.add('feedback-modal-open');
   document.body.style.overflowY = 'hidden';
   document.body.style.overflowX = 'hidden';
}

function closeFeedbackModal(event) {
   if (event.target.id === 'feedbackModal') {
      forceCloseFeedbackModal();
   }
}

function forceCloseFeedbackModal() {
   var modal = document.getElementById('feedbackModal');
   if (!modal) return;

   modal.classList.remove('open');
   document.body.classList.remove('feedback-modal-open');
   document.body.style.overflowY = '';
   document.body.style.overflowX = 'hidden';
}

document.addEventListener('keydown', function(e) {
   if (e.key === 'Escape') {
      forceCloseFeedbackModal();
   }
});

document.addEventListener('DOMContentLoaded', function() {
   var form = document.getElementById('feedbackForm');
   var nameInput = document.getElementById('feedbackName');
   var phoneInput = document.getElementById('feedbackPhone');
   var messageInput = document.getElementById('feedbackMessage');
   var errorBox = document.getElementById('feedbackInlineError');
   var submitBtn = document.getElementById('feedbackSubmitBtn');
   var charNote = document.getElementById('feedbackCharNote');

   var errorName = {{ error_name|json_encode|raw }};
   var errorPhone = {{ error_phone|json_encode|raw }};
   var errorMessageLength = {{ error_message_length|json_encode|raw }};
   var textCharNote = {{ text_char_note|json_encode|raw }};
   var textCharNoteValid = {{ text_char_note_valid|json_encode|raw }};

   function validateFormState() {
      if (!nameInput || !phoneInput || !messageInput || !submitBtn) return;

      var nameVal = nameInput.value.trim();
      var phoneVal = phoneInput.value.trim();
      var messageVal = messageInput.value.trim();

      var validName = /^[A-Za-zÇçĞğİıÖöŞşÜü\s]+$/.test(nameVal) && nameVal.length >= 2;
      var validPhone = /^[0-9]+$/.test(phoneVal) && phoneVal.length >= 10;
      var validMessage = messageVal.length >= 20;

      if (charNote) {
         if (validMessage) {
            charNote.textContent = textCharNoteValid;
            charNote.classList.add('valid');
         } else {
            charNote.textContent = textCharNote + ' (' + messageVal.length + '/20)';
            charNote.classList.remove('valid');
         }
      }

      submitBtn.disabled = !(validName && validPhone && validMessage);
   }

   if (phoneInput) {
      phoneInput.addEventListener('input', function() {
         this.value = this.value.replace(/\D/g, '');
         validateFormState();
      });
   }

   if (nameInput) {
      nameInput.addEventListener('input', function() {
         this.value = this.value.replace(/[^A-Za-zÇçĞğİıÖöŞşÜü\s]/g, '');
         validateFormState();
      });
   }

   if (messageInput) {
      messageInput.addEventListener('input', function() {
         validateFormState();
      });
   }

   if (form && nameInput && phoneInput && messageInput && errorBox) {
      form.addEventListener('submit', function(e) {
         var nameVal = nameInput.value.trim();
         var phoneVal = phoneInput.value.trim();
         var messageVal = messageInput.value.trim();

         errorBox.style.display = 'none';
         errorBox.textContent = '';

         if (!/^[A-Za-zÇçĞğİıÖöŞşÜü\s]+$/.test(nameVal) || nameVal.length < 2) {
            e.preventDefault();
            errorBox.textContent = errorName;
            errorBox.style.display = 'block';
            nameInput.focus();
            return;
         }

         if (!/^[0-9]+$/.test(phoneVal)) {
            e.preventDefault();
            errorBox.textContent = errorPhone;
            errorBox.style.display = 'block';
            phoneInput.focus();
            return;
         }

         if (messageVal.length < 20) {
            e.preventDefault();
            errorBox.textContent = errorMessageLength;
            errorBox.style.display = 'block';
            messageInput.focus();
            return;
         }
      });
   }

   validateFormState();

   var toast = document.getElementById('feedbackToast');
   if (toast) {
      setTimeout(function() {
         toast.style.transition = 'opacity .25s ease, transform .25s ease';
         toast.style.opacity = '0';
         toast.style.transform = 'translateX(-50%) translateY(-8px)';
      }, 2500);

      setTimeout(function() {
         if (toast && toast.parentNode) {
            toast.parentNode.removeChild(toast);
         }
      }, 2900);
   }
});
</script>
