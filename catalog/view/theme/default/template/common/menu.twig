<script>
(function() {
   var addEndpoint = '{{ menu_order_endpoint|e('js') }}';
var updateEndpoint = 'index.php?route=common/menu_order/update';
var summaryEndpoint = 'index.php?route=common/menu_order/summary';
var submitEndpoint = 'index.php?route=common/menu_order/submit';
var requestBillEndpoint = 'index.php?route=common/menu_order/requestBill';
var requestWaiterEndpoint = 'index.php?route=common/menu_order/requestWaiter';

var menuOrderLocale = {
   orderTitle: '{{ text_menu_order|e('js') }}',
   tableLabel: '{{ text_table|e('js') }}',
   choices: '{{ text_menu_choices|e('js') }}',
   add: '{{ text_menu_add|e('js') }}',
   added: '{{ text_menu_added|e('js') }}',
   orderNote: '{{ text_order_note|e('js') }}',
   orderNotePlaceholder: '{{ text_order_note_placeholder|e('js') }}',
   activeOrderInfo: '{{ text_active_order_info|e('js') }}',
   newOrder: '{{ text_new_order|e('js') }}',
   additionalOrder: '{{ text_additional_order|e('js') }}',
   requestBill: '{{ text_request_bill|e('js') }}',
   billRequested: '{{ text_bill_requested|e('js') }}',
   billRequestSeen: '{{ text_bill_request_seen|e('js') }}',
   billPaymentCash: '{{ text_bill_payment_cash|e('js') }}',
   billPaymentCard: '{{ text_bill_payment_card|e('js') }}',
   sendOrder: '{{ text_send_order|e('js') }}',
   orderSendFailed: '{{ text_order_send_failed|e('js') }}',
   orderSent: '{{ text_order_sent|e('js') }}',
   orderItemAddFailed: '{{ text_order_item_add_failed|e('js') }}',
   orderItemAdded: '{{ text_order_item_added|e('js') }}',
   requestBillFailed: '{{ text_request_bill_failed|e('js') }}',
   waiterConfirm: '{{ text_waiter_confirm|e('js') }}',
   waiterCallFailed: '{{ text_waiter_call_failed|e('js') }}',
   waiterCalled: '{{ text_waiter_called|e('js') }}',
   waiterCallWaiting: 'Garson çağrıldı',
   waiterCallSeen: 'Garson çağrınızı gördü',
   tableBill: '{{ text_table_bill|e('js') }}',
   billSummary: '{{ text_bill_summary|e('js') }}',
   activeOrdersTitle: '{{ text_active_orders|e('js') }}',
   tableTotalLabel: '{{ text_table_total|e('js') }}',
   orderStatusWaiting: '{{ text_order_waiting|e('js') }}',
   orderStatusKitchen: '{{ text_order_in_kitchen|e('js') }}',
   orderStatusReadyForService: '{{ text_order_ready_for_service|e('js') }}',
   orderStatusOutForService: '{{ text_order_out_for_service|e('js') }}',
   orderStatusServed: '{{ text_order_served|e('js') }}',
   orderHistory: '{{ text_order_history|e('js') }}',
   orderSentToWaiter: '{{ text_order_sent_to_waiter|e('js') }}'
};
var waiterCallPosting = false;
var billRequestPosting = false;

function getBillRequestButtonText(state) {
   return state && state.bill_request && state.bill_request.status == 'seen'
      ? menuOrderLocale.billRequestSeen
      : menuOrderLocale.billRequested;
}

function openBillPaymentModal() {
   $('#billPaymentModal').fadeIn(120);
}

function closeBillPaymentModal() {
   $('#billPaymentModal').fadeOut(120);
}

function submitBillRequest(paymentMethod) {
   if (billRequestPosting) {
      return;
   }

   var paymentLabel = paymentMethod === 'card' ? menuOrderLocale.billPaymentCard : menuOrderLocale.billPaymentCash;
   billRequestPosting = true;
   $('.bill-payment-choice').prop('disabled', true);

   $.post(requestBillEndpoint, { note: 'Ödeme tercihi: ' + paymentLabel }, function(resp) {
      if (!resp || !resp.success) {
         toast(resp && resp.message ? resp.message : menuOrderLocale.requestBillFailed);
         return;
      }

      closeBillPaymentModal();

      if (resp.state) {
         applyState(resp.state);
      }

      toast(resp.message || menuOrderLocale.orderSentToWaiter);
   }, 'json').always(function() {
      billRequestPosting = false;
      $('.bill-payment-choice').prop('disabled', false);
   });
}

   function toast(message) {
      var el = document.getElementById('menuOrderToast');
      if (!el) return;
      el.textContent = message;
      el.style.display = 'block';
      setTimeout(function() {
         el.style.display = 'none';
      }, 2600);
   }

   function updateBar(state) {
      var bar = document.getElementById('menuOrderBar');
      var count = document.getElementById('menuOrderCount');
      var totalQty = document.getElementById('menuOrderTotalQty');

      if (!bar || !count || !totalQty) return;

      if ((!state.cart.total_qty || state.cart.total_qty == 0) && !state.has_open_orders) {
         bar.style.display = 'none';
         document.body.classList.remove('has-order-bar');
         count.textContent = menuOrderLocale.choices;
         totalQty.textContent = '0';
         return;
      }

      bar.style.display = 'block';
    document.body.classList.add('has-order-bar');
      if (state.has_open_orders) {
         count.textContent = menuOrderLocale.orderTitle;
      } else {
         count.textContent = menuOrderLocale.newOrder;
      }

     if(state.has_open_orders && (!state.cart.total_qty || state.cart.total_qty==0)){
   totalQty.textContent='';
}else{
   totalQty.textContent=state.cart.total_qty || 0;
}
   }

   function getOrderStatusText(status) {
      return status == 'waiting_order'
         ? menuOrderLocale.orderStatusWaiting
         : status == 'in_kitchen'
         ? menuOrderLocale.orderStatusKitchen
         : status == 'ready_for_service'
         ? menuOrderLocale.orderStatusReadyForService
         : status == 'out_for_service'
         ? menuOrderLocale.orderStatusOutForService
         : status == 'served'
         ? menuOrderLocale.orderStatusServed
         : status;
   }

   function getOrderTimelineIndex(status) {
      if (status == 'waiting_order') return 0;
      if (status == 'in_kitchen') return 1;
      if (status == 'ready_for_service' || status == 'out_for_service') return 2;
      if (status == 'served') return 3;

      return 0;
   }

   function renderOrderTimeline(order) {
      var activeIndex = getOrderTimelineIndex(order.status);
      var serviceLabel = order.status == 'out_for_service'
         ? menuOrderLocale.orderStatusOutForService
         : menuOrderLocale.orderStatusReadyForService;
      var steps = [
         menuOrderLocale.orderStatusWaiting,
         menuOrderLocale.orderStatusKitchen,
         serviceLabel,
         menuOrderLocale.orderStatusServed
      ];
      var html = '<div class="menu-order-timeline status-' + order.status + '">';

      steps.forEach(function(label, index) {
         var cls = index < activeIndex ? 'done' : (index == activeIndex ? 'current' : 'pending');
         html += '<div class="menu-order-timeline-step ' + cls + '">';
         html += '<span></span>';
         html += '<small>' + label + '</small>';
         html += '</div>';
      });

      html += '</div>';

      return html;
   }

   function renderActiveOrders(state) {

   var wrap = document.getElementById('menuOrderActiveWrap');
   if (!wrap) return;

   if (!state || !state.has_open_orders || !state.active_orders || !state.active_orders.length) {
      wrap.innerHTML='';
      return;
   }

   var html = '<div class="menu-order-active-title">' + menuOrderLocale.activeOrdersTitle + '</div>';

   if (state.table_total) {
      html += '<div class="menu-order-table-total">';
      html += '<span>' + menuOrderLocale.tableTotalLabel + '</span>';
      html += '<strong>' + state.table_total + '</strong>';
      html += '</div>';
   }

   state.active_orders.forEach(function(order){

      html += '<div class="menu-order-history-card status-' + order.status + '">';
      html += '<div class="menu-order-history-head">';
      html += '<div class="menu-order-history-time">' + menuOrderLocale.orderHistory + ' ' + order.time + '</div>';
      html += '<div class="menu-order-history-status">' + getOrderStatusText(order.status) + '</div>';
      html += '</div>';
      html += renderOrderTimeline(order);

      if (order.status === 'in_kitchen' && order.prep_minutes) {
         html += '<div class="menu-order-prep-timer" data-deadline="' + (order.prep_deadline_ts || 0) + '">';
         html += '<span>Tahmini süre</span>';
         html += '<strong>' + (order.prep_label || (order.prep_minutes + ' dk')) + '</strong>';

         if (order.prep_deadline_ts) {
            html += '<em class="js-customer-prep-countdown">' + formatCustomerPrepRemaining(order.prep_deadline_ts) + '</em>';
         }

         html += '</div>';
      }

      order.items.forEach(function(item){
         html += '<div class="menu-order-history-item">'
              + item.name + ' x' + item.qty +
              '</div>';
      });

      html += '</div>';

   });

   wrap.innerHTML = html;
}

function formatCustomerPrepRemaining(deadlineTs) {
   deadlineTs = parseInt(deadlineTs, 10) || 0;

   if (!deadlineTs) {
      return '';
   }

   var remaining = Math.floor((deadlineTs * 1000 - Date.now()) / 1000);
   var overdue = remaining < 0;
   remaining = Math.abs(remaining);

   var minutes = Math.floor(remaining / 60);
   var seconds = remaining % 60;
   var text = String(minutes).padStart(2, '0') + ':' + String(seconds).padStart(2, '0');

   return overdue ? '-' + text : text;
}

function tickCustomerPrepCountdowns() {
   var timers = document.querySelectorAll('.menu-order-prep-timer[data-deadline]');

   timers.forEach(function(timer) {
      var countdown = timer.querySelector('.js-customer-prep-countdown');
      var deadline = parseInt(timer.getAttribute('data-deadline'), 10) || 0;

      if (!countdown || !deadline) {
         return;
      }

      countdown.textContent = formatCustomerPrepRemaining(deadline);

      if ((deadline * 1000 - Date.now()) < 0) {
         timer.classList.add('overdue');
      } else {
         timer.classList.remove('overdue');
      }
   });
}

   function renderCart(summary) {
      var wrap = document.getElementById('menuOrderItems');
      if (!wrap) return;

      if (!summary || !summary.items || !summary.items.length) {
         wrap.innerHTML = '';
         return;
      }

      var html = '';

      summary.items.forEach(function(item) {
         html += ''
         + '<div class="menu-order-item">'
         + '  <div>'
         + '    <div class="menu-order-item-name">' + item.name + '</div>'
         + '    <div class="menu-order-item-meta">' + item.price + '</div>'
         + '  </div>'
         + '  <div class="menu-order-qty">'
         + '    <button type="button" class="menu-order-minus" data-product-id="' + item.product_id + '" data-qty="' + item.quantity + '">-</button>'
         + '    <strong>' + item.quantity + '</strong>'
         + '    <button type="button" class="menu-order-plus" data-product-id="' + item.product_id + '" data-qty="' + item.quantity + '">+</button>'
         + '  </div>'
         + '</div>';
      });

      wrap.innerHTML = html;
   }

   function applyState(state) {
   if (!state) return;

   updateBar(state);
   renderActiveOrders(state);
   renderCart(state.cart || {});
   updateWaiterCallButton(state);

   var cartCount = 0;

   if (state.cart && state.cart.items) {
      cartCount = state.cart.items.length;
   }

   var noteWrap   = document.getElementById('menuOrderNoteWrap');
   var footerWrap = document.getElementById('menuOrderFooter');
   var infoText   = document.getElementById('menuOrderInfoText');
   var modalTitle = document.querySelector('.menu-order-sheet-head h3');
   var submitBtn  = document.getElementById('menuOrderSubmit');
   var billBtn    = document.getElementById('menuRequestBill');

   if (state.has_open_orders && cartCount === 0) {
      if (modalTitle) {
         modalTitle.innerHTML = menuOrderLocale.orderTitle;
      }
      if (noteWrap) {
         noteWrap.style.display = 'none';
      }

      if (submitBtn) {
         submitBtn.style.display = 'none';
      }

      var showBillButton = false;

      if (billBtn) {
         if (state.can_request_bill && !state.has_pending_bill_request) {
            billBtn.style.display = 'inline-flex';
            billBtn.textContent = menuOrderLocale.requestBill;
            billBtn.disabled = false;
            showBillButton = true;
         } else if (state.has_pending_bill_request) {
            billBtn.style.display = 'inline-flex';
            billBtn.textContent = getBillRequestButtonText(state);
            billBtn.disabled = true;
            showBillButton = true;
         } else {
            billBtn.style.display = 'none';
            billBtn.disabled = false;
         }
      }

      if (footerWrap) {
         footerWrap.style.display = showBillButton ? 'flex' : 'none';
      }

      if (infoText) {
         infoText.style.display = 'block';
      }

   } else {
      if (cartCount > 0) {
         if (modalTitle) {
            modalTitle.innerHTML = menuOrderLocale.additionalOrder;
         }
      } else {
         if (modalTitle) {
            modalTitle.innerHTML = menuOrderLocale.choices;
         }
      }

      if (noteWrap) {
         noteWrap.style.display = '';
      }

      if (submitBtn) {
         submitBtn.style.display = '';
      }

      var showBillButtonInCartMode = false;

      if (billBtn) {
         if (state.can_request_bill && !state.has_pending_bill_request) {
            billBtn.style.display = 'inline-flex';
            billBtn.textContent = menuOrderLocale.requestBill;
            billBtn.disabled = false;
            showBillButtonInCartMode = true;
         } else if (state.has_pending_bill_request) {
            billBtn.style.display = 'inline-flex';
            billBtn.textContent = getBillRequestButtonText(state);
            billBtn.disabled = true;
            showBillButtonInCartMode = true;
         } else {
            billBtn.style.display = 'none';
            billBtn.disabled = false;
         }
      }

      if (footerWrap) {
         footerWrap.style.display = (cartCount > 0 || showBillButtonInCartMode) ? 'flex' : 'none';
      }

      if (infoText) {
         infoText.style.display = 'none';
      }
   }
}

function updateWaiterCallButton(state) {
   var btn = document.getElementById('callWaiterBtn');
   if (!btn) return;

   var label = btn.querySelector('span');
   var waiterCall = state && state.waiter_call ? state.waiter_call : {};

   if (waiterCall && waiterCall.call_id) {
      btn.classList.add('disabled');
      btn.setAttribute('aria-disabled', 'true');
      if (label) {
         label.textContent = waiterCall.status === 'seen' ? menuOrderLocale.waiterCallSeen : menuOrderLocale.waiterCallWaiting;
      }
   } else {
      btn.classList.remove('disabled');
      btn.removeAttribute('aria-disabled');
      if (label) {
         label.textContent = '{{ text_call_waiter|e('js') }}';
      }
   }
}

   function refreshState(openIfHasItems) {
      $.get(summaryEndpoint, function(resp) {
         if (!resp || !resp.success) return;

         applyState(resp.state);

         if (openIfHasItems) {
            $('#menuOrderModal').show();
         }
      }, 'json');
   }

   $(document).on('click', '.order-add-btn', function() {
      var btn = $(this);
      var productId = btn.data('product-id');

      $.post(addEndpoint, { product_id: productId }, function(resp) {
         if (!resp || !resp.success) {
            toast(resp && resp.message ? resp.message : menuOrderLocale.orderItemAddFailed);
            return;
         }

         btn.addClass('added').text(menuOrderLocale.added);

         setTimeout(function() {
            btn.removeClass('added').text(menuOrderLocale.add);
         }, 1200);

         applyState(resp.state);
         toast(resp.message || menuOrderLocale.orderItemAdded);
      }, 'json');
   });

   $('#menuOrderBarBtn').on('click', function() {
      refreshState(true);
   });

   $('#menuOrderClose, .menu-order-backdrop').on('click', function() {
      $('#menuOrderModal').hide();
   });

   $(document).on('click', '.menu-order-plus', function() {
      var productId = $(this).data('product-id');
      var qty = parseInt($(this).data('qty'), 10) || 0;

      $.post(updateEndpoint, {
         product_id: productId,
         quantity: qty + 1
      }, function(resp) {
         if (resp && resp.success) {
            applyState(resp.state);
         }
      }, 'json');
   });

   $(document).on('click', '.menu-order-minus', function() {
      var productId = $(this).data('product-id');
      var qty = parseInt($(this).data('qty'), 10) || 0;

      $.post(updateEndpoint, {
         product_id: productId,
         quantity: qty - 1
      }, function(resp) {
         if (resp && resp.success) {
            applyState(resp.state);
         }
      }, 'json');
   });

   $('#menuOrderSubmit').on('click', function() {
      var note = $('#menuOrderNote').val() || '';

      $.post(submitEndpoint, { note: note }, function(resp) {
         if (!resp || !resp.success) {
            toast(resp && resp.message ? resp.message : menuOrderLocale.orderSendFailed);
            return;
         }

         $('#menuOrderNote').val('');
         $('#menuOrderModal').hide();

         if (resp.state) {
            applyState(resp.state);
         }

         toast(resp.message || menuOrderLocale.orderSent);
      }, 'json');
   });
$('#menuRequestBill').on('click', function() {
   openBillPaymentModal();
});

$('.bill-payment-choice').on('click', function() {
   submitBillRequest($(this).attr('data-payment-method'));
});

$('.bill-payment-cancel, .bill-payment-backdrop').on('click', function() {
   closeBillPaymentModal();
});
$(document).on('click', '#callWaiterBtn', function(e) {
   e.preventDefault();

   if (!e.originalEvent || e.originalEvent.isTrusted === false || waiterCallPosting) {
      return;
   }

   if ($(this).hasClass('disabled')) {
      return;
   }

   if(!confirm(menuOrderLocale.waiterConfirm)){
      return;
   }

   var btn = $(this);
   waiterCallPosting = true;
   btn.addClass('disabled');

   $.post(requestWaiterEndpoint, {}, function(resp) {
      if (!resp || !resp.success) {
         toast(resp && resp.message ? resp.message : menuOrderLocale.waiterCallFailed);
         btn.removeClass('disabled');
         return;
      }

      toast(resp.message || menuOrderLocale.waiterCalled);
      if (resp.state) {
         applyState(resp.state);
      } else {
         btn.addClass('disabled');
      }
   }, 'json').always(function() {
      waiterCallPosting = false;
   });
});
function watchMenuFooterVisibility(){
	var footer = document.querySelector('#vvMenuFooterWatch');
	if(!footer){
		return;
	}

	function checkFooter(){
		var rect = footer.getBoundingClientRect();
		var windowHeight = window.innerHeight || document.documentElement.clientHeight;

		if(rect.top < windowHeight && rect.bottom > 0){
			document.body.classList.add('footer-visible');
		}else{
			document.body.classList.remove('footer-visible');
		}
	}

	window.addEventListener('scroll', checkFooter, { passive:true });
	window.addEventListener('resize', checkFooter);
	checkFooter();
}

setTimeout(function(){
	watchMenuFooterVisibility();
}, 300);
setInterval(tickCustomerPrepCountdowns, 1000);
setInterval(function(){
   refreshState(false);
}, 10000);
refreshState(false);
})();
