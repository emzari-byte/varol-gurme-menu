      <script>
      function openMenuLightbox(src, alt) {
         var lightbox = document.getElementById('menuLightbox');
         var img = document.getElementById('menuLightboxImg');

         if (!lightbox || !img) return;

         img.src = src;
         img.alt = alt || '';
         lightbox.classList.add('open');
         document.body.style.overflow = 'hidden';
      }

      function closeMenuLightbox(event) {
         if (event.target.id === 'menuLightbox') {
            forceCloseMenuLightbox();
         }
      }

      function forceCloseMenuLightbox() {
         var lightbox = document.getElementById('menuLightbox');
         var img = document.getElementById('menuLightboxImg');

         if (!lightbox || !img) return;

         lightbox.classList.remove('open');
         img.src = '';
         img.alt = '';
         document.body.style.overflow = '';
      }

      document.addEventListener('keydown', function(e) {
         if (e.key === 'Escape') {
            forceCloseMenuLightbox();
         }
      });
      </script>
