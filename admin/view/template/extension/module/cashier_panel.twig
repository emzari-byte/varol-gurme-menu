{% if cashier_fullscreen %}
<!DOCTYPE html>
<html dir="ltr" lang="tr">
<head>
<meta charset="UTF-8" />
<title>Kasa Paneli</title>
<base href="{{ base|default('') }}" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
<script type="text/javascript" src="view/javascript/jquery/jquery-2.1.1.min.js"></script>
<script type="text/javascript" src="view/javascript/bootstrap/js/bootstrap.min.js"></script>
<link href="view/stylesheet/bootstrap.css" type="text/css" rel="stylesheet" />
<link href="view/javascript/font-awesome/css/font-awesome.min.css" type="text/css" rel="stylesheet" />
</head>
<body class="cashier-fullscreen-body">
{% else %}
{{ header }}{{ column_left }}
{% endif %}
<div id="content" class="cashier-content">
  {% if not cashier_fullscreen %}
  <div class="page-header">
    <div class="container-fluid">
      <h1>Kasa Paneli</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  {% endif %}

  <div class="cashier-pos">
    <style>
      .cashier-fullscreen-body{margin:0;background:#f5f7f6;color:#173126;font-family:Arial,Helvetica,sans-serif;}
      .cashier-fullscreen-body #content{margin:0;padding:0;}
      .cashier-pos{min-height:calc(100vh - 40px);background:#f5f7f6;}
      .cashier-topbar{height:64px;background:#26332d;color:#fff;display:flex;align-items:center;justify-content:space-between;box-shadow:0 8px 24px rgba(23,49,38,.12);}
      .cashier-nav{display:flex;align-items:center;height:100%;}
      .cashier-nav button,.cashier-nav a{height:64px;min-width:64px;border:0;border-right:1px solid rgba(255,255,255,.09);background:transparent;color:#fff;font-size:20px;display:flex;align-items:center;justify-content:center;text-decoration:none;}
      .cashier-nav strong{height:64px;min-width:230px;padding:0 18px;display:flex;align-items:center;border-right:1px solid rgba(255,255,255,.09);font-size:18px;font-weight:900;}
      .cashier-search{flex:1;height:100%;display:flex;align-items:center;background:#fff;}
      .cashier-pos:not(.order-mode) .cashier-search{display:none;}
      .cashier-pos:not(.order-mode) .cashier-topbar{background:#fff;color:#173126;}
      .cashier-pos:not(.order-mode) .cashier-nav button,.cashier-pos:not(.order-mode) .cashier-nav a{color:#173126;border-right:1px solid #edf2ee;}
      .cashier-pos:not(.order-mode) .cashier-nav strong{border-right:1px solid #edf2ee;}
      .cashier-pos:not(.order-mode) .cashier-user{color:#607168;}
      .cashier-search input{width:100%;height:100%;border:0;padding:0 24px;font-size:20px;font-weight:800;color:#173126;outline:none;background:#fff;}
      .cashier-user{display:flex;align-items:center;gap:10px;padding:0 18px;font-weight:800;color:#dce9e2;}
      .view{display:none;}
      .view.active{display:block;}
      .tables-view{padding:18px;}
      .table-toolbar{display:flex;align-items:center;justify-content:space-between;gap:12px;background:#fff;border:1px solid #e1e9e4;border-radius:16px 16px 0 0;padding:14px 16px;}
      .area-tabs{display:flex;gap:8px;flex-wrap:wrap;}
      .area-tab{border:1px solid #dce7e1;background:#fff;color:#54675d;border-radius:999px;padding:8px 13px;font-weight:900;}
      .area-tab.active{background:#173126;color:#fff;border-color:#173126;}
      .table-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:16px;background:#f8faf9;border:1px solid #e1e9e4;border-top:0;border-radius:0 0 16px 16px;padding:18px;min-height:calc(100vh - 150px);}
      .pos-table{min-height:132px;border:2px solid #cfe8d8;background:#f2fbf5;border-radius:16px;padding:16px;text-align:left;box-shadow:0 10px 22px rgba(23,49,38,.05);transition:.15s ease;cursor:pointer;}
      .pos-table:hover{transform:translateY(-2px);box-shadow:0 14px 28px rgba(23,49,38,.09);}
      .pos-table.occupied{border-color:#e8c0bf;background:#fff3f2;}
      .pos-table .table-no{font-size:20px;font-weight:900;color:#173126;}
      .pos-table .table-area{margin-top:5px;color:#7a887f;font-size:12px;font-weight:800;}
      .pos-table .table-status{margin-top:22px;display:flex;justify-content:space-between;align-items:end;gap:8px;}
      .pos-table .state{font-size:12px;font-weight:900;border-radius:999px;padding:5px 9px;background:#dff4e7;color:#2f6f49;}
      .pos-table.occupied .state{background:#f2d0cf;color:#9b3f3c;}
      .pos-table .amount{font-size:18px;font-weight:900;color:#173126;}
      .order-view{height:calc(100vh - 64px);display:none;grid-template-columns:430px 1fr;background:#f4f5f5;}
      .order-view.active{display:grid;}
      .receipt-pane{background:#fff;border-right:1px solid #e4e8e6;display:flex;flex-direction:column;min-height:0;}
      .receipt-head{display:flex;justify-content:space-between;align-items:center;padding:14px 16px;border-bottom:1px solid #edf2ee;font-weight:900;color:#55665d;}
      .receipt-items{padding:0 10px;overflow:auto;min-height:0;flex:1;}
      .receipt-row{display:grid;grid-template-columns:44px 1fr auto 44px;gap:10px;align-items:center;border-bottom:1px solid #edf2ee;padding:14px 0;}
      .receipt-qty{height:36px;border-radius:9px;background:#eef6f0;color:#2f6f49;display:flex;align-items:center;justify-content:center;font-weight:900;}
      .receipt-name{font-weight:900;color:#173126;}
      .receipt-sub{font-size:12px;color:#8a968f;margin-top:3px;font-weight:800;}
      .receipt-total{font-weight:900;color:#c83e38;white-space:nowrap;}
      .receipt-menu{height:40px;border:0;background:#fbfbfb;border-radius:8px;color:#c83e38;font-size:18px;}
      .receipt-empty{padding:42px 18px;text-align:center;color:#728278;font-weight:800;}
      .receipt-footer{border-top:1px solid #edf2ee;padding:14px;background:#fff;}
      .receipt-grand{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;font-weight:900;color:#173126;}
      .receipt-grand strong{font-size:22px;}
      .receipt-actions{display:grid;grid-template-columns:44px 1fr;gap:10px;}
      .receipt-actions.has-pay{grid-template-columns:44px 1fr 1fr 1fr;}
      .receipt-actions .btn{height:48px;border-radius:8px;font-weight:900;}
      .tag-btn{background:#f1f3f2;color:#c83e38;border:0;}
      .save-btn{background:#c93d38;color:#fff;border:0;}
      .product-pane{display:flex;flex-direction:column;min-width:0;}
      .category-strip{display:flex;gap:8px;overflow:auto;background:#fff;border-bottom:1px solid #e4e8e6;padding:12px;}
      .category-btn{min-width:150px;border:0;background:#fff;color:#173126;border-bottom:3px solid transparent;padding:14px 12px;font-weight:900;}
      .category-btn.active{color:#c83e38;background:#f5f5f5;border-bottom-color:#c83e38;}
      .sub-category-strip{display:flex;gap:10px;overflow:auto;padding:16px;background:#f7f8f8;border-bottom:1px solid #e4e8e6;}
      .sub-category-strip .category-btn{min-width:170px;border:1px solid #dce4df;border-radius:10px;background:#fff;color:#5d6870;border-bottom:1px solid #dce4df;}
      .product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:10px;padding:14px;overflow:auto;}
      .product-card{border:1px solid #e1e9e4;background:#fff;border-radius:10px;min-height:108px;padding:14px;text-align:left;box-shadow:0 8px 18px rgba(23,49,38,.04);cursor:pointer;}
      .product-card strong{display:block;color:#173126;font-weight:900;line-height:1.25;}
      .product-card span{display:block;margin-top:30px;color:#173126;font-weight:900;}
      .product-card:hover{border-color:#c83e38;}
      .cashier-modal-backdrop{display:none;position:fixed;inset:0;background:rgba(0,0,0,.35);z-index:40;}
      .cashier-pay-modal{display:none;position:fixed;left:50%;top:50%;transform:translate(-50%,-50%);width:min(1180px,calc(100vw - 80px));background:#fff;border-radius:6px;box-shadow:0 24px 80px rgba(0,0,0,.28);z-index:41;overflow:hidden;}
      .quick-pay-modal{width:min(520px,calc(100vw - 40px));border-radius:8px;}
      .pay-head{display:flex;align-items:center;justify-content:space-between;padding:16px 18px;border-bottom:1px solid #edf2ee;}
      .pay-head h3{margin:0;font-size:18px;font-weight:900;color:#173126;}
      .pay-close{border:0;background:transparent;color:#c83e38;font-size:24px;}
      .pay-body{display:grid;grid-template-columns:1fr 1fr .9fr;gap:16px;padding:18px;}
      .pay-box{border:1px solid #e5ebe7;border-radius:10px;min-height:390px;padding:14px;}
      .pay-box h4{margin:0 0 12px;font-size:15px;font-weight:900;color:#173126;}
      .pay-row{display:flex;justify-content:space-between;border-bottom:1px solid #edf2ee;padding:10px 0;font-weight:800;}
      .pay-total{font-size:18px;font-weight:900;text-align:right;margin:18px 0;color:#173126;}
      .keypad{display:grid;grid-template-columns:repeat(4,1fr);border:1px solid #edf2ee;border-width:1px 0 0 1px;}
      .keypad button{height:62px;border:1px solid #edf2ee;border-width:0 1px 1px 0;background:#fff;font-weight:900;font-size:16px;}
      .pay-method-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;}
      .pay-method{height:90px;border:1px solid #e1e7e3;background:#fbfdfb;border-radius:8px;font-weight:900;color:#173126;}
      .pay-method:hover{border-color:#c83e38;background:#fff8f7;}
      .quick-pay-modal .pay-method-grid{grid-template-columns:repeat(2,minmax(0,1fr));padding:16px;}
      .quick-sub{padding:0 18px 8px;color:#728278;font-weight:800;}
      @media(max-width:1100px){.order-view{grid-template-columns:360px 1fr;}.pay-body{grid-template-columns:1fr;}.cashier-pay-modal{width:calc(100vw - 30px);}}
      @media(max-width:760px){.order-view.active{display:block;height:auto;}.receipt-pane{min-height:420px;}.table-grid{grid-template-columns:repeat(2,minmax(0,1fr));}.cashier-search input{font-size:15px;}.cashier-nav strong{min-width:130px;}}
    </style>

    <div class="cashier-topbar">
      <div class="cashier-nav">
        <button type="button" id="backToTables" style="display:none;"><i class="fa fa-arrow-left"></i></button>
        <strong id="topTitle">Kasa Paneli</strong>
      </div>
      <div class="cashier-search"><input type="text" id="productSearch" placeholder="Ürün adı veya barkod ile arama"></div>
      {% if cashier_fullscreen %}
      <div class="cashier-user"><span>{{ cashier_username }}</span><a href="{{ logout_url }}"><i class="fa fa-sign-out"></i></a></div>
      {% endif %}
    </div>

    <div class="view tables-view active" id="tablesView">
      <div class="table-toolbar">
        <div class="area-tabs" id="areaTabs"></div>
        <button type="button" class="btn btn-default" id="refreshTables"><i class="fa fa-refresh"></i> Yenile</button>
      </div>
      <div class="table-grid" id="tableGrid"></div>
    </div>

    <div class="view order-view" id="orderView">
      <section class="receipt-pane">
        <div class="receipt-head">
          <span id="receiptNo">Adisyon: 0</span>
          <span>Sipariş Durumu: <b style="color:#4f8b55;">Hazırlanıyor</b></span>
        </div>
        <div class="receipt-items" id="receiptItems"></div>
        <div class="receipt-footer">
          <div class="receipt-grand"><span>Toplam Tutar</span><strong id="receiptTotal">0,00 TL</strong></div>
          <div class="receipt-actions" id="receiptActions">
            <button type="button" class="btn tag-btn"><i class="fa fa-tag"></i></button>
            <button type="button" class="btn save-btn" id="saveTableBtn">Kaydet</button>
          </div>
        </div>
      </section>

      <section class="product-pane">
        <div class="category-strip" id="categoryStrip"></div>
        <div class="sub-category-strip" id="subCategoryStrip"></div>
        <div class="product-grid" id="productGrid"></div>
      </section>
    </div>
  </div>
</div>

<div class="cashier-modal-backdrop" id="payBackdrop"></div>
<div class="cashier-pay-modal" id="payModal">
  <div class="pay-head">
    <div><h3 id="payTitle">Ödeme Ekranı</h3><strong id="payTableName"></strong></div>
    <button type="button" class="pay-close" id="closePayModal"><i class="fa fa-times"></i></button>
  </div>
  <div class="pay-body">
    <div class="pay-box">
      <h4>Parçalı Öde</h4>
      <div id="payItemList"></div>
    </div>
    <div class="pay-box">
      <h4>Toplam</h4>
      <div class="pay-total" id="payTotal">0,00 TL</div>
      <div class="keypad">
        <button>7</button><button>8</button><button>9</button><button>Tüm</button>
        <button>4</button><button>5</button><button>6</button><button>1/n</button>
        <button>1</button><button>2</button><button>3</button><button>İndirim</button>
        <button>.</button><button>0</button><button><i class="fa fa-arrow-left"></i></button><button></button>
      </div>
    </div>
    <div class="pay-box">
      <h4>Ödeme Tipleri</h4>
      <div class="pay-method-grid">
        <button type="button" class="pay-method" data-method="cash">Nakit</button>
        <button type="button" class="pay-method" data-method="card">Kredi Kartı</button>
        <button type="button" class="pay-method" data-method="complimentary">Ödenmez</button>
        <button type="button" class="pay-method" data-method="transfer">Açık Hesap</button>
      </div>
    </div>
  </div>
</div>

<div class="cashier-pay-modal quick-pay-modal" id="quickPayModal">
  <div class="pay-head">
    <div><h3 id="quickPayTitle">Hızlı Öde</h3><strong id="quickPayTotal">0,00 TL</strong></div>
    <button type="button" class="pay-close" id="closeQuickPayModal"><i class="fa fa-times"></i></button>
  </div>
  <div class="quick-sub">Siparişi hızlı öde</div>
  <div class="pay-method-grid">
    <button type="button" class="pay-method quick-method" data-method="cash">Nakit</button>
    <button type="button" class="pay-method quick-method" data-method="card">Kredi Kartı</button>
    <button type="button" class="pay-method quick-method" data-method="complimentary">Ödenmez</button>
    <button type="button" class="pay-method quick-method" data-method="transfer">Açık Hesap</button>
  </div>
</div>

<script>
(function($){
  var refreshUrl = '{{ refresh_url|replace({"&amp;":"&"}) }}';
  var payUrl = '{{ pay_url|replace({"&amp;":"&"}) }}';
  var detailUrl = '{{ detail_url|replace({"&amp;":"&"}) }}';
  var productsUrl = '{{ products_url|replace({"&amp;":"&"}) }}';
  var addProductUrl = '{{ add_product_url|replace({"&amp;":"&"}) }}';
  var tables = {{ tables_json|raw }};
  var categories = {{ categories_json|raw }};
  var products = {{ products_json|raw }};
  var selectedTableId = 0;
  var selectedArea = '';
  var selectedCategory = 0;
  var currentDetail = null;
  var searchTimer = null;

  function money(value) {
    value = parseFloat(value || 0);
    return value.toLocaleString('tr-TR', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' TL';
  }

  function escapeHtml(value) {
    return String(value === null || value === undefined ? '' : value)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;').replace(/'/g, '&#039;');
  }

  function showTables() {
    $('.cashier-pos').removeClass('order-mode');
    $('#tablesView').addClass('active');
    $('#orderView').removeClass('active');
    $('#backToTables').hide();
    $('#topTitle').text('Kasa Paneli');
    $('#productSearch').val('');
    selectedTableId = 0;
    currentDetail = null;
    refreshTables(false);
  }

  function showOrder() {
    $('.cashier-pos').addClass('order-mode');
    $('#tablesView').removeClass('active');
    $('#orderView').addClass('active');
    $('#backToTables').show();
  }

  function renderAreas() {
    var areas = {};
    tables.forEach(function(table){ areas[table.area || 'Salon'] = true; });
    var html = '<button type="button" class="area-tab ' + (selectedArea === '' ? 'active' : '') + '" data-area="">Tümü</button>';
    Object.keys(areas).forEach(function(area) {
      html += '<button type="button" class="area-tab ' + (selectedArea === area ? 'active' : '') + '" data-area="' + escapeHtml(area) + '">' + escapeHtml(area) + '</button>';
    });
    $('#areaTabs').html(html);
  }

  function renderTables() {
    renderAreas();
    var html = '';
    tables.filter(function(table){ return !selectedArea || (table.area || 'Salon') === selectedArea; }).forEach(function(table) {
      var occupied = parseFloat(table.total_amount || 0) > 0;
      html += '<button type="button" class="pos-table ' + (occupied ? 'occupied' : '') + '" data-table-id="' + table.table_id + '">';
      html += '<div class="table-no">Masa ' + escapeHtml(table.table_no) + '</div>';
      html += '<div class="table-area">' + escapeHtml(table.area || 'Salon') + '</div>';
      html += '<div class="table-status"><span class="state">' + (occupied ? 'Dolu' : 'Boş') + '</span><span class="amount">' + (occupied ? money(table.total_amount) : '') + '</span></div>';
      html += '</button>';
    });
    $('#tableGrid').html(html || '<div class="receipt-empty">Masa bulunamadı.</div>');
  }

  function renderCategories() {
    var html = '<button type="button" class="category-btn ' + (selectedCategory === 0 ? 'active' : '') + '" data-id="0">Tümü</button>';
    categories.forEach(function(category) {
      html += '<button type="button" class="category-btn ' + (parseInt(category.category_id, 10) === selectedCategory ? 'active' : '') + '" data-id="' + category.category_id + '">' + escapeHtml(category.name) + '</button>';
    });
    $('#categoryStrip').html(html);
    $('#subCategoryStrip').html('');
  }

  function renderProducts() {
    var html = '';
    products.forEach(function(product) {
      html += '<button type="button" class="product-card" data-product-id="' + product.product_id + '">';
      html += '<strong>' + escapeHtml(product.name) + '</strong><span>' + money(product.price) + '</span>';
      html += '</button>';
    });
    $('#productGrid').html(html || '<div class="receipt-empty">Ürün bulunamadı.</div>');
  }

  function renderDetail(detail) {
    currentDetail = detail || null;
    if (!detail || !detail.table) return;

    $('#topTitle').text('Masa ' + detail.table.table_no);
    $('#receiptNo').text('Adisyon: ' + (detail.orders && detail.orders.length ? detail.orders[0].restaurant_order_id : '0'));

    if (!detail.items || !detail.items.length) {
      $('#receiptItems').html('<div class="receipt-empty">Bu masada ürün yok. Sağdan ürün seçerek adisyon açabilirsiniz.</div>');
    } else {
      var html = '';
      detail.items.forEach(function(item) {
        html += '<div class="receipt-row"><div class="receipt-qty">' + item.quantity + '</div><div><div class="receipt-name">' + escapeHtml(item.name) + '</div><div class="receipt-sub">tam</div></div><div class="receipt-total">' + money(item.total) + '</div><button type="button" class="receipt-menu"><i class="fa fa-ellipsis-v"></i></button></div>';
      });
      $('#receiptItems').html(html);
    }

    $('#receiptTotal').text(money(detail.total_amount));
    var hasItems = detail.items && detail.items.length;
    $('#receiptActions')
      .toggleClass('has-pay', !!hasItems)
      .html(hasItems
        ? '<button type="button" class="btn tag-btn"><i class="fa fa-tag"></i></button><button type="button" class="btn btn-success" id="payBtn">Öde</button><button type="button" class="btn btn-warning" id="quickPayBtn"><i class="fa fa-bolt"></i> Hızlı Öde</button><button type="button" class="btn save-btn" id="saveTableBtn">Kaydet</button>'
        : '<button type="button" class="btn tag-btn"><i class="fa fa-tag"></i></button><button type="button" class="btn save-btn" id="saveTableBtn">Kaydet</button>');
  }

  function loadDetail(tableId) {
    selectedTableId = parseInt(tableId || 0, 10);
    $.getJSON(detailUrl + '&table_id=' + selectedTableId, function(json) {
      if (json && json.success) {
        showOrder();
        renderDetail(json.detail);
      }
    });
  }

  function refreshTables(keepDetail) {
    $.getJSON(refreshUrl, function(json) {
      if (!json || !json.success) return;
      tables = json.tables || [];
      renderTables();
      if (keepDetail && selectedTableId) {
        loadDetail(selectedTableId);
      }
    });
  }

  function loadProducts() {
    $.getJSON(productsUrl + '&category_id=' + selectedCategory + '&search=' + encodeURIComponent($('#productSearch').val()), function(json) {
      if (!json || !json.success) return;
      products = json.products || [];
      renderProducts();
    });
  }

  function fillPayModal(type) {
    var total = currentDetail ? currentDetail.total_amount : 0;
    var tableNo = currentDetail && currentDetail.table ? currentDetail.table.table_no : '';
    $('#payTitle').text('Masa ' + tableNo + ' Ödeme');
    $('#payTableName').text('Ödenecek Tutar: ' + money(total));
    $('#payTotal').text('Ödenecek Tutar: ' + money(total));
    $('#quickPayTitle').text('Hızlı Öde (' + money(total) + ')');
    $('#quickPayTotal').text('Masa ' + tableNo);
    var html = '';
    (currentDetail && currentDetail.items ? currentDetail.items : []).forEach(function(item) {
      html += '<div class="pay-row"><span>' + item.quantity + ' x ' + escapeHtml(item.name) + '</span><strong>' + money(item.total) + '</strong></div>';
    });
    $('#payItemList').html(html);
  }

  function openPayModal() {
    if (!selectedTableId || !currentDetail || !currentDetail.items || !currentDetail.items.length) {
      alert('Ödeme için ürün bulunan masa seçin.');
      return;
    }
    fillPayModal('pay');
    $('#payBackdrop,#payModal').show();
  }

  function openQuickPayModal() {
    if (!selectedTableId || !currentDetail || !currentDetail.items || !currentDetail.items.length) {
      alert('Hızlı ödeme için ürün bulunan masa seçin.');
      return;
    }
    fillPayModal('quick');
    $('#payBackdrop,#quickPayModal').show();
  }

  function closePayModal() {
    $('#payBackdrop,#payModal,#quickPayModal').hide();
  }

  function pay(method) {
    if (!selectedTableId || !method) return;
    $.post(payUrl, {table_id:selectedTableId, payment_method:method, note:''}, function(json) {
      if (!json || !json.success) {
        alert(json && json.message ? json.message : 'Ödeme alınamadı.');
        return;
      }
      closePayModal();
      showTables();
    }, 'json');
  }

  $(document).on('click', '.pos-table', function(){ loadDetail($(this).data('table-id')); });
  $(document).on('click', '.area-tab', function(){ selectedArea = $(this).data('area') || ''; renderTables(); });
  $(document).on('click', '.category-btn', function(){ selectedCategory = parseInt($(this).data('id') || 0, 10); renderCategories(); loadProducts(); });
  $(document).on('click', '.product-card', function(){
    if (!selectedTableId) return;
    $.post(addProductUrl, {table_id:selectedTableId, product_id:$(this).data('product-id'), quantity:1}, function(json) {
      if (!json || !json.success) {
        alert(json && json.message ? json.message : 'Ürün eklenemedi.');
        return;
      }
      renderDetail(json.detail);
      refreshTables(false);
    }, 'json');
  });
  $('#productSearch').on('input', function(){ clearTimeout(searchTimer); searchTimer = setTimeout(loadProducts, 250); });
  $('#refreshTables').on('click', function(){ refreshTables(false); });
  $('#backToTables').on('click', showTables);
  $(document).on('click', '#saveTableBtn', showTables);
  $(document).on('click', '#payBtn', openPayModal);
  $(document).on('click', '#quickPayBtn', openQuickPayModal);
  $('#closePayModal,#closeQuickPayModal,#payBackdrop').on('click', closePayModal);
  $(document).on('click', '.pay-method', function(){ pay($(this).data('method')); });

  renderTables();
  renderCategories();
  renderProducts();
  setInterval(function(){ if ($('#tablesView').hasClass('active')) refreshTables(false); }, 10000);
})(jQuery);
</script>
{% if cashier_fullscreen %}
</body></html>
{% else %}
{{ footer }}
{% endif %}
