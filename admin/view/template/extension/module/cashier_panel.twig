{% if cashier_fullscreen %}
<!DOCTYPE html>
<html dir="ltr" lang="tr">
<head>
<meta charset="UTF-8" />
<title>Kasa Paneli</title>
<base href="{{ base|default('') }}" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no" />
<script type="text/javascript" src="view/javascript/jquery/jquery-2.1.1.min.js"></script>
<script type="text/javascript" src="view/javascript/bootstrap/js/bootstrap.min.js"></script>
<link href="view/stylesheet/bootstrap.css" type="text/css" rel="stylesheet" />
<link href="view/javascript/font-awesome/css/font-awesome.min.css" type="text/css" rel="stylesheet" />
</head>
<body class="cashier-fullscreen-body">
{% else %}
{{ header }}{{ column_left }}
{% endif %}
<div id="content" class="cashier-content">
  {% if not cashier_fullscreen %}
  <div class="page-header">
    <div class="container-fluid">
      <h1>Kasa Paneli</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  {% endif %}

  <div class="cashier-pos">
    <style>
      .cashier-fullscreen-body{margin:0;background:#eef3f1;color:#173126;font-family:Arial,Helvetica,sans-serif;}
      .cashier-fullscreen-body #content{margin:0;padding:0;}
      .cashier-pos{min-height:calc(100vh - 40px);background:#eef3f1;}
      .cashier-topbar{height:62px;background:#fff;color:#173126;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #dde7e2;box-shadow:0 10px 24px rgba(23,49,38,.06);}
      .cashier-nav{display:flex;align-items:center;height:100%;}
      .cashier-nav button,.cashier-nav a{height:62px;min-width:62px;border:0;border-right:1px solid #edf2ee;background:transparent;color:#173126;font-size:19px;display:flex;align-items:center;justify-content:center;text-decoration:none;}
      .cashier-nav strong{height:62px;min-width:210px;padding:0 18px;display:flex;align-items:center;border-right:1px solid #edf2ee;font-size:20px;font-weight:900;letter-spacing:0;}
      .cashier-user{display:flex;align-items:center;gap:10px;padding:0 18px;font-weight:800;color:#607168;}
      .cashier-summary{display:grid;grid-template-columns:repeat(5,minmax(0,1fr));gap:10px;padding:14px 18px 0;background:#eef3f1;}
      .summary-card{background:#fff;border:1px solid #dfe9e4;border-radius:14px;padding:13px 14px;box-shadow:0 10px 22px rgba(23,49,38,.05);}
      .summary-card span{display:block;color:#708179;font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.02em;}
      .summary-card strong{display:block;margin-top:6px;color:#173126;font-size:20px;font-weight:900;white-space:nowrap;}
      .summary-card.warning strong{color:#bf7c16;}
      .summary-card.danger strong{color:#c83e38;}
      .view{display:none;}
      .view.active{display:block;}
      .tables-view{padding:18px;}
      .table-toolbar{display:flex;align-items:center;justify-content:space-between;gap:12px;background:#fff;border:1px solid #dfe9e4;border-radius:14px 14px 0 0;padding:12px 14px;}
      .area-tabs{display:flex;gap:8px;flex-wrap:wrap;}
      .area-tab{border:1px solid #dce7e1;background:#fff;color:#54675d;border-radius:999px;padding:9px 14px;font-weight:900;}
      .area-tab.active{background:#173126;color:#fff;border-color:#173126;}
      .table-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:12px;background:#f8faf9;border:1px solid #dfe9e4;border-top:0;border-radius:0 0 14px 14px;padding:14px;min-height:calc(100vh - 145px);align-content:start;}
      .pos-table{min-height:152px;border:1px solid #cfe8d8;background:linear-gradient(180deg,#f8fffa 0%,#eef9f2 100%);border-radius:14px;padding:13px;text-align:left;box-shadow:0 8px 18px rgba(23,49,38,.05);transition:.15s ease;cursor:pointer;display:flex;flex-direction:column;justify-content:space-between;position:relative;overflow:hidden;}
      .pos-table:hover{transform:translateY(-2px);box-shadow:0 14px 26px rgba(23,49,38,.1);}
      .pos-table.occupied{border-color:#efc2bf;background:linear-gradient(180deg,#fff7f6 0%,#fff0ee 100%);}
      .pos-table.pending{border-color:#d9b06a;background:linear-gradient(180deg,#fffaf0 0%,#fff3dd 100%);}
      .pos-table.bill{min-height:180px;box-shadow:inset 0 0 0 2px rgba(200,62,56,.12),0 10px 22px rgba(23,49,38,.07);}
      .pos-table .table-no{font-size:20px;font-weight:900;color:#173126;line-height:1;}
      .pos-table .table-area{margin-top:5px;color:#708179;font-size:12px;font-weight:800;}
      .pos-table .waiter-line{margin-top:5px;color:#42564b;font-size:12px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
      .pos-table .table-bottom{display:flex;align-items:center;justify-content:space-between;gap:8px;}
      .pos-table .state{font-size:12px;font-weight:900;border-radius:999px;padding:5px 9px;background:#dff4e7;color:#2f6f49;}
      .pos-table.occupied .state{background:#f3d4d2;color:#a43f3b;}
      .pos-table.pending .state{background:#f7e2bb;color:#8a5a08;}
      .pos-table .amount{font-size:17px;font-weight:900;color:#173126;white-space:nowrap;}
      .pos-table .mini-meta{position:absolute;right:10px;top:10px;display:flex;gap:5px;}
      .pos-table .mini-meta span{width:24px;height:24px;border-radius:8px;background:rgba(255,255,255,.8);display:flex;align-items:center;justify-content:center;color:#c83e38;}
      .bill-label{display:none;margin-top:8px;padding:6px 8px;border-radius:9px;background:#c83e38;color:#fff;font-size:11px;font-weight:900;max-width:100%;white-space:normal;line-height:1.25;}
      .pos-table.bill .bill-label{display:inline-flex;align-items:center;gap:5px;}
      .bill-method{display:inline-flex;margin-top:6px;padding:5px 8px;border-radius:999px;background:#fff;color:#173126;border:1px solid #efd2ce;font-size:11px;font-weight:900;max-width:100%;white-space:normal;line-height:1.25;}
      .pos-table.bill.new-bill{animation:cashierPulse 1.2s ease-in-out infinite;}
      @keyframes cashierPulse{0%,100%{box-shadow:inset 0 0 0 2px rgba(200,62,56,.12),0 10px 22px rgba(23,49,38,.07);}50%{box-shadow:inset 0 0 0 3px rgba(200,62,56,.28),0 14px 34px rgba(200,62,56,.2);}}
      .empty-state{grid-column:1 / -1;min-height:160px;display:flex;align-items:center;justify-content:center;color:#728278;font-weight:900;}
      .order-view{height:calc(100vh - 62px);display:none;grid-template-columns:390px 1fr;background:#f4f6f5;}
      .order-view.active{display:grid;}
      .receipt-pane{background:#fff;border-right:1px solid #e0e7e3;display:flex;flex-direction:column;min-height:0;}
      .receipt-head{padding:14px 16px;border-bottom:1px solid #edf2ee;}
      .receipt-title{display:flex;align-items:center;justify-content:space-between;gap:12px;font-weight:900;color:#173126;}
      .receipt-meta{display:flex;align-items:center;justify-content:space-between;gap:10px;margin-top:8px;color:#6f7f76;font-size:12px;font-weight:800;}
      .receipt-items{padding:10px;overflow:auto;min-height:0;flex:1;}
      .receipt-row{display:grid;grid-template-columns:48px 1fr auto;gap:10px;align-items:center;border:1px solid #edf2ee;border-radius:12px;padding:10px;margin-bottom:9px;background:#fff;box-shadow:0 6px 16px rgba(23,49,38,.04);}
      .receipt-row.is-paid{opacity:.55;background:#f5f7f6;}
      .receipt-row.pay-selected{border-color:#2f6f49;box-shadow:0 0 0 2px rgba(47,111,73,.16),0 6px 16px rgba(23,49,38,.05);}
      .qty-badge{width:42px;height:42px;border-radius:12px;background:#f3f7f5;color:#173126;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:18px;}
      .receipt-name{font-weight:900;color:#173126;line-height:1.25;}
      .receipt-sub{font-size:12px;color:#8a968f;margin-top:4px;font-weight:800;}
      .receipt-total{font-weight:900;color:#173126;white-space:nowrap;text-align:right;}
      .row-actions{display:flex;justify-content:flex-end;gap:6px;margin-top:8px;}
      .row-actions button{width:32px;height:30px;border:0;border-radius:8px;background:#f5f7f6;color:#c83e38;}
      .pay-select{color:#2f6f49!important;}
      .pay-select.is-selected{background:#2f6f49!important;color:#fff!important;}
      .paid-chip{display:inline-flex;margin-top:5px;padding:3px 7px;border-radius:999px;background:#e8f3ed;color:#2f6f49;font-size:11px;font-weight:900;}
      .receipt-empty{height:100%;min-height:240px;display:flex;align-items:center;justify-content:center;text-align:center;color:#728278;font-weight:900;padding:20px;}
      .receipt-footer{border-top:1px solid #edf2ee;padding:12px;background:#fff;}
      .receipt-grand{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;font-weight:900;color:#173126;}
      .receipt-grand strong{font-size:22px;}
      .receipt-actions{display:grid;grid-template-columns:42px 1fr;gap:8px;}
      .receipt-actions.has-pay{grid-template-columns:repeat(2,minmax(0,1fr));}
      .receipt-actions .btn{height:46px;border-radius:10px;font-weight:900;}
      .tag-btn{background:#f1f3f2;color:#c83e38;border:0;}
      .save-btn{background:#173126;color:#fff;border:0;}
      .product-pane{display:flex;flex-direction:column;min-width:0;min-height:0;}
      .product-tools{display:grid;grid-template-columns:minmax(260px,1fr) auto;gap:12px;padding:12px;background:#fff;border-bottom:1px solid #e0e7e3;}
      .product-search-box{position:relative;}
      .product-search-box i{position:absolute;left:14px;top:50%;transform:translateY(-50%);color:#7f8c85;}
      .product-search-box input{width:100%;height:46px;border:1px solid #dce7e1;border-radius:12px;padding:0 14px 0 40px;font-size:15px;font-weight:800;outline:none;background:#fbfdfb;}
      .product-search-box input:focus{border-color:#2f6f49;background:#fff;box-shadow:0 0 0 3px rgba(47,111,73,.1);}
      .search-hint{font-size:12px;color:#728278;font-weight:800;margin-top:5px;padding-left:4px;}
      .category-strip{display:flex;gap:8px;overflow:auto;background:#fff;border-bottom:1px solid #e0e7e3;padding:0 12px 12px;}
      .category-btn{white-space:nowrap;border:1px solid #dce7e1;background:#fff;color:#4f6158;border-radius:999px;padding:9px 14px;font-weight:900;}
      .category-btn.active{color:#fff;background:#173126;border-color:#173126;}
      .product-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:12px;padding:14px;overflow:auto;align-content:start;}
      .product-card{border:1px solid #dfe7e3;background:#fff;border-radius:14px;min-height:190px;padding:10px;text-align:left;box-shadow:0 8px 20px rgba(23,49,38,.05);cursor:pointer;display:flex;flex-direction:column;gap:10px;position:relative;overflow:hidden;}
      .product-card:hover{border-color:#2f6f49;transform:translateY(-1px);}
      .product-img{height:94px;border-radius:11px;background:#edf3ef;display:flex;align-items:center;justify-content:center;overflow:hidden;color:#2f6f49;font-weight:900;font-size:22px;}
      .product-img img{width:100%;height:100%;object-fit:cover;display:block;}
      .product-card strong{display:block;color:#173126;font-weight:900;line-height:1.22;min-height:38px;}
      .product-price{margin-top:auto;display:flex;align-items:center;justify-content:space-between;gap:8px;color:#173126;font-weight:900;}
      .product-add{width:34px;height:34px;border-radius:10px;background:#2f6f49;color:#fff;display:flex;align-items:center;justify-content:center;}
      .cashier-modal-backdrop{display:none;position:fixed;inset:0;background:rgba(13,20,17,.46);z-index:40;backdrop-filter:blur(2px);}
      .cashier-pay-modal{display:none;position:fixed;left:50%;top:50%;transform:translate(-50%,-50%);width:min(1120px,calc(100vw - 70px));background:#fff;border-radius:18px;box-shadow:0 26px 90px rgba(0,0,0,.28);z-index:41;overflow:hidden;}
      .quick-pay-modal{width:min(560px,calc(100vw - 36px));}
      .pay-head{display:flex;align-items:center;justify-content:space-between;padding:18px 20px;background:#173126;color:#fff;}
      .pay-head h3{margin:0;font-size:20px;font-weight:900;color:#fff;}
      .pay-head strong{display:block;margin-top:4px;color:#cfe8d8;}
      .pay-close{border:0;background:rgba(255,255,255,.12);color:#fff;width:38px;height:38px;border-radius:10px;font-size:20px;}
      .pay-body{display:grid;grid-template-columns:1fr .9fr 1fr;gap:14px;padding:16px;background:#f7faf8;}
      .pay-box{background:#fff;border:1px solid #e2e9e5;border-radius:14px;min-height:360px;padding:14px;box-shadow:0 10px 24px rgba(23,49,38,.06);}
      .pay-box h4{margin:0 0 12px;font-size:15px;font-weight:900;color:#173126;}
      .pay-row{display:flex;justify-content:space-between;gap:10px;border-bottom:1px solid #edf2ee;padding:10px 0;font-weight:800;color:#173126;}
      .pay-row.selectable{cursor:pointer;border:1px solid #edf2ee;border-radius:10px;padding:10px;margin-bottom:8px;background:#fff;}
      .pay-row.selectable.is-selected{border-color:#2f6f49;background:#f1faf5;box-shadow:0 0 0 2px rgba(47,111,73,.12);}
      .pay-row.selectable.is-paid{opacity:.5;text-decoration:line-through;cursor:not-allowed;}
      .pay-summary{margin-top:14px;border-top:1px solid #edf2ee;padding-top:12px;display:grid;gap:8px;}
      .pay-summary-row{display:flex;align-items:center;justify-content:space-between;font-weight:900;color:#5f7067;}
      .pay-summary-row strong{color:#173126;font-size:18px;}
      .pay-summary-row.remaining strong{color:#c83e38;font-size:22px;}
      .pay-history{margin-top:10px;border-top:1px solid #edf2ee;padding-top:8px;}
      .pay-history-title{color:#708179;font-size:12px;font-weight:900;text-transform:uppercase;margin-bottom:4px;}
      .pay-entry{display:grid;gap:10px;margin-bottom:12px;}
      .pay-entry label{margin:0;color:#5f7067;font-weight:900;}
      .pay-entry input{height:54px;border:1px solid #dce7e1;border-radius:12px;padding:0 14px;text-align:right;font-size:24px;font-weight:900;color:#173126;outline:none;}
      .pay-entry input:focus{border-color:#2f6f49;box-shadow:0 0 0 3px rgba(47,111,73,.1);}
      .pay-total{font-size:22px;font-weight:900;text-align:right;margin:10px 0 14px;color:#173126;}
      .keypad{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;}
      .keypad button{height:54px;border:1px solid #e1e7e3;border-radius:10px;background:#fff;font-weight:900;font-size:16px;color:#173126;}
      .keypad button.action{background:#f1f5f3;color:#2f6f49;}
      .pay-method-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px;}
      .pay-method{height:102px;border:1px solid #e1e7e3;background:#fff;border-radius:14px;font-weight:900;color:#173126;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:9px;}
      .pay-method i{font-size:28px;color:#2f6f49;}
      .pay-method:hover{border-color:#2f6f49;background:#f3fbf6;}
      .pay-method.is-busy{pointer-events:none;opacity:.65;}
      .amount-shortcuts{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:8px;margin-bottom:12px;}
      .amount-shortcuts button{height:38px;border:1px solid #dfe7e3;border-radius:10px;background:#fff;color:#173126;font-weight:900;}
      .cashier-toast{display:none;position:fixed;right:18px;bottom:18px;z-index:80;max-width:360px;background:#173126;color:#fff;border-radius:14px;padding:13px 15px;font-weight:900;box-shadow:0 18px 48px rgba(0,0,0,.24);}
      .cashier-toast.error{background:#c83e38;}
      .cashier-toast.success{background:#2f6f49;}
      .quick-pay-modal .pay-method-grid{grid-template-columns:repeat(2,minmax(0,1fr));padding:16px;background:#f7faf8;}
      .quick-sub{padding:14px 18px 0;color:#728278;font-weight:800;background:#f7faf8;}
      .cancel-modal{width:min(620px,calc(100vw - 36px));}
      .cancel-body{padding:22px;background:#fff;}
      .cancel-body h4{margin:0;font-size:24px;font-weight:900;color:#242424;}
      .cancel-body .cancel-product{margin:6px 0 22px;color:#5f6662;font-size:15px;font-weight:800;}
      .cancel-summary{display:grid;grid-template-columns:1fr auto;gap:10px;padding:12px 14px;border:1px solid #edf2ee;border-radius:12px;background:#f8faf9;margin-bottom:16px;color:#173126;font-weight:900;}
      .cancel-summary small{display:block;margin-top:3px;color:#728278;font-weight:800;}
      .cancel-error{display:none;color:#c83e38;font-weight:900;margin-bottom:12px;}
      .cancel-reasons{border-top:2px solid #d3423c;padding-top:18px;margin-top:14px;}
      .cancel-option{display:flex;align-items:center;gap:12px;border-bottom:1px solid #edf2ee;padding:14px 0;font-size:18px;font-weight:900;color:#303030;cursor:pointer;}
      .cancel-option input{width:22px;height:22px;margin:0;}
      .cancel-note{width:100%;min-height:86px;margin-top:14px;border:1px solid #dfe7e3;border-radius:12px;padding:12px;resize:vertical;font-weight:700;}
      .cancel-actions{display:flex;justify-content:flex-end;align-items:center;gap:14px;padding:16px 22px;background:#fff;}
      .cancel-actions .btn-link{color:#c83e38;font-weight:900;text-decoration:none;}
      .cancel-actions .btn-danger{height:48px;min-width:110px;border-radius:7px;font-weight:900;background:#c83e38;border-color:#c83e38;box-shadow:0 8px 18px rgba(200,62,56,.24);}
      @media(max-width:1180px){.order-view{grid-template-columns:360px 1fr;}.pay-body{grid-template-columns:1fr;}.cashier-pay-modal{width:calc(100vw - 28px);max-height:calc(100vh - 30px);overflow:auto;}.cashier-summary{grid-template-columns:repeat(2,minmax(0,1fr));}}
      @media(max-width:780px){.order-view.active{display:block;height:auto;}.receipt-pane{min-height:420px;}.table-grid{grid-template-columns:repeat(2,minmax(0,1fr));}.product-tools{grid-template-columns:1fr;}.cashier-nav strong{min-width:140px;}.receipt-actions.has-pay{grid-template-columns:1fr 1fr;}.tag-btn{display:none;}}
    </style>

    <div class="cashier-topbar">
      <div class="cashier-nav">
        <button type="button" id="backToTables" style="display:none;"><i class="fa fa-arrow-left"></i></button>
        <strong id="topTitle">Kasa Paneli</strong>
      </div>
      {% if cashier_fullscreen %}
      <div class="cashier-user"><span>{{ cashier_username }}</span><a href="{{ logout_url }}"><i class="fa fa-sign-out"></i></a></div>
      {% endif %}
    </div>

    {% if not cashier_fullscreen %}
    <div class="cashier-summary" id="cashierSummary"></div>
    {% endif %}

    <div class="view tables-view active" id="tablesView">
      <div class="table-toolbar">
        <div class="area-tabs" id="areaTabs"></div>
        <div>
          <button type="button" class="btn btn-default" id="refreshTables"><i class="fa fa-refresh"></i> Yenile</button>
        </div>
      </div>
      <div class="table-grid" id="tableGrid"></div>
    </div>

    <div class="view order-view" id="orderView">
      <section class="receipt-pane">
        <div class="receipt-head">
          <div class="receipt-title"><span id="receiptTableName">Masa</span><span id="receiptTotalTop">0,00 TL</span></div>
          <div class="receipt-meta"><span id="receiptNo">Adisyon: 0</span><span>Durum: <b style="color:#4f8b55;">Hazırlanıyor</b></span></div>
        </div>
        <div class="receipt-items" id="receiptItems"></div>
        <div class="receipt-footer">
          <div class="receipt-grand"><span>Toplam Tutar</span><strong id="receiptTotal">0,00 TL</strong></div>
          <div class="receipt-actions" id="receiptActions">
            <button type="button" class="btn tag-btn"><i class="fa fa-tag"></i></button>
            <button type="button" class="btn save-btn" id="saveTableBtn">Kaydet</button>
          </div>
        </div>
      </section>

      <section class="product-pane">
        <div class="product-tools">
          <div class="product-search-box"><i class="fa fa-search"></i><input type="text" id="productSearch" placeholder="Ürün adı, stok kodu veya barkod ile ara"><div class="search-hint">Arama tüm menüde yapılır; boşken seçili kategori listelenir.</div></div>
          <button type="button" class="btn btn-default" id="clearProductSearch"><i class="fa fa-times"></i> Temizle</button>
        </div>
        <div class="category-strip" id="categoryStrip"></div>
        <div class="product-grid" id="productGrid"></div>
      </section>
    </div>
  </div>
</div>

<div class="cashier-modal-backdrop" id="payBackdrop"></div>
<div class="cashier-pay-modal cancel-modal" id="cancelModal">
  <div class="cancel-body">
    <h4>Ürün İptali</h4>
    <div class="cancel-product" id="cancelProductName">Ürünü iptal etmek üzeresiniz</div>
    <div class="cancel-summary" id="cancelProductSummary"></div>
    <div class="cancel-error" id="cancelError">İptal sebebi seçiniz.</div>
    <strong style="color:#c83e38;">*İptal Sebebi Seçiniz</strong>
    <div class="cancel-reasons">
      <label class="cancel-option"><input type="radio" name="cancel_reason" value="waste" data-label="Ürün zayi oldu"> <span>Ürün zayi oldu</span></label>
      <label class="cancel-option"><input type="radio" name="cancel_reason" value="wrong_item" data-label="Yanlış ürün girildi"> <span>Yanlış ürün girildi</span></label>
      <label class="cancel-option"><input type="radio" name="cancel_reason" value="customer_cancel" data-label="Müşteri vazgeçti"> <span>Müşteri vazgeçti</span></label>
      <label class="cancel-option"><input type="radio" name="cancel_reason" value="service_error" data-label="Servis / hazırlık hatası"> <span>Servis / hazırlık hatası</span></label>
      <label class="cancel-option"><input type="radio" name="cancel_reason" value="other" data-label="Diğer"> <span>Diğer</span></label>
    </div>
    <textarea class="cancel-note" id="cancelNote" placeholder="Not / açıklama (opsiyonel)"></textarea>
  </div>
  <div class="cancel-actions">
    <button type="button" class="btn btn-link" id="closeCancelModal">İptal</button>
    <button type="button" class="btn btn-danger" id="confirmCancelProduct">Kaydet</button>
  </div>
</div>
<div class="cashier-pay-modal" id="payModal">
  <div class="pay-head">
    <div><h3 id="payTitle">Ödeme Ekranı</h3><strong id="payTableName"></strong></div>
    <button type="button" class="pay-close" id="closePayModal"><i class="fa fa-times"></i></button>
  </div>
  <div class="pay-body">
    <div class="pay-box">
      <h4><i class="fa fa-list-ul"></i> Adisyon Kalemleri</h4>
      <div id="payItemList"></div>
      <div class="pay-summary">
        <div class="pay-summary-row"><span>Toplam</span><strong id="paySubtotal">0,00 TL</strong></div>
        <div class="pay-summary-row"><span>Alınan</span><strong id="payPaid">0,00 TL</strong></div>
        <div class="pay-summary-row remaining"><span>Kalan</span><strong id="payRemaining">0,00 TL</strong></div>
      </div>
    </div>
    <div class="pay-box">
      <h4><i class="fa fa-calculator"></i> Alınan Ödeme</h4>
      <div class="pay-entry">
        <label for="payAmountInput">Kasaya girilen tutar</label>
        <input type="text" id="payAmountInput" inputmode="decimal" value="">
      </div>
      <div class="amount-shortcuts">
        <button type="button" data-pay-shortcut="all">Kalanı Gir</button>
        <button type="button" data-pay-shortcut="half">Yarısı</button>
        <button type="button" data-pay-shortcut="clear">Temizle</button>
      </div>
      <div class="keypad">
        <button>7</button><button>8</button><button>9</button><button class="action">Tüm</button>
        <button>4</button><button>5</button><button>6</button><button class="action">1/n</button>
        <button>1</button><button>2</button><button>3</button><button class="action">İndirim</button>
        <button>,</button><button>0</button><button><i class="fa fa-arrow-left"></i></button><button class="action">Sil</button>
      </div>
    </div>
    <div class="pay-box">
      <h4><i class="fa fa-credit-card"></i> Ödeme Tipleri</h4>
      <div class="pay-method-grid">
        <button type="button" class="pay-method" data-method="cash"><i class="fa fa-money"></i>Nakit</button>
        <button type="button" class="pay-method" data-method="card"><i class="fa fa-credit-card"></i>Kredi Kartı</button>
      </div>
      <div class="pay-history" id="payHistory"></div>
    </div>
  </div>
</div>

<div class="cashier-pay-modal quick-pay-modal" id="quickPayModal">
  <div class="pay-head">
    <div><h3 id="quickPayTitle">Hızlı Öde</h3><strong id="quickPayTotal">0,00 TL</strong></div>
    <button type="button" class="pay-close" id="closeQuickPayModal"><i class="fa fa-times"></i></button>
  </div>
  <div class="quick-sub">Tek dokunuşla ödeme tipini seçin, masa kapansın.</div>
  <div class="pay-method-grid">
    <button type="button" class="pay-method quick-method" data-method="cash"><i class="fa fa-money"></i>Nakit</button>
    <button type="button" class="pay-method quick-method" data-method="card"><i class="fa fa-credit-card"></i>Kredi Kartı</button>
  </div>
</div>

<div class="cashier-toast" id="cashierToast"></div>

<script>
(function($){
  var refreshUrl = '{{ refresh_url|replace({"&amp;":"&"}) }}';
  var payUrl = '{{ pay_url|replace({"&amp;":"&"}) }}';
  var detailUrl = '{{ detail_url|replace({"&amp;":"&"}) }}';
  var productsUrl = '{{ products_url|replace({"&amp;":"&"}) }}';
  var addProductUrl = '{{ add_product_url|replace({"&amp;":"&"}) }}';
  var saveOrderUrl = '{{ save_order_url|replace({"&amp;":"&"}) }}';
  var removeProductUrl = '{{ remove_product_url|replace({"&amp;":"&"}) }}';
  var printReceiptUrl = '{{ print_receipt_url|replace({"&amp;":"&"}) }}';
  var imageBase = '{{ image_base|replace({"&amp;":"&"}) }}';
  var tables = {{ tables_json|raw }};
  var categories = {{ categories_json|raw }};
  var products = {{ products_json|raw }};
  var summary = {{ summary_json|raw }};
  var selectedTableId = 0;
  var selectedArea = '';
  var selectedCategory = categories.length ? parseInt(categories[0].category_id, 10) : 0;
  var currentDetail = null;
  var pendingCancelRowId = 0;
  var pendingCancelItem = null;
  var selectedPayItems = [];
  var searchTimer = null;
  var payAmount = '';
  var previousBillRequests = [];

  function money(value) {
    value = parseFloat(value || 0);
    return value.toLocaleString('tr-TR', {minimumFractionDigits: 2, maximumFractionDigits: 2}) + ' TL';
  }

  function parseAmount(value) {
    value = String(value || '').replace(/\./g, '').replace(',', '.').replace(/[^0-9.]/g, '');
    return parseFloat(value || 0) || 0;
  }

  function escapeHtml(value) {
    return String(value === null || value === undefined ? '' : value)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;').replace(/'/g, '&#039;');
  }

  function normalizeArea(area) {
    area = $.trim(String(area || ''));

    if (!area) {
      return 'Salon';
    }

    var key = area.toLocaleLowerCase('tr-TR');

    if (key.indexOf('bah') === 0 && (key.indexOf('?') !== -1 || key.indexOf('ç') !== -1 || key.indexOf('c') !== -1)) {
      return 'Bahçe';
    }

    if (key === 'salon') {
      return 'Salon';
    }

    return area;
  }

  function toast(message, type) {
    var $toast = $('#cashierToast');
    $toast.removeClass('error success').addClass(type || '').text(message).stop(true, true).fadeIn(120);
    clearTimeout($toast.data('timer'));
    $toast.data('timer', setTimeout(function(){ $toast.fadeOut(160); }, 2600));
  }

  function isOccupied(table) {
    return parseFloat(table.total_amount || 0) > 0;
  }

  function getBillRequestKeys(sourceTables) {
    var keys = [];
    (sourceTables || []).forEach(function(table) {
      if (parseInt(table.bill_request_pending || 0, 10)) {
        keys.push(String(table.bill_request_id || table.table_id));
      }
    });
    return keys;
  }

  function notifyNewBillRequests(sourceTables) {
    var keys = getBillRequestKeys(sourceTables);
    (sourceTables || []).forEach(function(table) {
      var key = String(table.bill_request_id || table.table_id);
      if (parseInt(table.bill_request_pending || 0, 10) && previousBillRequests.indexOf(key) === -1) {
        toast('Masa ' + table.table_no + ' hesap istiyor. Fiş hazırla.', 'error');
      }
    });
    previousBillRequests = keys;
  }

  function renderSummary() {
    if (!$('#cashierSummary').length) return;
    var html = '';
    html += '<div class="summary-card"><span>Açık Masa</span><strong>' + (summary.open_count || 0) + '</strong></div>';
    html += '<div class="summary-card"><span>Açık Tutar</span><strong>' + money(summary.open_total || 0) + '</strong></div>';
    html += '<div class="summary-card"><span>Bugün Nakit</span><strong>' + money(summary.cash_total || 0) + '</strong></div>';
    html += '<div class="summary-card"><span>Bugün Kart</span><strong>' + money(summary.card_total || 0) + '</strong></div>';
    html += '<div class="summary-card warning"><span>Tahsilat Adedi</span><strong>' + (summary.payment_count || 0) + '</strong></div>';
    $('#cashierSummary').html(html);
  }

  function showTables() {
    $('#tablesView').addClass('active');
    $('#orderView').removeClass('active');
    $('#backToTables').hide();
    $('#topTitle').text('Kasa Paneli');
    $('#productSearch').val('');
    selectedTableId = 0;
    currentDetail = null;
    refreshTables(false);
  }

  function showOrder() {
    $('#tablesView').removeClass('active');
    $('#orderView').addClass('active');
    $('#backToTables').show();
  }

  function renderAreas() {
    var areas = {};
    tables.forEach(function(table){ areas[normalizeArea(table.area)] = true; });
    var openCount = tables.filter(isOccupied).length;
    var html = '<button type="button" class="area-tab ' + (selectedArea === '__open' ? 'active' : '') + '" data-area="__open">Açık Masalar <span>(' + openCount + ')</span></button>';
    html += '<button type="button" class="area-tab ' + (selectedArea === '' ? 'active' : '') + '" data-area="">Tümü <span>(' + tables.length + ')</span></button>';
    Object.keys(areas).forEach(function(area) {
      var areaCount = tables.filter(function(table){ return normalizeArea(table.area) === area; }).length;
      html += '<button type="button" class="area-tab ' + (selectedArea === area ? 'active' : '') + '" data-area="' + escapeHtml(area) + '">' + escapeHtml(area) + ' <span>(' + areaCount + ')</span></button>';
    });
    $('#areaTabs').html(html);
  }

  function renderTables() {
    renderAreas();
    renderSummary();
    var filtered = tables.filter(function(table){
      if (selectedArea === '__open') return isOccupied(table);
      return !selectedArea || normalizeArea(table.area) === selectedArea;
    });
    var html = '';
    filtered.forEach(function(table) {
      var occupied = isOccupied(table);
      var pending = table.service_status === 'payment_pending';
      var inKitchen = table.service_status === 'in_kitchen';
      var ready = table.service_status === 'ready_for_service' || table.service_status === 'out_for_service';
      var served = table.service_status === 'served';
      var billPending = parseInt(table.bill_request_pending || 0, 10);
      var billNew = parseInt(table.bill_request_new || 0, 10);
      var stateLabel = billPending ? 'Hesap istiyor' : (pending ? 'Ödeme' : (inKitchen ? 'Mutfakta' : (ready ? 'Servise hazır' : (served ? 'Servis edildi' : (occupied ? 'Dolu' : 'Boş')))));
      var classes = (occupied ? 'occupied ' : '') + (pending ? 'pending ' : '') + (inKitchen ? 'in-kitchen ' : '') + (ready ? 'ready ' : '') + (served ? 'served ' : '') + (billPending ? 'bill ' : '') + (billNew ? 'new-bill' : '');
      var areaLabel = normalizeArea(table.area);
      html += '<button type="button" class="pos-table ' + classes + '" data-table-id="' + table.table_id + '">';
      html += '<div class="mini-meta">' + (billPending ? '<span title="Hesap talebi"><i class="fa fa-bell"></i></span>' : '') + '</div>';
      html += '<div><div class="table-no">Masa ' + escapeHtml(table.table_no) + '</div><div class="table-area">' + escapeHtml(areaLabel) + '</div>' + (table.waiter_name ? '<div class="waiter-line">' + escapeHtml(table.waiter_name) + '</div>' : '') + '<div class="bill-label"><i class="fa fa-bell"></i> Müşteri hesap istiyor</div>' + (table.bill_payment_note ? '<div class="bill-method">' + escapeHtml(table.bill_payment_note) + '</div>' : '') + '</div>';
      html += '<div class="table-bottom"><span class="state">' + stateLabel + '</span><span class="amount">' + (occupied ? money(table.total_amount) : '') + '</span></div>';
      html += '</button>';
    });
    $('#tableGrid').html(html || '<div class="empty-state">Bu filtrede masa bulunamadı.</div>');
    $('#tableGrid .table-area').each(function(){
      $(this).text(normalizeArea($(this).text()));
    });
  }

  function renderCategories() {
    var html = '';
    categories.forEach(function(category) {
      var id = parseInt(category.category_id, 10);
      html += '<button type="button" class="category-btn ' + (id === selectedCategory ? 'active' : '') + '" data-id="' + id + '">' + escapeHtml(category.name) + '</button>';
    });
    $('#categoryStrip').html(html || '<span class="empty-state">Kategori yok.</span>');
  }

  function productImage(product) {
    var image = product.image || '';
    if (!image || image === 'no_image.png') {
      return '<div class="product-img">' + escapeHtml((product.name || '?').substring(0, 1)) + '</div>';
    }
    return '<div class="product-img"><img src="' + imageBase + escapeHtml(image) + '" alt=""></div>';
  }

  function renderProducts() {
    var html = '';
    products.forEach(function(product) {
      html += '<button type="button" class="product-card" data-product-id="' + product.product_id + '">';
      html += productImage(product);
      html += '<strong>' + escapeHtml(product.name) + '</strong>';
      html += '<div class="product-price"><span>' + money(product.price) + '</span><span class="product-add"><i class="fa fa-plus"></i></span></div>';
      html += '</button>';
    });
    $('#productGrid').html(html || '<div class="empty-state">Ürün bulunamadı.</div>');
  }

  function renderDetail(detail) {
    currentDetail = detail || null;
    selectedPayItems = [];
    if (!detail || !detail.table) return;

    $('#topTitle').text('Masa ' + detail.table.table_no);
    $('#receiptTableName').text('Masa ' + detail.table.table_no);
    var firstOrder = detail.orders && detail.orders.length ? detail.orders[0] : null;
    $('#receiptNo').text('Adisyon: ' + (firstOrder ? firstOrder.restaurant_order_id : '0'));
    var statusText = 'Hazırlanıyor';
    if (detail.service_status === 'payment_pending') statusText = 'Ödeme bekliyor';
    else if (detail.service_status === 'cashier_draft') statusText = 'Kasada taslak';
    else if (detail.service_status === 'served') statusText = 'Servis edildi';
    else if (detail.service_status === 'ready_for_service' || detail.service_status === 'out_for_service') statusText = 'Servise hazır';
    else if (detail.service_status === 'in_kitchen') statusText = 'Mutfakta';
    $('.receipt-meta b').text(statusText + (detail.bill_payment_note ? ' - ' + detail.bill_payment_note : ''));
    $('#receiptTotal,#receiptTotalTop').text(money(detail.total_amount));

    if (!detail.items || !detail.items.length) {
      $('#receiptItems').html('<div class="receipt-empty">Bu masada ürün yok. Sağdan ürün seçerek adisyon açabilirsiniz.</div>');
    } else {
      var html = '';
      detail.items.forEach(function(item) {
        html += '<div class="receipt-row ' + (item.is_paid ? 'is-paid' : '') + '" data-row-id="' + item.restaurant_order_product_id + '" data-qty="' + item.quantity + '">';
        html += '<div class="qty-badge">' + (item.remaining_quantity || item.quantity) + '</div>';
        html += '<div><div class="receipt-name">' + escapeHtml(item.name) + '</div><div class="receipt-sub">' + money(item.price) + ' / adet' + (item.paid_amount > 0 ? ' - ödenen ' + money(item.paid_amount) : '') + '</div>' + (item.is_paid ? '<div class="paid-chip">Ödendi</div>' : '') + '<div class="row-actions">' + (!item.is_paid ? '<button type="button" class="pay-select" data-row-id="' + item.restaurant_order_product_id + '" title="Parçalı ödeme için seç"><i class="fa fa-check"></i></button><button type="button" class="qty-remove" data-row-id="' + item.restaurant_order_product_id + '"><i class="fa fa-trash"></i></button>' : '') + '</div></div>';
        html += '<div class="receipt-total">' + money(item.remaining_total || item.total) + '</div>';
        html += '</div>';
      });
      $('#receiptItems').html(html);
    }

    var hasItems = detail.items && detail.items.length;
    var hasDraft = detail.service_status === 'cashier_draft' || (detail.orders || []).some(function(order){ return order.service_status === 'cashier_draft'; });
    var paymentReady = (!!detail.payment_ready || !!detail.bill_payment_note) && !hasDraft;
    var payLabel = detail.bill_payment_note ? 'Hesabı Kapat' : 'Öde';
    $('#receiptActions')
      .toggleClass('has-pay', !!hasItems)
      .html(hasItems
        ? '<button type="button" class="btn btn-default" id="printReceiptBtn"><i class="fa fa-print"></i> Fiş</button><button type="button" class="btn btn-success" id="payBtn" ' + (paymentReady ? '' : 'disabled title="Taslak sipariş kaydedilmeden veya servis edilmeden ödeme alınamaz"') + '><i class="fa fa-credit-card"></i> ' + payLabel + '</button><button type="button" class="btn btn-warning" id="quickPayBtn" ' + (paymentReady ? '' : 'disabled title="Taslak sipariş kaydedilmeden veya servis edilmeden hızlı ödeme alınamaz"') + '><i class="fa fa-bolt"></i> Hızlı Öde</button><button type="button" class="btn save-btn" id="saveTableBtn">' + (hasDraft ? '<i class="fa fa-paper-plane"></i> Mutfağa Gönder' : 'Kaydet') + '</button>'
        : '<button type="button" class="btn tag-btn"><i class="fa fa-tag"></i></button><button type="button" class="btn save-btn" id="saveTableBtn">Kaydet</button>');
  }

  function loadDetail(tableId) {
    selectedTableId = parseInt(tableId || 0, 10);
    $.getJSON(detailUrl + '&table_id=' + selectedTableId, function(json) {
      if (json && json.success) {
        showOrder();
        renderDetail(json.detail);
        renderCategories();
        loadProducts();
      } else {
        toast(json && json.message ? json.message : 'Masa detayı alınamadı.', 'error');
      }
    }).fail(function(){ toast('Masa detayı alınamadı. Bağlantıyı kontrol edin.', 'error'); });
  }

  function setBusy($el, busy) {
    if (!$el || !$el.length) return;
    $el.prop('disabled', !!busy).toggleClass('is-busy', !!busy);
    if (busy && !$el.data('old-html')) {
      $el.data('old-html', $el.html()).html('<i class="fa fa-spinner fa-spin"></i>');
    } else if (!busy && $el.data('old-html')) {
      $el.html($el.data('old-html')).removeData('old-html');
    }
  }

  function refreshTables(keepDetail) {
    $.getJSON(refreshUrl, function(json) {
      if (!json || !json.success) return;
      tables = json.tables || [];
      summary = json.summary || summary || {};
      notifyNewBillRequests(tables);
      renderTables();
      if (keepDetail && selectedTableId) loadDetail(selectedTableId);
    });
  }

  function loadProducts() {
    var search = $.trim($('#productSearch').val());
    var categoryId = search ? 0 : selectedCategory;
    $.getJSON(productsUrl + '&category_id=' + categoryId + '&search=' + encodeURIComponent(search), function(json) {
      if (!json || !json.success) {
        toast(json && json.message ? json.message : 'Ürünler alınamadı.', 'error');
        return;
      }
      products = json.products || [];
      renderProducts();
    }).fail(function(){ toast('Ürünler alınamadı. Bağlantıyı kontrol edin.', 'error'); });
  }

  function getDetailItem(rowId) {
    rowId = parseInt(rowId || 0, 10);
    var found = null;
    (currentDetail && currentDetail.items ? currentDetail.items : []).forEach(function(item) {
      if (parseInt(item.restaurant_order_product_id, 10) === rowId) {
        found = item;
      }
    });
    return found;
  }

  function openCancelModal(rowId) {
    pendingCancelRowId = parseInt(rowId || 0, 10);
    pendingCancelItem = getDetailItem(pendingCancelRowId);
    $('input[name="cancel_reason"]').prop('checked', false);
    $('#cancelNote').val('');
    $('#cancelError').hide();
    $('#confirmCancelProduct').prop('disabled', false).html('Kaydet');
    $('#cancelProductName').text(pendingCancelItem ? pendingCancelItem.name + ' ürününü iptal etmek üzeresiniz' : 'Ürünü iptal etmek üzeresiniz');
    $('#cancelProductSummary').html(pendingCancelItem
      ? '<span>' + escapeHtml(pendingCancelItem.quantity + ' x ' + pendingCancelItem.name) + '<small>' + money(pendingCancelItem.price) + ' / adet</small></span><strong>' + money(pendingCancelItem.total) + '</strong>'
      : '');
    $('#payBackdrop,#cancelModal').show();
  }

  function closeCancelModal() {
    pendingCancelRowId = 0;
    pendingCancelItem = null;
    $('#cancelModal').hide();
    if (!$('#payModal').is(':visible') && !$('#quickPayModal').is(':visible')) {
      $('#payBackdrop').hide();
    }
  }

  function removeRow(rowId, reasonCode, reasonText, note) {
    $('#confirmCancelProduct').prop('disabled', true).html('<i class="fa fa-spinner fa-spin"></i> Kaydediliyor');
    $.post(removeProductUrl, {
      restaurant_order_product_id: rowId,
      reason_code: reasonCode,
      reason_text: reasonText,
      note: note || ''
    }, function(json) {
      if (!json || !json.success) {
        $('#confirmCancelProduct').prop('disabled', false).html('Kaydet');
        alert(json && json.message ? json.message : 'Ürün silinemedi.');
        return;
      }
      closeCancelModal();
      renderDetail(json.detail);
      refreshTables(false);
    }, 'json').fail(function() {
      $('#confirmCancelProduct').prop('disabled', false).html('Kaydet');
      alert('Ürün iptali kaydedilemedi. Sunucu cevabı alınamadı.');
    });
  }

  function fillPayModal() {
    var subtotal = currentDetail ? currentDetail.subtotal_amount || currentDetail.total_amount : 0;
    var paid = currentDetail ? currentDetail.paid_amount || 0 : 0;
    var total = currentDetail ? currentDetail.total_amount : 0;
    var tableNo = currentDetail && currentDetail.table ? currentDetail.table.table_no : '';
    $('#payTitle').text('Masa ' + tableNo + ' Ödeme');
    $('#payTableName').text('Ödenecek Tutar: ' + money(total));
    $('#paySubtotal').text(money(subtotal));
    $('#payPaid').text(money(paid));
    $('#payRemaining').text(money(total));
    $('#payHistory').html(paid > 0 ? '<div class="pay-history-title">Alınan Tahsilat</div><div class="pay-row"><span>Ödenen</span><strong>' + money(paid) + '</strong></div>' : '<div class="pay-history-title">Parçalı ödeme için tutarı girip ödeme tipini seçin.</div>');
    payAmount = '';
    $('#payAmountInput').val('');
    $('#quickPayTitle').text('Hızlı Öde');
    $('#quickPayTotal').text('Masa ' + tableNo + ' - ' + money(total));
    var html = '';
    (currentDetail && currentDetail.items ? currentDetail.items : []).forEach(function(item) {
      var rowId = parseInt(item.restaurant_order_product_id || 0, 10);
      var selected = selectedPayItems.indexOf(rowId) !== -1;
      html += '<div class="pay-row selectable ' + (selected ? 'is-selected ' : '') + (item.is_paid ? 'is-paid' : '') + '" data-pay-row-id="' + rowId + '" data-pay-amount="' + (item.remaining_total || item.total || 0) + '"><span>' + (item.remaining_quantity || item.quantity) + ' x ' + escapeHtml(item.name) + (item.paid_amount > 0 ? '<br><small>Ödenen: ' + money(item.paid_amount) + '</small>' : '') + '</span><strong>' + money(item.remaining_total || item.total) + '</strong></div>';
    });
    $('#payItemList').html(html);
    updateSelectedPayAmount();
  }

  function updateSelectedPayAmount() {
    var selectedTotal = 0;
    $('#payItemList .pay-row.is-selected').each(function() {
      selectedTotal += parseFloat($(this).data('pay-amount') || 0);
    });

    if (selectedTotal > 0) {
      setPayAmount(selectedTotal.toLocaleString('tr-TR', {minimumFractionDigits: 2, maximumFractionDigits: 2}));
    }
  }

  function canPay() {
    var hasDraft = currentDetail && (currentDetail.service_status === 'cashier_draft' || (currentDetail.orders || []).some(function(order){ return order.service_status === 'cashier_draft'; }));
    return selectedTableId && currentDetail && !hasDraft && (currentDetail.payment_ready || currentDetail.bill_payment_note) && currentDetail.items && currentDetail.items.length;
  }

  function getRequestedPaymentMethod() {
    var note = String(currentDetail && currentDetail.bill_payment_note ? currentDetail.bill_payment_note : '').toLowerCase();

    if (note.indexOf('nakit') !== -1 || note.indexOf('cash') !== -1) {
      return 'cash';
    }

    if (note.indexOf('kart') !== -1 || note.indexOf('card') !== -1 || note.indexOf('pos') !== -1 || note.indexOf('kredi') !== -1) {
      return 'card';
    }

    return '';
  }

  function openPayModal() {
    if (!canPay()) {
      alert('Ödeme için siparişin servis edilmiş olması gerekir.');
      return;
    }

    if (currentDetail && currentDetail.bill_payment_note) {
      var requestedMethod = getRequestedPaymentMethod();

      if (!requestedMethod) {
        requestedMethod = 'card';
      }

      if (requestedMethod) {
        pay(requestedMethod, {autoClose:true});
        return;
      }
    }

    fillPayModal();
    $('#payBackdrop,#payModal').show();
  }

  function openQuickPayModal() {
    if (!canPay()) {
      alert('Hızlı ödeme için siparişin servis edilmiş olması gerekir.');
      return;
    }
    fillPayModal();
    $('#payBackdrop,#quickPayModal').show();
  }

  function closePayModal() {
    $('#payBackdrop,#payModal,#quickPayModal,#cancelModal').hide();
  }

  function setPayAmount(value) {
    payAmount = String(value || '');
    $('#payAmountInput').val(payAmount);
  }

  function appendPayKey(key) {
    if (key === 'clear') {
      setPayAmount('');
    } else if (key === 'back') {
      setPayAmount(payAmount.slice(0, -1));
    } else if (key === 'all') {
      setPayAmount((currentDetail ? currentDetail.total_amount : 0).toLocaleString('tr-TR', {minimumFractionDigits: 2, maximumFractionDigits: 2}));
    } else if (key === 'half') {
      setPayAmount(((currentDetail ? currentDetail.total_amount : 0) / 2).toLocaleString('tr-TR', {minimumFractionDigits: 2, maximumFractionDigits: 2}));
    } else {
      setPayAmount(payAmount + key);
    }
  }

  function pay(method, options) {
    options = options || {};
    if (!selectedTableId || !method) return;
    var amount = options.autoClose && currentDetail ? parseFloat(currentDetail.total_amount || 0) : parseAmount($('#payAmountInput').val());
    var selectedItems = options.autoClose ? [] : selectedPayItems;
    var $method = options.autoClose ? $('#payBtn') : $('.pay-method[data-method="' + method + '"]');
    setBusy($method, true);
    $.post(payUrl, {table_id:selectedTableId, payment_method:method, amount:amount, selected_items:selectedItems, note:''}, function(json) {
      setBusy($method, false);
      if (!json || !json.success) {
        toast(json && json.message ? json.message : 'Ödeme alınamadı.', 'error');
        return;
      }
      toast(json.message || 'Tahsilat alındı.', 'success');
      if (json.closed) {
        closePayModal();
        showTables();
        return;
      }
      if (json.detail) {
        renderDetail(json.detail);
        fillPayModal();
      }
      refreshTables(false);
    }, 'json').fail(function(){
      setBusy($method, false);
      toast('Ödeme alınamadı. Sunucu cevabı alınamadı.', 'error');
    });
  }

  function printReceipt() {
    if (!selectedTableId) return;
    var receiptWindow = window.open(printReceiptUrl + '&table_id=' + selectedTableId, '_blank', 'width=420,height=720');
    if (receiptWindow) {
      setTimeout(function() {
        try {
          receiptWindow.focus();
          receiptWindow.print();
        } catch (e) {}
      }, 900);
    }
  }

  function saveTableOrder() {
    if (!selectedTableId) {
      showTables();
      return;
    }

    var $btn = $('#saveTableBtn');
    setBusy($btn, true);

    $.post(saveOrderUrl, {table_id:selectedTableId}, function(json) {
      setBusy($btn, false);
      if (!json || !json.success) {
        toast(json && json.message ? json.message : 'Sipariş kaydedilemedi.', 'error');
        return;
      }

      toast(json.message || 'Sipariş mutfağa gönderildi.', 'success');

      if (json.detail) {
        renderDetail(json.detail);
      }

      refreshTables(false);
      showTables();
    }, 'json').fail(function() {
      setBusy($btn, false);
      toast('Sipariş kaydedilemedi. Sunucu cevabı alınamadı.', 'error');
    });
  }

  $(document).on('click', '.pos-table', function(){ loadDetail($(this).data('table-id')); });
  $(document).on('click', '.area-tab', function(){ selectedArea = $(this).data('area') || ''; renderTables(); });
  $(document).on('click', '.category-btn', function(){ selectedCategory = parseInt($(this).data('id') || 0, 10); renderCategories(); loadProducts(); });
  $(document).on('click', '.product-card', function(){
    if (!selectedTableId) return;
    var $card = $(this);
    setBusy($card, true);
    $.post(addProductUrl, {table_id:selectedTableId, product_id:$card.data('product-id'), quantity:1}, function(json) {
      setBusy($card, false);
      if (!json || !json.success) {
        toast(json && json.message ? json.message : 'Ürün eklenemedi.', 'error');
        return;
      }
      toast('Ürün adisyona eklendi.', 'success');
      renderDetail(json.detail);
      refreshTables(false);
    }, 'json').fail(function(){
      setBusy($card, false);
      toast('Ürün eklenemedi. Sunucu cevabı alınamadı.', 'error');
    });
  });
  $(document).on('click', '.qty-remove', function(e){ e.preventDefault(); e.stopPropagation(); openCancelModal($(this).data('row-id') || $(this).closest('.receipt-row').data('row-id')); });
  $(document).on('click', '.pay-select', function(e){
    e.preventDefault();
    e.stopPropagation();
    var rowId = parseInt($(this).data('row-id') || 0, 10);
    var index = selectedPayItems.indexOf(rowId);
    if (index === -1) {
      selectedPayItems.push(rowId);
    } else {
      selectedPayItems.splice(index, 1);
    }
    $(this).toggleClass('is-selected', index === -1);
    $(this).closest('.receipt-row').toggleClass('pay-selected', index === -1);
    fillPayModal();
  });
  $(document).on('click', '#payItemList .pay-row.selectable:not(.is-paid)', function(){
    var rowId = parseInt($(this).data('pay-row-id') || 0, 10);
    var index = selectedPayItems.indexOf(rowId);
    if (index === -1) {
      selectedPayItems.push(rowId);
    } else {
      selectedPayItems.splice(index, 1);
    }
    fillPayModal();
  });
  $(document).on('click', '#cancelModal', function(e){ e.stopPropagation(); });
  $(document).on('click', '#closeCancelModal', function(e){ e.preventDefault(); closeCancelModal(); });
  $(document).on('change', 'input[name="cancel_reason"]', function(){ $('#cancelError').hide(); });
  $(document).on('click', '#confirmCancelProduct', function(e){
    e.preventDefault();
    e.stopPropagation();
    var reason = $('input[name="cancel_reason"]:checked');
    if (!pendingCancelRowId || !reason.length) {
      $('#cancelError').text('İptal sebebi seçiniz.').show();
      return;
    }
    if (reason.val() === 'other' && $.trim($('#cancelNote').val()).length < 3) {
      $('#cancelError').text('Diğer sebebi için kısa bir açıklama yazınız.').show();
      return;
    }
    removeRow(pendingCancelRowId, reason.val(), reason.data('label') || reason.closest('label').text(), $('#cancelNote').val());
  });
  $('#productSearch').on('input', function(){ clearTimeout(searchTimer); searchTimer = setTimeout(loadProducts, 220); });
  $('#clearProductSearch').on('click', function(){ $('#productSearch').val(''); loadProducts(); });
  $('#payAmountInput').on('input', function(){ payAmount = $(this).val(); });
  $(document).on('click', '[data-pay-shortcut]', function(){ appendPayKey($(this).data('pay-shortcut')); });
  $(document).on('click', '.keypad button', function(){
    var text = $.trim($(this).text());
    if (text === 'Tüm') return appendPayKey('all');
    if (text === '1/n') return appendPayKey('half');
    if (text === 'Sil') return appendPayKey('clear');
    if (!text) return appendPayKey('back');
    appendPayKey(text === ',' ? ',' : text);
  });
  $('#refreshTables').on('click', function(){ refreshTables(false); });
  $('#backToTables').on('click', showTables);
  $(document).on('click', '#saveTableBtn', saveTableOrder);
  $(document).on('click', '#payBtn', openPayModal);
  $(document).on('click', '#quickPayBtn', openQuickPayModal);
  $(document).on('click', '#printReceiptBtn', printReceipt);
  $('#closePayModal,#closeQuickPayModal,#payBackdrop').on('click', closePayModal);
  $(document).on('click', '.pay-method', function(){ pay($(this).data('method')); });

  renderTables();
  renderCategories();
  renderProducts();
  previousBillRequests = getBillRequestKeys(tables);
  setInterval(function(){ if ($('#tablesView').hasClass('active')) refreshTables(false); }, 10000);
})(jQuery);
</script>
{% if cashier_fullscreen %}
</body></html>
{% else %}
{{ footer }}
{% endif %}
