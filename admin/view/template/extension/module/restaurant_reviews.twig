{{ header }}{{ column_left }}
<div id="content" class="restaurant-review-admin">
  <div class="page-header review-page-header">
    <div class="container-fluid">
      <div class="review-title-wrap">
        <div>
          <h1>Değerlendirmeler</h1>
          <p>Müşteri puanlarını, masa deneyimini, ilgili garsonu ve sipariş numarasını tek ekranda takip edin.</p>
        </div>
        <div class="review-title-badge">
          <i class="fa fa-star"></i>
          <span>Misafir Deneyimi</span>
        </div>
      </div>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
          <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="container-fluid">
    <div class="review-stat-grid">
      <div class="review-stat-card hero">
        <span>Genel Ortalama</span>
        <strong>{{ average_all.average|number_format(1, ',', '.') }}</strong>
        <em>{{ average_all.total }} değerlendirme</em>
      </div>
      <div class="review-stat-card">
        <span>Son 1 Ay</span>
        <strong>{{ average_month.average|number_format(1, ',', '.') }}</strong>
        <em>{{ average_month.total }} değerlendirme</em>
      </div>
      <div class="review-stat-card">
        <span>Son 7 Gün</span>
        <strong>{{ average_week.average|number_format(1, ',', '.') }}</strong>
        <em>{{ average_week.total }} değerlendirme</em>
      </div>
      <div class="review-stat-card">
        <span>Bugün</span>
        <strong>{{ average_today.average|number_format(1, ',', '.') }}</strong>
        <em>{{ average_today.total }} değerlendirme</em>
      </div>
    </div>

    <form action="{{ action }}" method="get" class="review-filter-panel">
      <input type="hidden" name="route" value="extension/module/restaurant_reviews">
      <input type="hidden" name="user_token" value="{{ user_token }}">
      <div>
        <label>Başlangıç</label>
        <input type="date" name="date_from" value="{{ filter.date_from }}" class="form-control">
      </div>
      <div>
        <label>Bitiş</label>
        <input type="date" name="date_to" value="{{ filter.date_to }}" class="form-control">
      </div>
      <div>
        <label>Yıldız</label>
        <select name="rating" class="form-control">
          <option value="0">Tümü</option>
          {% for i in 1..5 %}
            <option value="{{ i }}" {% if filter.rating == i %}selected{% endif %}>{{ i }} yıldız</option>
          {% endfor %}
        </select>
      </div>
      <div class="review-filter-actions">
        <button type="submit" class="btn btn-primary"><i class="fa fa-filter"></i> Filtrele</button>
        <a href="{{ clear }}" class="btn btn-default">Temizle</a>
      </div>
    </form>

    <div class="review-list">
      {% for review in reviews %}
        <article class="review-card rating-{{ review.rating }}">
          <div class="review-score-block">
            <strong>{{ review.rating }}</strong>
            <span>/ 5</span>
            <div class="review-score-stars">
              {% for i in 1..5 %}<i class="fa fa-star{% if i > review.rating %}-o{% endif %}"></i>{% endfor %}
            </div>
          </div>

          <div class="review-card-main">
            <div class="review-card-title">
              <div>
                <strong>{{ review.display_table }}</strong>
                <span>{{ review.date_added|date('d.m.Y H:i') }}</span>
              </div>
              <div class="review-quality-label">
                {% if review.rating >= 5 %}
                  Mükemmel
                {% elseif review.rating >= 4 %}
                  Çok iyi
                {% elseif review.rating >= 3 %}
                  Orta
                {% else %}
                  Dikkat gerekli
                {% endif %}
              </div>
            </div>

            <div class="review-meta-row">
              <span><i class="fa fa-user"></i> Garson: <b>{{ review.display_waiter_name }}</b></span>
              <span><i class="fa fa-list-alt"></i> Sipariş No: <b>{{ review.display_order_no }}</b></span>
            </div>

            {% if review.note %}
              <p>{{ review.note }}</p>
            {% else %}
              <p class="muted">Müşteri not eklemedi.</p>
            {% endif %}
          </div>

          <aside class="review-card-side">
            <span>Masa</span>
            <strong>{{ review.display_table }}</strong>
            <span>Garson</span>
            <strong>{{ review.display_waiter_name }}</strong>
            <span>Sipariş No</span>
            <strong>{{ review.display_order_no }}</strong>
          </aside>
        </article>
      {% else %}
        <div class="review-empty">Bu filtrelerde değerlendirme bulunamadı.</div>
      {% endfor %}
    </div>
  </div>

  <style>
    .restaurant-review-admin{background:#f5f7f6;min-height:100vh;}
    .review-page-header{background:#fff;border-bottom:1px solid #e5ebe7;margin-bottom:18px;}
    .review-title-wrap{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;}
    .review-page-header h1{margin-bottom:4px;color:#1d3329;font-weight:900;}
    .review-page-header p{margin:0 0 8px;color:#6f7f77;}
    .review-title-badge{display:inline-flex;align-items:center;gap:8px;margin-top:6px;padding:10px 14px;border-radius:999px;background:#f7f0df;color:#7a5a19;font-weight:900;}
    .review-title-badge i{color:#d3a64e;}
    .review-stat-grid{display:grid;grid-template-columns:1.2fr repeat(3,1fr);gap:14px;margin-bottom:16px;}
    .review-stat-card{padding:18px;border:1px solid #dfe8e2;border-radius:14px;background:#fff;box-shadow:0 12px 28px rgba(28,55,42,.06);}
    .review-stat-card span{display:block;color:#6d7e75;font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.04em;}
    .review-stat-card strong{display:block;margin-top:6px;color:#1d3329;font-size:34px;font-weight:900;line-height:1;}
    .review-stat-card strong:after{content:' ★';font-size:20px;color:#d3a64e;}
    .review-stat-card em{display:block;margin-top:7px;color:#7b8982;font-style:normal;}
    .review-stat-card.hero{background:linear-gradient(135deg,#143629,#2f6b4e);border-color:#143629;}
    .review-stat-card.hero span,.review-stat-card.hero em{color:#d9eadf;}
    .review-stat-card.hero strong{color:#fff;}
    .review-filter-panel{display:grid;grid-template-columns:repeat(3,minmax(0,1fr)) auto;gap:12px;align-items:end;margin-bottom:16px;padding:16px;border:1px solid #dfe8e2;border-radius:14px;background:#fff;box-shadow:0 10px 24px rgba(28,55,42,.045);}
    .review-filter-panel label{display:block;margin-bottom:6px;color:#30463b;font-weight:900;}
    .review-filter-actions{display:flex;gap:8px;}
    .review-list{display:grid;gap:14px;}
    .review-card{display:grid;grid-template-columns:116px minmax(0,1fr) 240px;gap:18px;padding:18px;border:1px solid #dfe8e2;border-radius:16px;background:#fff;box-shadow:0 12px 28px rgba(28,55,42,.055);}
    .review-score-block{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:116px;border-radius:14px;background:#f7f0df;color:#7a5a19;}
    .review-score-block strong{font-size:42px;font-weight:900;line-height:1;}
    .review-score-block span{font-weight:900;color:#9a7b34;}
    .review-score-stars{margin-top:8px;color:#d3a64e;white-space:nowrap;}
    .review-card.rating-1 .review-score-block,.review-card.rating-2 .review-score-block{background:#fdecec;color:#a13b36;}
    .review-card.rating-1 .review-score-stars,.review-card.rating-2 .review-score-stars{color:#c84a43;}
    .review-card-title{display:flex;justify-content:space-between;gap:12px;margin-bottom:10px;}
    .review-card-title strong{display:block;color:#1d3329;font-size:20px;font-weight:900;}
    .review-card-title span{display:block;margin-top:2px;color:#7b8982;}
    .review-quality-label{align-self:flex-start;padding:7px 11px;border-radius:999px;background:#edf6f1;color:#2f6b4e;font-size:12px;font-weight:900;white-space:nowrap;}
    .review-meta-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px;}
    .review-meta-row span{display:inline-flex;align-items:center;gap:6px;padding:7px 10px;border-radius:999px;background:#f1f6f3;color:#53695d;font-weight:800;}
    .review-meta-row b{color:#1d3329;}
    .review-card p{margin:0;color:#43584d;line-height:1.6;font-size:14px;}
    .review-card p.muted{color:#9aa6a0;}
    .review-card-side{display:grid;grid-template-columns:1fr;align-content:start;gap:4px;padding-left:18px;border-left:1px solid #edf2ef;}
    .review-card-side span{color:#829089;font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.04em;}
    .review-card-side strong{margin-bottom:10px;color:#243b31;word-break:break-word;}
    .review-empty{padding:34px;text-align:center;border:1px dashed #cfdcd4;border-radius:14px;background:#fff;color:#819089;font-weight:900;}
    @media (max-width:1199px){.review-card{grid-template-columns:96px minmax(0,1fr);}.review-card-side{grid-column:1 / -1;padding-left:0;border-left:0;border-top:1px solid #edf2ef;padding-top:12px;grid-template-columns:repeat(3,1fr);}}
    @media (max-width:991px){.review-title-wrap,.review-stat-grid,.review-filter-panel,.review-card{grid-template-columns:1fr;display:grid;}.review-score-block{align-items:flex-start;padding:16px;}.review-card-side{grid-template-columns:1fr;}}
  </style>
</div>
{{ footer }}
