{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="submit" form="form-restaurant-settings" data-toggle="tooltip" title="Kaydet" class="btn btn-primary"><i class="fa fa-save"></i></button>
        <a href="{{ cancel }}" data-toggle="tooltip" title="Vazgeç" class="btn btn-default"><i class="fa fa-reply"></i></a>
      </div>
      <h1>Restoran Ayarları</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">
    {% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}</div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}</div>
    {% endif %}

    <div class="panel panel-default">
      <div class="panel-heading">
        <h3 class="panel-title"><i class="fa fa-cog"></i> Restoran Sistem Ayarları</h3>
      </div>
      <div class="panel-body">
        <style>
          .restaurant-settings-shell{
            background:#f6f8f7;
            border-radius:16px;
            padding:18px;
            border:1px solid #e4ebe7;
          }
          .restaurant-hero{
            display:flex;
            align-items:center;
            justify-content:space-between;
            gap:18px;
            padding:20px 22px;
            margin-bottom:16px;
            background:linear-gradient(135deg,#173126 0%,#2f5f49 58%,#c49a61 100%);
            color:#fff;
            border-radius:14px;
            box-shadow:0 18px 36px rgba(23,49,38,.16);
          }
          .restaurant-hero h2{margin:0 0 6px;font-size:22px;font-weight:800;color:#fff;}
          .restaurant-hero p{margin:0;color:rgba(255,255,255,.78);font-size:13px;line-height:1.55;}
          .restaurant-hero-badges{display:flex;flex-wrap:wrap;gap:8px;justify-content:flex-end;}
          .restaurant-hero-badge{
            display:inline-flex;
            align-items:center;
            gap:7px;
            padding:8px 11px;
            border-radius:999px;
            background:rgba(255,255,255,.14);
            color:#fff;
            font-size:12px;
            font-weight:800;
            border:1px solid rgba(255,255,255,.18);
            white-space:nowrap;
          }
          .restaurant-settings-shell .nav-tabs{
            border:0;
            display:flex;
            flex-wrap:wrap;
            gap:8px;
            margin-bottom:16px;
          }
          .restaurant-settings-shell .nav-tabs > li{float:none;margin:0;}
          .restaurant-settings-shell .nav-tabs > li > a{
            border:1px solid #dfe7e2;
            border-radius:999px;
            margin:0;
            padding:9px 14px;
            color:#5f6f67;
            background:#fff;
            font-weight:700;
          }
          .restaurant-settings-shell .nav-tabs > li.active > a,
          .restaurant-settings-shell .nav-tabs > li.active > a:hover,
          .restaurant-settings-shell .nav-tabs > li.active > a:focus{
            border-color:#2f5f49;
            background:#173126;
            color:#fff;
            box-shadow:0 10px 22px rgba(23,49,38,.14);
          }
          .settings-section-title{
            display:flex;
            align-items:center;
            justify-content:space-between;
            gap:12px;
            margin:18px 0 10px;
          }
          .settings-section-title h3{
            margin:0;
            font-size:16px;
            font-weight:800;
            color:#173126;
          }
          .settings-section-title span{
            color:#7b8981;
            font-size:12px;
            font-weight:700;
          }
          .settings-card-grid{
            display:grid;
            grid-template-columns:repeat(4,minmax(0,1fr));
            gap:12px;
            margin-bottom:16px;
          }
          .settings-mini-card{
            padding:14px;
            background:#fff;
            border:1px solid #e1e9e4;
            border-radius:12px;
            box-shadow:0 10px 24px rgba(23,49,38,.05);
          }
          .settings-mini-card strong{display:block;color:#173126;font-size:13px;margin-bottom:5px;}
          .settings-mini-card span{display:block;color:#74837b;font-size:12px;line-height:1.45;}
          .restaurant-settings-shell .tab-pane > .form-group{
            margin:0 0 10px;
            padding:16px;
            background:#fff;
            border:1px solid #e3ebe6;
            border-radius:12px;
            box-shadow:0 8px 20px rgba(23,49,38,.035);
          }
          .restaurant-settings-shell .control-label{
            color:#213c31;
            font-weight:800;
            padding-top:8px;
          }
          .restaurant-settings-shell .help-block{
            color:#718178;
            font-size:12px;
            margin-bottom:0;
            line-height:1.5;
          }
          .restaurant-settings-shell .form-control{
            border-color:#dce5df;
            border-radius:8px;
            box-shadow:none;
          }
          .restaurant-settings-shell .form-control:focus{
            border-color:#3f725d;
            box-shadow:0 0 0 3px rgba(63,114,93,.12);
          }
          .restaurant-settings-shell .img-thumbnail{
            border-radius:12px;
            border-color:#dce5df;
            padding:10px;
            background:#fbfcfb;
          }
          .restaurant-settings-shell .radio-inline{
            padding:8px 13px 8px 28px;
            margin:0 6px 8px 0;
            border:1px solid #dce5df;
            border-radius:999px;
            background:#fbfcfb;
            font-weight:700;
          }
          .restaurant-module-frame{
            width:100%;
            min-height:680px;
            border:1px solid #e3ebe6;
            border-radius:12px;
            background:#fff;
          }
          .restaurant-embed-note{
            margin:0 0 12px;
            padding:12px 14px;
            color:#4f6358;
            background:#f4faf6;
            border:1px solid #dce9e2;
            border-radius:10px;
            font-size:13px;
            font-weight:700;
          }
          @media (max-width: 991px){
            .restaurant-hero{display:block;}
            .restaurant-hero-badges{justify-content:flex-start;margin-top:12px;}
            .settings-card-grid{grid-template-columns:repeat(2,minmax(0,1fr));}
          }
          @media (max-width: 600px){
            .settings-card-grid{grid-template-columns:1fr;}
          }
        </style>
        <form action="{{ action }}" method="post" enctype="multipart/form-data" id="form-restaurant-settings" class="form-horizontal">
          <div class="restaurant-settings-shell">
          <div class="restaurant-hero">
            <div>
              <h2>Restoran Operasyon Merkezi</h2>
              <p>QR menü, sipariş akışı, garson/mutfak paneli, iletişim ve ERP ayarları tek yerden yönetilir.</p>
            </div>
            <div class="restaurant-hero-badges">
              <span class="restaurant-hero-badge"><i class="fa fa-qrcode"></i> QR Menü</span>
              <span class="restaurant-hero-badge"><i class="fa fa-bell"></i> Garson Çağrı</span>
              <span class="restaurant-hero-badge"><i class="fa fa-plug"></i> Akınsoft Bridge</span>
            </div>
          </div>
          <ul class="nav nav-tabs">
            <li class="active"><a href="#tab-menu-settings" data-toggle="tab">Menü Ayarları</a></li>
            <li><a href="#tab-tables" data-toggle="tab">Masa Yönetimi</a></li>
            <li><a href="#tab-waiters" data-toggle="tab">Garson Yönetimi</a></li>
            <li><a href="#tab-allergens" data-toggle="tab">Alerjen Tanımları</a></li>
            <li><a href="#tab-recommendation" data-toggle="tab">Menü Öneri Motoru</a></li>
            <li><a href="#tab-production" data-toggle="tab">Production Test</a></li>
            <li><a href="#tab-integrations" data-toggle="tab">AI & İletişim</a></li>
            <li><a href="#tab-erp" data-toggle="tab">ERP</a></li>
          </ul>

          <div class="tab-content">
            <div class="tab-pane active" id="tab-menu-settings">
              <div class="settings-card-grid">
                <div class="settings-mini-card">
                  <strong>QR Menü</strong>
                  <span>{% if restaurant_plain_qr_menu %}Aktif{% else %}Kapalı{% endif %}</span>
                </div>
                <div class="settings-mini-card">
                  <strong>QR Sipariş</strong>
                  <span>{% if restaurant_qr_order_menu %}Müşteri sipariş gönderebilir{% else %}Sipariş kapalı{% endif %}</span>
                </div>
                <div class="settings-mini-card">
                  <strong>Servis Akışı</strong>
                  <span>{% if restaurant_waiter_panel %}Garson onayı aktif{% else %}Garson paneli kapalı{% endif %}</span>
                </div>
                <div class="settings-mini-card">
                  <strong>Mutfak</strong>
                  <span>{% if restaurant_kitchen_panel %}Mutfak ekranı aktif{% else %}Mutfak ekranı kapalı{% endif %}</span>
                </div>
                <div class="settings-mini-card">
                  <strong>Kasa</strong>
                  <span>{% if restaurant_cashier_panel %}Kasa paneli aktif{% else %}Kasa paneli kapalı{% endif %}</span>
                </div>
              </div>

              <div class="settings-section-title">
                <h3>Marka ve Müşteri Görünümü</h3>
                <span>Logo, tema ve müşteri ekranı</span>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">Menü Logo</label>
                <div class="col-sm-3">
                  <a href="" id="thumb-menu-logo" data-toggle="image" class="img-thumbnail">
                    <img src="{{ restaurant_menu_logo_thumb }}" alt="" title="" data-placeholder="{{ placeholder }}" />
                  </a>
                  <input type="hidden" name="restaurant_menu_logo" value="{{ restaurant_menu_logo }}" id="input-menu-logo" />
                  <p class="help-block">Müşteri home/QR menü ekranlarında kullanılır.</p>
                </div>
                <label class="col-sm-2 control-label">Admin Logo</label>
                <div class="col-sm-4">
                  <a href="" id="thumb-admin-logo" data-toggle="image" class="img-thumbnail">
                    <img src="{{ restaurant_admin_logo_thumb }}" alt="" title="" data-placeholder="{{ placeholder }}" />
                  </a>
                  <input type="hidden" name="restaurant_admin_logo" value="{{ restaurant_admin_logo }}" id="input-admin-logo" />
                  <p class="help-block">Admin panel üst alanı için yatay/dikdörtgen logo kullanın.</p>
                </div>
              </div>

              <div class="settings-section-title">
                <h3>Operasyon Anahtarları</h3>
                <span>Sipariş ve panel akışı</span>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">Müşteri Menü Teması</label>
                <div class="col-sm-9">
                  <select name="restaurant_menu_theme" class="form-control" style="max-width:320px;">
                    <option value="default" {% if restaurant_menu_theme == 'default' %}selected{% endif %}>Default - Orijinal Tasarım</option>
                    <option value="v1" {% if restaurant_menu_theme == 'v1' %}selected{% endif %}>V1 - Ferah Klasik</option>
                    <option value="v2" {% if restaurant_menu_theme == 'v2' %}selected{% endif %}>V2 - Koyu Bistro</option>
                    <option value="v3" {% if restaurant_menu_theme == 'v3' %}selected{% endif %}>V3 - Minimal Beyaz</option>
                    <option value="v4" {% if restaurant_menu_theme == 'v4' %}selected{% endif %}>V4 - Premium Gece</option>
                    <option value="v5" {% if restaurant_menu_theme == 'v5' %}selected{% endif %}>V5 - Renkli Casual</option>
                  </select>
                  <p class="help-block">Default, tema eklenmeden önceki orijinal müşteri ekranıdır. V1-V5 farklı restoranlara göre alternatif görünümler sağlar.</p>
                </div>
              </div>

              <div class="settings-section-title">
                <h3>Tekrar Süreleri</h3>
                <span>Müşteri butonları ve yoğunluk bazlı hazırlık süreleri</span>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">Sadece QR Menü Kullan</label>
                <div class="col-sm-9">
                  <label class="radio-inline"><input type="radio" name="restaurant_plain_qr_menu" value="1" {% if restaurant_plain_qr_menu %}checked{% endif %}> Açık</label>
                  <label class="radio-inline"><input type="radio" name="restaurant_plain_qr_menu" value="0" {% if not restaurant_plain_qr_menu %}checked{% endif %}> Kapalı</label>
                  <p class="help-block">Siparişsiz, sadece menü gösterimi için temel anahtar.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">QR Sipariş Menü Kullan</label>
                <div class="col-sm-9">
                  <label class="radio-inline"><input type="radio" name="restaurant_qr_order_menu" value="1" {% if restaurant_qr_order_menu %}checked{% endif %}> Açık</label>
                  <label class="radio-inline"><input type="radio" name="restaurant_qr_order_menu" value="0" {% if not restaurant_qr_order_menu %}checked{% endif %}> Kapalı</label>
                  <p class="help-block">Kapalıysa müşteri QR üzerinden sipariş gönderemez.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">Garson Paneli Kullan</label>
                <div class="col-sm-9">
                  <label class="radio-inline"><input type="radio" name="restaurant_waiter_panel" value="1" {% if restaurant_waiter_panel %}checked{% endif %}> Açık</label>
                  <label class="radio-inline"><input type="radio" name="restaurant_waiter_panel" value="0" {% if not restaurant_waiter_panel %}checked{% endif %}> Kapalı</label>
                  <p class="help-block">Kapalıysa müşteri siparişi garson onayına düşmeden, mutfak açıksa doğrudan mutfağa gider.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">Mutfak Paneli Kullan</label>
                <div class="col-sm-9">
                  <label class="radio-inline"><input type="radio" name="restaurant_kitchen_panel" value="1" {% if restaurant_kitchen_panel %}checked{% endif %}> Açık</label>
                  <label class="radio-inline"><input type="radio" name="restaurant_kitchen_panel" value="0" {% if not restaurant_kitchen_panel %}checked{% endif %}> Kapalı</label>
                  <p class="help-block">Kapalıysa sipariş akışı mutfak ekranına gönderilmez. Akınsoft entegrasyonu açıkken mutfak Akınsoft üzerinden yönetilir.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">Kasa Paneli Kullan</label>
                <div class="col-sm-9">
                  <label class="radio-inline"><input type="radio" name="restaurant_cashier_panel" value="1" {% if restaurant_cashier_panel %}checked{% endif %}> Açık</label>
                  <label class="radio-inline"><input type="radio" name="restaurant_cashier_panel" value="0" {% if not restaurant_cashier_panel %}checked{% endif %}> Kapalı</label>
                  <p class="help-block">Açıksa ödeme alma ve günlük tahsilat takibi Kasa Paneli üzerinden yapılır. Akınsoft entegrasyonu açıkken kasa Akınsoft tarafında yönetilir.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">Garson Çağrı Tekrar Süresi</label>
                <div class="col-sm-9">
                  <div class="input-group" style="max-width:220px;">
                    <input type="number" name="restaurant_waiter_call_reset_minutes" value="{{ restaurant_waiter_call_reset_minutes }}" min="1" max="60" class="form-control">
                    <span class="input-group-addon">dk</span>
                  </div>
                  <p class="help-block">Garson çağrıyı gördükten sonra butonun müşteride tekrar aktif olacağı süre. Önerilen değer 5 dakikadır.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">Hesap Talebi Tekrar Süresi</label>
                <div class="col-sm-9">
                  <div class="input-group" style="max-width:220px;">
                    <input type="number" name="restaurant_bill_request_reset_minutes" value="{{ restaurant_bill_request_reset_minutes }}" min="1" max="60" class="form-control">
                    <span class="input-group-addon">dk</span>
                  </div>
                  <p class="help-block">Garson hesap talebini gördükten sonra müşterinin tekrar hesap isteyebileceği süre. Önerilen değer 5 dakikadır.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">WiFi Adı</label>
                <div class="col-sm-9">
                  <input type="text" name="restaurant_wifi_name" value="{{ restaurant_wifi_name }}" class="form-control" style="max-width:420px;" placeholder="Örn: Varol Veranda Misafir">
                  <p class="help-block">Müşteri WiFi penceresinde bağlanması gereken ağ adı olarak gösterilir.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">WiFi Şifresi</label>
                <div class="col-sm-9">
                  <input type="text" name="restaurant_wifi_password" value="{{ restaurant_wifi_password }}" class="form-control" style="max-width:420px;" placeholder="Örn: Veranda2026">
                  <p class="help-block">Doluysa müşteri menü ve kategori ekranlarında WiFi simgesine dokunarak ağ adını ve şifreyi görebilir. Kopyala düğmesi sadece şifreyi kopyalar.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">Orta Yoğun Hazırlık Ek Süresi</label>
                <div class="col-sm-9">
                  <div class="input-group" style="max-width:220px;">
                    <input type="number" name="restaurant_medium_density_prep_extra_minutes" value="{{ restaurant_medium_density_prep_extra_minutes }}" min="0" max="120" class="form-control">
                    <span class="input-group-addon">dk</span>
                  </div>
                  <p class="help-block">Masaların %30-%60 arası dolu olduğu durumda ürün hazırlık süresine eklenecek dakika.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">Yoğun Hazırlık Ek Süresi</label>
                <div class="col-sm-9">
                  <div class="input-group" style="max-width:220px;">
                    <input type="number" name="restaurant_high_density_prep_extra_minutes" value="{{ restaurant_high_density_prep_extra_minutes }}" min="0" max="120" class="form-control">
                    <span class="input-group-addon">dk</span>
                  </div>
                  <p class="help-block">Masaların %60 üzeri dolu olduğu durumda ürün hazırlık süresine eklenecek dakika.</p>
                </div>
              </div>
            </div>

            <div class="tab-pane" id="tab-tables">
              <p class="restaurant-embed-note">Masalar, QR kodları ve salon düzeni bu sekmeden yönetilir.</p>
              <iframe class="restaurant-module-frame" data-embedded-admin="1" src="{{ restaurant_tables_url }}"></iframe>
            </div>

            <div class="tab-pane" id="tab-waiters">
              <p class="restaurant-embed-note">Garson kullanıcıları, masa yetkileri ve servis alanları bu sekmeden yönetilir.</p>
              <iframe class="restaurant-module-frame" data-embedded-admin="1" src="{{ restaurant_waiters_url }}"></iframe>
            </div>

            <div class="tab-pane" id="tab-allergens">
              <p class="restaurant-embed-note">Ürünlerde kullanılan alerjen seçenekleri bu sekmeden yönetilir.</p>
              <iframe class="restaurant-module-frame" data-embedded-admin="1" src="{{ allergen_url }}"></iframe>
            </div>

            <div class="tab-pane" id="tab-recommendation">
              <p class="restaurant-embed-note">Menü önerileri, öne çıkan ürünler ve öneri akışı bu sekmeden yönetilir.</p>
              <iframe class="restaurant-module-frame" data-embedded-admin="1" src="{{ recommendation_url }}"></iframe>
            </div>

            <div class="tab-pane" id="tab-production">
              <p class="restaurant-embed-note">Canlı kullanım öncesi kritik QR, panel, ses, yetki ve açık işlem kontrolleri.</p>
              <div class="row">
                {% for check in production_checks %}
                  <div class="col-sm-6 col-lg-4">
                    <div class="well production-check production-{{ check.state }}">
                      <div class="production-check-head">
                        {% if check.state == 'ok' %}
                          <i class="fa fa-check-circle text-success"></i>
                        {% elseif check.state == 'warning' %}
                          <i class="fa fa-exclamation-triangle text-warning"></i>
                        {% else %}
                          <i class="fa fa-times-circle text-danger"></i>
                        {% endif %}
                        <strong>{{ check.title }}</strong>
                      </div>
                      <p>{{ check.detail }}</p>
                    </div>
                  </div>
                {% endfor %}
              </div>
              <style>
                .production-check{min-height:122px;border-radius:8px;background:#fff;}
                .production-check-head{display:flex;align-items:center;gap:8px;margin-bottom:10px;font-size:15px;}
                .production-check-head i{font-size:20px;}
                .production-check p{margin:0;color:#66706b;font-weight:600;}
                .production-ok{border-left:5px solid #3c763d;}
                .production-warning{border-left:5px solid #d29922;}
                .production-error{border-left:5px solid #a94442;}
              </style>
            </div>

            <div class="tab-pane" id="tab-integrations">
              <div class="form-group">
                <label class="col-sm-3 control-label">OpenAI Secret Key</label>
                <div class="col-sm-9">
                  <input type="password" name="restaurant_openai_api_key" value="{{ restaurant_openai_api_key }}" class="form-control" autocomplete="new-password">
                  <p class="help-block">Menü öneri motorunun AI metinleri için kullanılır. Boş bırakılırsa öneri motoru yedek metinle çalışır.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">WeatherAPI Key</label>
                <div class="col-sm-9">
                  <input type="password" name="restaurant_weatherapi_key" value="{{ restaurant_weatherapi_key }}" class="form-control" autocomplete="new-password">
                  <p class="help-block">Hava durumuna göre öneri üretmek için kullanılır.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">Hava Durumu Konumu</label>
                <div class="col-sm-4">
                  <input type="text" name="restaurant_weather_lat" value="{{ restaurant_weather_lat }}" placeholder="Latitude" class="form-control">
                </div>
                <div class="col-sm-4">
                  <input type="text" name="restaurant_weather_lon" value="{{ restaurant_weather_lon }}" placeholder="Longitude" class="form-control">
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">WhatsApp Telefon</label>
                <div class="col-sm-9">
                  <input type="text" name="restaurant_whatsapp_phone" value="{{ restaurant_whatsapp_phone }}" placeholder="905xxxxxxxxx" class="form-control">
                  <p class="help-block">Menü footer WhatsApp butonu bu numaraya yönlenir. Ülke kodu ile, boşluksuz giriniz.</p>
                </div>
              </div>

              <div class="form-group">
                <label class="col-sm-3 control-label">Şikayet & Öneri Maili</label>
                <div class="col-sm-9">
                  <input type="email" name="restaurant_feedback_email" value="{{ restaurant_feedback_email }}" placeholder="mail@domain.com" class="form-control">
