  <script type="text/javascript"><!--
  function prepareRestaurantFrame(frame) {
    try {
      var doc = frame.contentDocument || frame.contentWindow.document;

      if (!doc) {
        return;
      }

      var style = doc.createElement('style');
      style.innerHTML = '#header,#column-left,footer{display:none!important;}#content{margin-left:0!important;padding-top:0!important;}.page-header{margin-top:0!important;}body{background:#fff!important;}';
      doc.head.appendChild(style);

      var resize = function() {
        var height = Math.max(
          doc.body ? doc.body.scrollHeight : 0,
          doc.documentElement ? doc.documentElement.scrollHeight : 0,
          680
        );
        frame.style.height = height + 'px';
      };

      resize();
      setTimeout(resize, 500);
      setTimeout(resize, 1200);
    } catch (e) {}
  }

  $('.restaurant-module-frame').on('load', function() {
    prepareRestaurantFrame(this);
  });

  function refreshRestaurantFrame(frame) {
    var $frame = $(frame);
    var currentSrc = $frame.attr('src') || '';

    if (!currentSrc) {
      return;
    }

    var cleanSrc = currentSrc.replace(/([?&])_rs=\d+(&?)/, function(match, prefix, suffix) {
      return suffix ? prefix : '';
    }).replace(/[?&]$/, '');

    var separator = cleanSrc.indexOf('?') === -1 ? '?' : '&';
    $frame.attr('src', cleanSrc + separator + '_rs=' + Date.now());
  }

  $('a[data-toggle="tab"]').on('shown.bs.tab', function() {
    toggleRestaurantSettingsSave();

    $('.tab-pane.active .restaurant-module-frame').each(function() {
      refreshRestaurantFrame(this);
    });
  });

  function toggleRestaurantSettingsSave() {
    var target = $('.nav-tabs li.active a[data-toggle="tab"]').attr('href');
    var showSave = target == '#tab-menu-settings' || target == '#tab-integrations' || target == '#tab-erp';

    $('button[form="form-restaurant-settings"]').toggle(showSave);
  }

  function toggleAkinsoftMode() {
    var mode = $('input[name="restaurant_akinsoft_mode"]:checked').val();
    var akinsoftEnabled = $('input[name="restaurant_akinsoft_enabled"]:checked').val() == '1';

    $('.akinsoft-local-fields').toggle(mode == 'local_firebird');
    $('.akinsoft-bridge-fields').toggle(mode == 'bridge_agent');

    $('input[name="restaurant_kitchen_panel"], input[name="restaurant_cashier_panel"]').prop('disabled', akinsoftEnabled);

    if (akinsoftEnabled) {
      $('input[name="restaurant_kitchen_panel"][value="0"], input[name="restaurant_cashier_panel"][value="0"]').prop('checked', true);
    }
  }

  $('input[name="restaurant_akinsoft_mode"]').on('change', toggleAkinsoftMode);
  $('input[name="restaurant_akinsoft_enabled"]').on('change', toggleAkinsoftMode);
  toggleAkinsoftMode();

  function runAkinsoftAction(button, url, loadingText) {
    var $button = $(this);
    var $result = $('#akinsoft-test-result');
    var iconClass = $button.find('i').attr('class');

    if (button) {
      $button = $(button);
      iconClass = $button.find('i').attr('class');
    }

    $button.prop('disabled', true).find('i').attr('class', 'fa fa-spinner fa-spin');
    $result.removeClass('text-success text-danger').text(loadingText);

    $.ajax({
      url: url,
      type: 'post',
      dataType: 'json',
      data: $('#form-restaurant-settings').serialize(),
      success: function(json) {
        if (json && json.success) {
          $result.addClass('text-success').text(json.message);
        } else {
          $result.addClass('text-danger').text(json && json.message ? json.message : 'Bağlantı testi başarısız.');
        }
      },
      error: function() {
        $result.addClass('text-danger').text('İşlem sırasında hata oluştu.');
      },
      complete: function() {
        $button.prop('disabled', false).find('i').attr('class', iconClass);
      }
    });
  }

  $('#button-akinsoft-test').on('click', function() {
    runAkinsoftAction(this, '{{ akinsoft_test_url|replace({"&amp;":"&"}) }}', 'Test ediliyor...');
  });

  $('#button-akinsoft-sync-tables').on('click', function() {
    runAkinsoftAction(this, '{{ akinsoft_sync_tables_url|replace({"&amp;":"&"}) }}', 'Masalar Akınsofttan çekiliyor...');
  });

  $('#button-akinsoft-sync-prices').on('click', function() {
    runAkinsoftAction(this, '{{ akinsoft_sync_prices_url|replace({"&amp;":"&"}) }}', 'Fiyatlar Akınsofttan güncelleniyor...');
  });

  toggleRestaurantSettingsSave();
  //--></script>
