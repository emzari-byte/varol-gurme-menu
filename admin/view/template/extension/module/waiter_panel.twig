{{ header }}{{ column_left }}

<div id="content">
	<div class="page-header">
		<div class="container-fluid">
			<h1>Garson Paneli</h1>
			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
					<li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
				{% endfor %}
			</ul>
		</div>
	</div>

	<div class="container-fluid">
		<div class="waiter-summary">
			<div class="box">
				Toplam Masa
				<strong id="summary-total">{{ total_tables }}</strong>
			</div>
			<div class="box">
				Aktif Masa
				<strong id="summary-active">{{ active_tables }}</strong>
			</div>
			<div class="box">
				Onay Bekleyen
				<strong id="summary-call">{{ new_calls }}</strong>
			</div>
			<div class="box">
				Bugün Ödenen
				<strong id="summary-paid">{{ paid_count }}</strong>
			</div>
		</div>

		{% if admin_notification_controls %}
			<div class="waiter-admin-alert-controls" id="waiterAdminAlertControls">
				<button type="button" class="waiter-alert-toggle" id="toggleAdminNotifications" title="Bildirimleri kapat" aria-label="Bildirimleri kapat">
					<i class="fa fa-bell"></i>
					<span>Bildirimler</span>
				</button>
				<button type="button" class="waiter-alert-toggle" id="toggleAdminSound" title="Sesi kapat" aria-label="Sesi kapat">
					<i class="fa fa-volume-up"></i>
					<span>Ses</span>
				</button>
			</div>
		{% endif %}

		<div class="panel panel-default">
			<div class="panel-heading">
				<h3 class="panel-title"><i class="fa fa-cutlery"></i> Masalar</h3>
			</div>
			<div class="panel-body">
				<div class="waiter-grid" id="waiter-grid">
					{% for table in tables %}
						{% set status_text = {
	'empty': 'Boş',
	'waiting_order': 'Onay Bekliyor',
	'cashier_draft': 'Kasa Taslağı',
	'in_kitchen': 'Mutfakta',
	'ready_for_service': 'Servise Hazır',
	'served': 'Servis Edildi',
	'paid': 'Ödeme Alındı',
	'out_for_service': 'Servise Çıkıyor',
	'cancelled': 'İptal'
} %}

						<div class="table-card {{ table.service_status }}"
							 data-table-id="{{ table.table_id }}"
							 data-table-no="{{ table.table_no }}"
							 data-status="{{ table.service_status }}"
							 data-waiter-call-pending="{{ table.waiter_call_pending|default(0) }}"
							 data-waiter-call-status="{{ table.latest_waiter_call_status|default('') }}"
							 data-bill-request-pending="{{ table.bill_request_pending|default(0) }}"
							 data-bill-request-status="{{ table.latest_bill_request_status|default('') }}"
							 data-bill-request-note="{{ table.latest_bill_request_note|default('')|e('html_attr') }}"
							 data-note="{{ table.note|e('html_attr') }}">
							<div class="table-top">
								<div>
									<div class="table-name">Masa {{ table.table_no }}</div>
									<div class="table-sub">{{ table.area }} · {{ table.capacity }} Kişi</div>
								</div>

								<div class="table-amount">{{ table.total_amount }} TL</div>
							</div>

							<div class="table-service-name">{{ table.name }}</div>

							<div class="table-operation {{ table.operation_class|default('idle') }}">
								<span>{{ table.operation_label|default('Boş masa') }}</span>
								{% if table.operation_time %}
									<strong>{{ table.operation_time }}</strong>
								{% endif %}
							</div>

							{% if table.bill_payment_note %}
								<div class="bill-payment-chip">{{ table.bill_payment_note }}</div>
							{% endif %}

							<div class="table-footer">
								<span class="table-status-badge">
									{{ status_text[table.service_status] is defined ? status_text[table.service_status] : table.service_status }}
								</span>

								{% if table.call_badge %}
									<span class="table-alert-badge {{ table.call_badge_class }}">{{ table.call_badge }}</span>
								{% endif %}

								<span class="order-count">{{ table.active_order_count }} Sipariş</span>
							</div>

							<div class="waiter-note">{{ table.note }}</div>
						</div>
					{% endfor %}
				</div>
			</div>
		</div>
	</div>
</div>

<div class="waiter-modal-backdrop" id="waiterModalBackdrop"></div>

<div class="waiter-modal" id="waiterModal">
	<h3 id="modalTitle">Masa Detayı</h3>

	<input type="hidden" id="modal_table_id" value="">

	<div class="waiter-call-panel" id="waiterCallPanel" style="display:none;">
		<div>
			<strong id="waiterCallTitle">Garson çağrısı var</strong>
			<span id="waiterCallText">Müşteri masaya destek istiyor.</span>
		</div>
		<button type="button" class="btn btn-success" id="ackWaiterCallBtn">Tamam, masaya gidiyorum</button>
	</div>

	<div class="waiter-call-panel bill-panel" id="billRequestPanel" style="display:none;">
		<div>
			<strong id="billRequestTitle">Hesap talebi var</strong>
			<span id="billRequestText">Müşteri hesabı istiyor.</span>
			<span id="billPaymentNote"></span>
		</div>
	</div>

	<div class="form-group">
		<label>Masa Notu</label>
		<textarea id="modal_note" class="form-control" rows="3" placeholder="Masa notu..."></textarea>
	</div>

	<div class="form-group">
		<label>Masaya Bağlı Siparişler</label>
		<div id="orderList"><div class="no-orders">Yükleniyor...</div></div>
	</div>
    <div class="form-group">
	<label>Garson İlave Ürün</label>

	<input type="text"
		   id="manualProductSearch"
		   class="form-control"
		   placeholder="Ürün ara: su, kola, kahve...">

	<div id="manualProductResults" class="manual-product-results"></div>

	<div id="manualSelectedProducts" class="manual-selected-products"></div>
</div>
<button type="button"
id="sendManualOrderBtn"
class="btn btn-success"
disabled
style="margin-top:12px;width:100%;opacity:.55;cursor:not-allowed;">
Mutfağa Gönder
</button>
	<div class="actions">
		<button type="button" class="btn btn-default" id="modalCloseBtn">Kapat</button>
		<button type="button" class="btn btn-primary" id="modalSaveBtn">Masa Notunu Kaydet</button>
	</div>
</div>

<div id="orderAlarm">
	<div id="alarmTitle">YENİ SİPARİŞ</div>
	<div id="alarmTable"></div>
	<div id="alarmSubText">Garson lütfen siparişi kontrol edin</div>
	<button id="alarmOkBtn">TAMAM</button>
</div>

<script>
(function($) {
	var refreshUrl      = '{{ refresh_url|replace({'&amp;':'&'}) }}';
	var ordersUrl       = '{{ orders_url|replace({'&amp;':'&'}) }}';
	var orderStatusUrl  = '{{ order_status_url|replace({'&amp;':'&'}) }}';
	var removeOrderProductUrl = '{{ remove_order_product_url|replace({'&amp;':'&'}) }}';
	var tableNoteUrl    = '{{ table_note_url|replace({'&amp;':'&'}) }}';
	var waiterCallAckUrl = '{{ waiter_call_ack_url|replace({'&amp;':'&'}) }}';
	var billRequestAckUrl = '{{ bill_request_ack_url|replace({'&amp;':'&'}) }}';
    var productSearchUrl = '{{ product_search_url|replace({'&amp;':'&'}) }}';
	var originalTitle = document.title;
	var previousWaitingTables = [];
	var previousBillRequests = [];
	var previousWaiterCalls = [];
	var previousReadyCalls=[];
    var firstReadyRefresh=false;
    var firstBillRefreshCompleted = false;
    var firstWaiterRefreshCompleted = false;
	var notificationPermissionAsked = false;
	var audioUnlocked = false;
	var notifyAudio = new Audio('/menu/sound/notify.wav');
	var autoOpenedTableKey = null;
	var firstRefreshCompleted = false;
	var alarmLoop = null;
	var alarmOpen = false;
	var titleBlinkInterval = null;
	var titleBlinkState = false;
    var manualOrderItems = {};
    var currentTableOrders = [];
    var currentBillRequestPending = false;
    var currentBillRequestStatus = '';
    var currentMainAction = null;
    var productSearchTimer = null;
	var manualOrderUrl='{{ manual_order_url|replace({'&amp;':'&'}) }}';
    var kitchenPanelEnabled = {{ kitchen_panel_enabled ? 1 : 0 }};
    var akinsoftEnabled = {{ akinsoft_enabled ? 1 : 0 }};
    var cashierPanelEnabled = {{ cashier_panel_enabled ? 1 : 0 }};
	var adminNotificationControls = {{ admin_notification_controls ? 1 : 0 }};
	var notificationsMuted = adminNotificationControls ? getLocalFlag('waiter_admin_notifications_muted') : false;
	var soundMuted = adminNotificationControls ? getLocalFlag('waiter_admin_sound_muted') : false;
	function statusText(status) {
		var map = {
empty:'Boş',
waiting_order:'Onay Bekliyor',
cashier_draft:'Kasa Taslağı',
in_kitchen:'Mutfakta',
ready_for_service:'Servise Hazır',
out_for_service:'Servise Çıkıyor',
served:'Servis Edildi',
paid:'Ödeme Alındı',
cancelled:'İptal'
};
		return map[status] || status;
	}

	function getLocalFlag(key) {
		try {
			return localStorage.getItem(key) === '1';
		} catch (e) {
			return false;
		}
	}

	function setLocalFlag(key, value) {
		try {
			localStorage.setItem(key, value ? '1' : '0');
		} catch (e) {}
	}

	function notificationsEnabled() {
		return !notificationsMuted;
	}

	function soundEnabled() {
		return notificationsEnabled() && !soundMuted;
	}

	function updateAdminAlertControls() {
		if (!adminNotificationControls) return;

		var $notifications = $('#toggleAdminNotifications');
		var $sound = $('#toggleAdminSound');

		$notifications
			.toggleClass('is-muted', notificationsMuted)
			.attr('title', notificationsMuted ? 'Bildirimleri ac' : 'Bildirimleri kapat')
			.attr('aria-label', notificationsMuted ? 'Bildirimleri ac' : 'Bildirimleri kapat')
			.find('i')
			.removeClass('fa-bell fa-bell-slash')
			.addClass(notificationsMuted ? 'fa-bell-slash' : 'fa-bell');

		$sound
			.prop('disabled', notificationsMuted)
			.toggleClass('is-muted', soundMuted || notificationsMuted)
			.attr('title', soundMuted ? 'Sesi ac' : 'Sesi kapat')
			.attr('aria-label', soundMuted ? 'Sesi ac' : 'Sesi kapat')
			.find('i')
			.removeClass('fa-volume-up fa-volume-off')
			.addClass((soundMuted || notificationsMuted) ? 'fa-volume-off' : 'fa-volume-up');
	}

	function escapeHtml(text) {
		if (text === null || text === undefined) return '';
		return $('<div>').text(text).html();
	}
$(document).on('input', '#manualProductSearch', function() {
	var keyword = $(this).val();

	clearTimeout(productSearchTimer);

	if (!keyword || keyword.length < 2) {
		$('#manualProductResults').html('');
		return;
	}

	productSearchTimer = setTimeout(function() {
		$.ajax({
			url: productSearchUrl + '&keyword=' + encodeURIComponent(keyword),
			type: 'GET',
			dataType: 'json',
			cache: false,
			success: function(json) {
				if (json.error) {
					$('#manualProductResults').html('<div class="no-orders">' + json.error + '</div>');
					return;
				}

				renderProductResults(json.products || []);
			},
			error: function() {
				$('#manualProductResults').html('<div class="no-orders">Ürün aranırken hata oluştu.</div>');
			}
		});
	}, 250);
});

$(document).on('click', '.manual-product-result', function() {
	var productId = String($(this).data('product-id'));

	if (!manualOrderItems[productId]) {
		manualOrderItems[productId] = {
			product_id: parseInt(productId, 10),
			name: $(this).data('name'),
			price: $(this).data('price'),
			price_raw: parseFloat($(this).data('price-raw')) || 0,
			quantity: 1
		};
	} else {
		manualOrderItems[productId].quantity++;
	}

	$('#manualProductSearch').val('');
	$('#manualProductResults').html('');
	renderManualSelectedProducts();
});

$(document).on('click', '.manual-plus', function() {
	var productId = String($(this).data('product-id'));

	if (manualOrderItems[productId]) {
		manualOrderItems[productId].quantity++;
		renderManualSelectedProducts();
	}
});

$(document).on('click', '.manual-minus', function() {
	var productId = String($(this).data('product-id'));

	if (manualOrderItems[productId]) {
		manualOrderItems[productId].quantity--;

		if (manualOrderItems[productId].quantity <= 0) {
			delete manualOrderItems[productId];
		}

		renderManualSelectedProducts();
	}
});
	function bindCards() {
		$('.table-card').off('click').on('click', function() {
			openModal(this);
		});
	}

	function openModal(card) {
		var tableId = $(card).attr('data-table-id');
		var tableNo = $(card).attr('data-table-no');

		$('#modal_table_id').val(tableId);
		$('#modalTitle').text('Masa ' + tableNo + ' Detayı');
		$('#modal_note').val($(card).attr('data-note') || '');
		updateWaiterCallPanel($(card).attr('data-waiter-call-pending'), $(card).attr('data-waiter-call-status'));
		updateBillRequestPanel($(card).attr('data-bill-request-pending'), $(card).attr('data-bill-request-status'), $(card).attr('data-bill-request-note'));
		$('#orderList').html('<div class="no-orders">Yükleniyor...</div>');
        
		$('#waiterModalBackdrop').show();
		$('#waiterModal').show();
        resetManualOrderBox();
		loadOrders(tableId);
	}

	function openModalByTableData(table) {
		if (!table || !table.table_id) return;

		var fakeCard = $('<div>')
			.attr('data-table-id', table.table_id)
			.attr('data-table-no', table.table_no)
			.attr('data-waiter-call-pending', table.waiter_call_pending || 0)
			.attr('data-waiter-call-status', table.latest_waiter_call_status || '')
			.attr('data-bill-request-pending', table.bill_request_pending || 0)
			.attr('data-bill-request-status', table.latest_bill_request_status || '')
			.attr('data-bill-request-note', table.latest_bill_request_note || '')
			.attr('data-note', table.note || '');

		openModal(fakeCard);
	}

	function updateWaiterCallPanel(pending, status) {
		var hasPending = parseInt(pending || 0, 10) > 0;

		if (!hasPending) {
			$('#waiterCallPanel').hide();
			$('#ackWaiterCallBtn').prop('disabled', false).text('Tamam, masaya gidiyorum');
			return;
		}

		$('#waiterCallPanel').css('display', 'flex');

		if (status === 'seen') {
			$('#waiterCallTitle').text('Çağrı görüldü');
			$('#waiterCallText').text('Müşteri ekranında garsonun masaya geldiği bilgisi görünüyor.');
			$('#ackWaiterCallBtn').prop('disabled', true).text('Müşteriye bilgi verildi');
		} else {
			$('#waiterCallTitle').text('Garson çağrısı var');
			$('#waiterCallText').text('Müşteri masaya destek istiyor.');
			$('#ackWaiterCallBtn').prop('disabled', false).text('Tamam, masaya gidiyorum');
		}
	}

	function updateBillRequestPanel(pending, status, note) {
		var hasPending = parseInt(pending || 0, 10) > 0;
		currentBillRequestPending = hasPending;
		currentBillRequestStatus = hasPending ? (status || '') : '';

		if (!hasPending) {
			$('#billRequestPanel').hide();
			$('#billPaymentNote').text('');
			toggleManualOrderButton();
			return;
		}

		$('#billRequestPanel').css('display', 'flex');
		$('#billPaymentNote').text(note || '');

		if (status === 'seen') {
			$('#billRequestTitle').text('Hesap talebi görüldü');
			$('#billRequestText').text('Müşteri ekranında hesap talebinin alındığı bilgisi görünüyor.');
		} else {
			$('#billRequestTitle').text('Hesap talebi var');
			$('#billRequestText').text('Müşteri hesabını istiyor.');
		}
		toggleManualOrderButton();
	}

	function closeModal() {
		$('#waiterModalBackdrop').hide();
		$('#waiterModal').hide();
	}

	function orderButtons(order) {
		var html = '<div class="order-actions" style="margin-top:10px; display:flex; gap:8px; flex-wrap:wrap;">';

		if (order.service_status === 'waiting_order') {
			html += '<button type="button" class="btn btn-sm btn-danger js-order-status" data-id="' + order.restaurant_order_id + '" data-status="cancelled">İptal</button>';
		} else if (order.service_status === 'in_kitchen') {
			html += '<span class="label label-info">Mutfakta hazırlanıyor</span>';
		} else if (order.service_status === 'ready_for_service') {
			html += '<button type="button" class="btn btn-sm btn-success js-order-status" data-id="' + order.restaurant_order_id + '" data-status="served">Servis Edildi</button>';
		} else if (order.service_status === 'out_for_service') {
			html += '<button type="button" class="btn btn-sm btn-success js-order-status" data-id="' + order.restaurant_order_id + '" data-status="served">Servis Edildi</button>';
		} else if (order.service_status === 'served') {
			html += '<button type="button" class="btn btn-sm btn-warning js-order-status" data-id="' + order.restaurant_order_id + '" data-status="paid">Ödeme Alındı</button>';
		} else if (order.service_status === 'paid') {
			html += '<span class="label label-success">Ödeme tamamlandı</span>';
		} else if (order.service_status === 'cancelled') {
			html += '<span class="label label-danger">Sipariş iptal edildi</span>';
		}

		html += '</div>';

		return html;
	}
	function orderButtons(order) {
		if (order.service_status === 'in_kitchen') {
			return '<div class="order-actions"><span class="label label-info">Mutfakta hazırlanıyor</span></div>';
		}

		if (order.service_status === 'cancelled') {
			return '<div class="order-actions"><span class="label label-danger">Sipariş iptal edildi</span></div>';
		}

		return '';
	}

	function orderIntegrationBadge(order) {
		if (!order || !order.integration_status) {
			return '';
		}

		if (order.integration_status === 'sent') {
			var sentText = 'Akınsoft’a aktarıldı';

			if (order.external_order_no) {
				sentText += ' #' + order.external_order_no;
			}

			return '<div class="order-integration sent">' + escapeHtml(sentText) + '</div>';
		}

		if (order.integration_status === 'failed') {
			return '<div class="order-integration failed">' + escapeHtml(order.integration_message || 'Akınsoft aktarımı başarısız') + '</div>';
		}

		if (order.integration_status === 'pending_export') {
			return '<div class="order-integration pending">Akınsoft aktarımı bekliyor</div>';
		}

		return '';
	}

	function renderOrders(orders) {
		var html = '';
		currentTableOrders = orders || [];

		if (!orders || !orders.length) {
			html = '<div class="no-orders">Bu masaya bağlı aktif sipariş yok.</div>';
		} else {
			orders.forEach(function(order) {
				html += '<div class="order-box">';
				html += '<div class="order-head">Sipariş #' + escapeHtml(order.restaurant_order_id) + ' - ' + statusText(order.service_status) + '</div>';
				html += '<div class="order-date">' + escapeHtml(order.date_added || '') + '</div>';
				html += orderIntegrationBadge(order);

				if (order.customer_note) {
					html += '<div class="waiter-note" style="margin-bottom:8px;">Not: ' + escapeHtml(order.customer_note) + '</div>';
				}

				if (order.products && order.products.length) {
					order.products.forEach(function(product) {
						html += '<div class="order-product-row">';
						html += '<div>' + escapeHtml(product.name) + ' x ' + escapeHtml(product.quantity) + '</div>';
						html += '<div class="order-product-side"><span>' + escapeHtml(product.total) + ' ₺</span>' + (order.service_status === 'waiting_order' ? '<button type="button" class="btn btn-xs btn-danger js-remove-order-product" data-id="' + escapeHtml(product.restaurant_order_product_id) + '">Sil</button>' : '') + '</div>';
						html += '</div>';
					});
				} else {
					html += '<div class="no-orders">Bu siparişte ürün yok.</div>';
				}

				html += '<div class="order-total">Toplam: ' + escapeHtml(order.total_amount || '0.0000') + ' ₺</div>';
				html += orderButtons(order);
				html += '</div>';
			});
		}

		$('#orderList').html(html);
		bindOrderButtons();
		toggleManualOrderButton();
	}

	function loadOrders(tableId) {
		$.ajax({
			url: ordersUrl + '&table_id=' + tableId,
			type: 'GET',
			dataType: 'json',
			cache: false,
			success: function(json) {
	if (json.error) {
		$('#orderList').html('<div class="no-orders">' + json.error + '</div>');
		return;
	}

	renderOrders(json.orders || []);
},
error: function(xhr) {
	$('#orderList').html('<div class="no-orders">Siparişler alınırken hata oluştu.<br>' + (xhr.responseText ? xhr.responseText : '') + '</div>');
}
		});
	}

	function bindOrderButtons() {
		$('.js-remove-order-product').off('click').on('click', function() {
			var button = $(this);
			var rowId = button.data('id');
			var tableId = $('#modal_table_id').val();

			if (!rowId || !confirm('Bu ürün siparişten çıkarılsın mı?')) {
				return;
			}

			button.prop('disabled', true);

			$.ajax({
				url: removeOrderProductUrl,
				type: 'POST',
				dataType: 'json',
				cache: false,
				data: {
					restaurant_order_product_id: rowId
				},
				success: function(json) {
					if (json.success) {
						loadOrders(tableId);
						refreshPanel();
					} else {
						alert(json.message || 'Ürün çıkarılamadı.');
						button.prop('disabled', false);
					}
				},
				error: function() {
					alert('Ürün çıkarılırken hata oluştu.');
					button.prop('disabled', false);
				}
			});
		});

		$('.js-order-status').off('click').on('click', function() {
		    var $button = $(this);
		    var nextStatus = $(this).data('status');

var confirmText='';
if(nextStatus=='out_for_service'){
	confirmText='Siparişi teslim aldığınızı onaylıyor musunuz?';
}
if(nextStatus=='served'){
	confirmText='Sipariş servis edildi olarak işaretlensin mi?';
}
if(nextStatus=='in_kitchen'){
	confirmText='Siparişi mutfağa göndermek istiyor musunuz?';
}

if(nextStatus=='served'){
	confirmText='Sipariş servis edildi olarak işaretlensin mi?';
}

if(nextStatus=='paid'){
	confirmText='Bu sipariş ödeme alındı olarak kapatılsın mı?';
}

if(nextStatus=='cancelled'){
	confirmText='Sipariş iptal edilsin mi?';
}

if(confirmText && !confirm(confirmText)){
	return;
}
			var restaurantOrderId = $(this).data('id');
			var serviceStatus = $(this).data('status');
			var tableId = $('#modal_table_id').val();

