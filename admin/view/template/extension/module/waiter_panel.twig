	function requestNotificationPermission() {
		if (!notificationsEnabled()) return;
		if (!('Notification' in window)) return;

		if (!notificationPermissionAsked && Notification.permission === 'default') {
			notificationPermissionAsked = true;
			Notification.requestPermission();
		}
	}

	function unlockAudio() {
		if (!soundEnabled()) return;
		if (audioUnlocked) return;

		audioUnlocked = true;

		try {
			notifyAudio.volume = 1;
			notifyAudio.load();
		} catch (e) {}
	}

	function playNotifySound() {
		if (!soundEnabled()) return;

		try {
			notifyAudio.currentTime = 0;
			notifyAudio.play().catch(function() {});
		} catch (e) {}
	}

	function vibratePhone(pattern) {
		if (!notificationsEnabled()) return;

		if (navigator.vibrate) {
			navigator.vibrate(pattern || [250, 120, 250]);
		}
	}

	function showToast(message) {
		if (!notificationsEnabled()) return;

		var $oldToast = $('#waiter-new-order-toast');

		if ($oldToast.length) {
			$oldToast.remove();
		}

		var $toast = $('<div id="waiter-new-order-toast"></div>');
		$toast.text(message).css({
			position: 'fixed',
			top: '0',
			left: '0',
			right: '0',
			background: '#e53935',
			color: '#fff',
			padding: '14px 16px',
			fontSize: '16px',
			fontWeight: '700',
			textAlign: 'center',
			zIndex: 10050,
			boxShadow: '0 2px 10px rgba(0,0,0,0.25)'
		});

		$('body').append($toast);

		setTimeout(function() {
			$toast.fadeOut(300, function() {
				$(this).remove();
			});
		}, 4500);
	}

	function showBrowserNotification(title, body) {
		if (!notificationsEnabled()) return;
		if (!('Notification' in window)) return;

		if (Notification.permission === 'granted') {
			try {
				new Notification(title, {
					body: body,
					icon: '/image/catalog/logo.png'
				});
			} catch (e) {}
		}
	}

	function startTitleBlink(message) {
	if (!notificationsEnabled()) return;

	if (titleBlinkInterval) {
		clearInterval(titleBlinkInterval);
	}

	titleBlinkState = false;

	titleBlinkInterval = setInterval(function() {
		titleBlinkState = !titleBlinkState;

		if (titleBlinkState) {
			document.title = message;
		} else {
			document.title = '(Yeni Bildirim) ' + originalTitle;
		}
	}, 1000);
}

	function stopTitleBlink() {
		if (titleBlinkInterval) {
			clearInterval(titleBlinkInterval);
			titleBlinkInterval = null;
		}

		document.title = originalTitle;
	}

	function setAlertTitle(count) {
		if (!notificationsEnabled()) {
			document.title = originalTitle;
			return;
		}

		if (!alarmOpen) {
			if (count > 0) {
				document.title = '(' + count + ') Yeni Sipariş - ' + originalTitle;
			} else {
				document.title = originalTitle;
			}
		}
	}

	function showFullAlarm(message, type) {
	if (!notificationsEnabled()) return;
	if (alarmOpen) return;

	alarmOpen = true;

	if (type === 'bill_request') {
		$('#alarmTitle').text('HESAP İSTİYOR');
		$('#alarmTable').text(message);
		$('#alarmSubText').text('Garson lütfen hesabı hazırlayın');
	} else if (type === 'service_ready') {
		$('#alarmTitle').text('SERVİSE HAZIR');
		$('#alarmTable').text(message);
		$('#alarmSubText').text('Mutfaktan teslim alın');
	} else if (type === 'waiter_call') {
		$('#alarmTitle').text('GARSON ÇAĞRISI');
		$('#alarmTable').text(message);
		$('#alarmSubText').text('Müşteri garson çağırıyor');
	} else {
		$('#alarmTitle').text('YENİ SİPARİŞ');
		$('#alarmTable').text(message);
		$('#alarmSubText').text('Garson lütfen siparişi kontrol edin');
	}

	$('#orderAlarm').show();

	startTitleBlink(message);

	try {
		if (soundEnabled()) {
			notifyAudio.currentTime = 0;
			notifyAudio.play().catch(function() {});
		}
	} catch (e) {}

	vibratePhone([400, 200, 400, 200, 700]);

	alarmLoop = setInterval(function() {
		try {
			if (soundEnabled()) {
				notifyAudio.currentTime = 0;
				notifyAudio.play().catch(function() {});
			}
		} catch (e) {}

		vibratePhone([250, 120, 250, 120, 250]);
	}, 2500);
}

	function closeFullAlarm() {
		alarmOpen = false;

		if (alarmLoop) {
			clearInterval(alarmLoop);
			alarmLoop = null;
		}

		try {
			notifyAudio.pause();
			notifyAudio.currentTime = 0;
		} catch (e) {}

		stopTitleBlink();
		$('#orderAlarm').hide();
	}

	function getWaitingTableKeys(tables) {
		var keys = [];

		(tables || []).forEach(function(table) {
			var waitingCount = parseInt(table.active_order_count || 0, 10);

			if (table.service_status === 'waiting_order' && waitingCount > 0) {
				keys.push('table_' + table.table_id);
			}
		});

		return keys;
	}

	function checkNewWaitingOrders(tables) {
		var currentKeys = getWaitingTableKeys(tables);
		var newOrders = [];

		(tables || []).forEach(function(table) {
			var waitingCount = parseInt(table.active_order_count || 0, 10);
			var tableKey = 'table_' + table.table_id;

			if (table.service_status === 'waiting_order' && waitingCount > 0) {
				if (previousWaitingTables.indexOf(tableKey) === -1) {
					newOrders.push({
						table_id: table.table_id,
						table_no: table.table_no,
						count: waitingCount,
						note: table.note || ''
					});
				}
			}
		});

		if (firstRefreshCompleted && newOrders.length > 0 && notificationsEnabled()) {
			var firstOrder = newOrders[0];
			var toastMessage = 'Yeni Sipariş! Masa ' + firstOrder.table_no;

			if (firstOrder.count > 1) {
				toastMessage += ' (' + firstOrder.count + ' sipariş)';
			}

			showToast(toastMessage);
			vibratePhone();
			playNotifySound();
			showBrowserNotification('Yeni Sipariş', 'Masa ' + firstOrder.table_no + ' için yeni sipariş geldi');
			showFullAlarm('Masa ' + firstOrder.table_no + ' Yeni Sipariş', 'order');

			if (!$('#waiterModal').is(':visible') || autoOpenedTableKey !== ('table_' + firstOrder.table_id)) {
				autoOpenedTableKey = 'table_' + firstOrder.table_id;
				openModalByTableData(firstOrder);
			}
		}

		setAlertTitle(currentKeys.length);
		previousWaitingTables = currentKeys;
		firstRefreshCompleted = true;
	}
function checkNewBillRequests(tables) {
	var currentReadyKeys = [];
	var currentBillKeys = [];
	var currentWaiterKeys = [];

	(tables || []).forEach(function(table) {
		var readyCount = parseInt(table.ready_service_pending || 0, 10);
		var billCount = parseInt(table.bill_request_pending || 0, 10);
		var waiterCount = parseInt(table.waiter_call_pending || 0, 10);

		if (readyCount > 0) {
			currentReadyKeys.push('ready_' + table.table_id);
		}

		if (billCount > 0) {
			currentBillKeys.push('bill_' + table.table_id);
		}

		if (waiterCount > 0) {
			currentWaiterKeys.push('waiter_' + table.table_id + '_' + table.latest_waiter_call_id);
		}
	});

	if (!firstReadyRefresh) {
		previousReadyCalls = currentReadyKeys;
		firstReadyRefresh = true;
	} else {
		(tables || []).forEach(function(table) {
			var readyCount = parseInt(table.ready_service_pending || 0, 10);
			var readyKey = 'ready_' + table.table_id;

			if (readyCount > 0 && previousReadyCalls.indexOf(readyKey) === -1) {
				showToast('Masa ' + table.table_no + ' servise hazır');
				vibratePhone();
				playNotifySound();
				showBrowserNotification('Servise Hazır', 'Masa ' + table.table_no + ' mutfaktan hazır');
				showFullAlarm('Masa ' + table.table_no + ' Servise Hazır', 'service_ready');
			}
		});

		previousReadyCalls = currentReadyKeys;
	}

	if (!firstBillRefreshCompleted) {
		previousBillRequests = currentBillKeys;
		firstBillRefreshCompleted = true;
	} else {
		(tables || []).forEach(function(table) {
			var billCount = parseInt(table.bill_request_pending || 0, 10);
			var billKey = 'bill_' + table.table_id;

			if (billCount > 0 && previousBillRequests.indexOf(billKey) === -1) {
				showToast('Masa ' + table.table_no + ' hesap istiyor');
				vibratePhone();
				playNotifySound();
				showBrowserNotification('Hesap Talebi', 'Masa ' + table.table_no + ' hesap talebinde bulundu');
				showFullAlarm('Masa ' + table.table_no + ' Hesap İstiyor', 'bill_request');
			}
		});

		previousBillRequests = currentBillKeys;
	}

	if (!firstWaiterRefreshCompleted) {
		previousWaiterCalls = currentWaiterKeys;
		firstWaiterRefreshCompleted = true;
	} else {
		(tables || []).forEach(function(table) {
			var waiterCount = parseInt(table.waiter_call_pending || 0, 10);
			var waiterKey = 'waiter_' + table.table_id + '_' + table.latest_waiter_call_id;

			if (waiterCount > 0 && previousWaiterCalls.indexOf(waiterKey) === -1) {
				showToast('Masa ' + table.table_no + ' garson çağırıyor');
				vibratePhone();
				playNotifySound();
				showBrowserNotification('Garson Çağrısı', 'Masa ' + table.table_no + ' garson çağırıyor');
				showFullAlarm('Masa ' + table.table_no + ' Garson Çağırıyor', 'waiter_call');
			}
		});

		previousWaiterCalls = currentWaiterKeys;
	}
}
