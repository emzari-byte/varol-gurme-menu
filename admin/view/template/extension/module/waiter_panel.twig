function getOrdersByStatus(statuses) {
	return (currentTableOrders || []).filter(function(order) {
		return statuses.indexOf(order.service_status) !== -1;
	});
}

function isCardBillRequest() {
	var note = String($('#billPaymentNote').text() || '').toLowerCase();
	return note.indexOf('kart') !== -1 || note.indexOf('card') !== -1 || note.indexOf('pos') !== -1 || note.indexOf('kredi') !== -1;
}

function getMainAction() {
	var hasItems = Object.keys(manualOrderItems).length > 0;

	if (hasItems) {
		return {type:'manual_order', label:'Mutfağa Gönder', className:'btn-success'};
	}

	if (currentBillRequestPending && currentBillRequestStatus !== 'seen') {
		return {type:'ack_bill', label:'Hesapla İlgileniyorum', className:'btn-warning'};
	}

	if (cashierPanelEnabled && currentBillRequestPending && currentBillRequestStatus === 'seen' && isCardBillRequest() && getOrdersByStatus(['served']).length) {
		return {type:'pay_orders', label:'Kart Ödemesi Alındı', className:'btn-warning'};
	}

	if (!cashierPanelEnabled && currentBillRequestPending && currentBillRequestStatus === 'seen' && getOrdersByStatus(['served']).length) {
		return {type:'pay_orders', label:'Ödeme Alındı', className:'btn-warning'};
	}

	if (!cashierPanelEnabled && getOrdersByStatus(['served']).length) {
		return {type:'pay_orders', label:'Ödeme Alındı', className:'btn-warning'};
	}

	if (getOrdersByStatus(['ready_for_service', 'out_for_service']).length) {
		return {type:'serve_orders', label:'Servis Edildi', className:'btn-info'};
	}

	if (akinsoftEnabled && !kitchenPanelEnabled && getOrdersByStatus(['in_kitchen']).length) {
		return {type:'serve_orders', label:'Servis Edildi', className:'btn-info'};
	}

	if (getOrdersByStatus(['waiting_order']).length) {
		return {type:'approve_orders', label:(kitchenPanelEnabled || akinsoftEnabled) ? 'Mutfağa Gönder' : 'Servis Edildi', className:'btn-success'};
	}

	return null;
}
