		}

		var approveBtn = $(this);
		var nextStatus = (kitchenPanelEnabled || akinsoftEnabled) ? 'in_kitchen' : 'served';
		var index = 0;

		approveBtn.prop('disabled', true).text('Gönderiliyor...');

		function sendNextWaitingOrder() {
			if (index >= waitingOrders.length) {
				closeModal();
				autoOpenedTableKey = null;
				refreshPanel();
				approveBtn.prop('disabled', false).text('Mutfağa Gönder');
				return;
			}

			$.ajax({
				url: orderStatusUrl,
				type: 'POST',
				dataType: 'json',
				cache: false,
				data: {
					restaurant_order_id: waitingOrders[index].restaurant_order_id,
					service_status: nextStatus
				},
				success: function(json) {
					if (json.success) {
						index++;
						sendNextWaitingOrder();
					} else {
						alert(json.message || 'Sipariş mutfağa gönderilemedi.');
						approveBtn.prop('disabled', false).text('Mutfağa Gönder');
					}
				},
				error: function() {
					alert('Sipariş mutfağa gönderilemedi.');
					approveBtn.prop('disabled', false).text('Mutfağa Gönder');
				}
			});
		}

		sendNextWaitingOrder();
		return;
	}

	var tableId = $('#modal_table_id').val();
    if (!confirm('Bu ilave siparişi mutfağa göndermek istiyor musunuz?')) {
	return;
}
	var btn = $(this);
	btn.prop('disabled', true).text('Gönderiliyor...');

	$.ajax({
		url: manualOrderUrl,
		type: 'POST',
		dataType: 'json',
		data: {
			table_id: tableId,
			products: items
		},
		success: function(json) {
			if (json.success) {
				resetManualOrderBox();
				closeModal();
				autoOpenedTableKey = null;
				refreshPanel();
			} else {
				alert(json.message || 'Hata oluştu');
				btn.prop('disabled', false).text('Mutfağa Gönder');
			}

		},
		error: function(xhr) {
	alert('Sipariş gönderilemedi:\n' + (xhr.responseText ? xhr.responseText : 'Boş cevap'));
	btn.prop('disabled', false).text('Mutfağa Gönder');
}
	});
});

$('#sendManualOrderBtn').on('click', function(e) {
	e.preventDefault();
	e.stopImmediatePropagation();
	processMainAction($(this));
	return false;
});

function updateOrdersSequential(orders, nextStatus, confirmText, doneText, button) {
	if (!orders.length) {
		alert('Bu işlem için uygun sipariş bulunmuyor.');
		return;
	}

	if (confirmText && !confirm(confirmText)) {
		return;
	}

	var index = 0;
	var tableId = $('#modal_table_id').val();

	button.prop('disabled', true).text('İşleniyor...');

	function next() {
		if (index >= orders.length) {
			closeModal();
			autoOpenedTableKey = null;
			refreshPanel();
			button.prop('disabled', false).text(doneText || 'Tamam');
			return;
		}

		$.ajax({
			url: orderStatusUrl,
			type: 'POST',
			dataType: 'json',
			cache: false,
			data: {
				restaurant_order_id: orders[index].restaurant_order_id,
				service_status: nextStatus
			},
			success: function(json) {
				if (json.success) {
					index++;
					next();
				} else {
					alert(json.message || 'İşlem tamamlanamadı.');
					button.prop('disabled', false);
					toggleManualOrderButton();
				}
			},
			error: function() {
				alert('İşlem sırasında hata oluştu.');
				button.prop('disabled', false);
				toggleManualOrderButton();
			}
		});
	}

	next();
}

function processManualOrder(button) {
	var items = [];

	Object.keys(manualOrderItems).forEach(function(id) {
		items.push({
			product_id: manualOrderItems[id].product_id,
			quantity: manualOrderItems[id].quantity
		});
	});

	if (!items.length) {
		return false;
	}

	if (!confirm('Bu ilave siparişi mutfağa göndermek istiyor musunuz?')) {
		return true;
	}

	button.prop('disabled', true).text('Gönderiliyor...');

	$.ajax({
		url: manualOrderUrl,
		type: 'POST',
		dataType: 'json',
		data: {
			table_id: $('#modal_table_id').val(),
			products: items
		},
		success: function(json) {
			if (json.success) {
				resetManualOrderBox();
				closeModal();
				autoOpenedTableKey = null;
				refreshPanel();
			} else {
				alert(json.message || 'Hata oluştu');
				button.prop('disabled', false);
				toggleManualOrderButton();
			}
		},
		error: function(xhr) {
			alert('Sipariş gönderilemedi:\n' + (xhr.responseText ? xhr.responseText : 'Boş cevap'));
			button.prop('disabled', false);
			toggleManualOrderButton();
		}
	});

	return true;
}

function processMainAction(button) {
	var action = getMainAction();

	if (!action || button.prop('disabled')) {
		return;
	}

	if (action.type === 'manual_order') {
		processManualOrder(button);
		return;
	}

	if (action.type === 'ack_bill') {
		if (!confirm('Hesap talebiyle ilgilendiğinizi müşteriye bildirelim mi?')) {
			return;
		}

		button.prop('disabled', true).text('Bildirim gönderiliyor...');

		$.ajax({
			url: billRequestAckUrl,
			type: 'POST',
			dataType: 'json',
			cache: false,
			data: { table_id: $('#modal_table_id').val() },
			success: function(json) {
				if (json.success) {
					updateBillRequestPanel(1, 'seen');
					refreshPanel();
					showToast(json.message || 'Hesap talebi görüldü.');
				} else {
					alert(json.message || 'Hesap talebi güncellenemedi.');
				}
				button.prop('disabled', false);
				toggleManualOrderButton();
			},
			error: function() {
				alert('Hesap talebi güncellenemedi.');
				button.prop('disabled', false);
				toggleManualOrderButton();
			}
		});

		return;
	}

	if (action.type === 'approve_orders') {
		updateOrdersSequential(
			getOrdersByStatus(['waiting_order']),
			(kitchenPanelEnabled || akinsoftEnabled) ? 'in_kitchen' : 'served',
			(kitchenPanelEnabled || akinsoftEnabled) ? 'Bekleyen siparişleri mutfağa göndermek istiyor musunuz?' : 'Bekleyen siparişleri servis edildi olarak işaretleyelim mi?',
			action.label,
			button
		);
		return;
	}

	if (action.type === 'serve_orders') {
		var serveStatuses = ['ready_for_service', 'out_for_service'];

		if (akinsoftEnabled && !kitchenPanelEnabled) {
			serveStatuses.push('in_kitchen');
		}

		updateOrdersSequential(
			getOrdersByStatus(serveStatuses),
			'served',
			'Sipariş servis edildi olarak işaretlensin mi?',
			action.label,
			button
		);
		return;
	}

	if (action.type === 'pay_orders') {
		updateOrdersSequential(
			getOrdersByStatus(['served']),
			'paid',
			'Bu masadaki servis edilmiş siparişler ödeme alındı olarak kapatılsın mı?',
			action.label,
			button
		);
	}
}

bindCards();
updateAdminAlertControls();
refreshPanel();
setInterval(refreshPanel, 10000);
})(jQuery);
</script>

