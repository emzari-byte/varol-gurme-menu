{{ header }}{{ column_left }}
<div id="content">
	<div class="page-header">
		<div class="container-fluid">
			<div class="pull-right">
				<a href="{{ add }}" data-toggle="tooltip" title="Yeni Masa Ekle" class="btn btn-primary">
					<i class="fa fa-plus"></i>
				</a>

				<button type="submit"
						form="form-table"
						data-toggle="tooltip"
						title="Sil"
						class="btn btn-danger"
						onclick="return confirm('Seçilen masaları silmek istiyor musunuz?');">
					<i class="fa fa-trash-o"></i>
				</button>
			</div>

			<h1>{{ heading_title }}</h1>

			<ul class="breadcrumb">
				{% for breadcrumb in breadcrumbs %}
					<li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
				{% endfor %}
			</ul>
		</div>
	</div>


	<div class="container-fluid">

		{% if error_warning %}
		<div class="alert alert-danger">
			<i class="fa fa-exclamation-circle"></i>
			{{ error_warning }}
		</div>
		{% endif %}

		{% if success %}
		<div class="alert alert-success">
			<i class="fa fa-check-circle"></i>
			{{ success }}
		</div>
		{% endif %}

		{% if unassigned_table_count %}
		<div class="alert alert-danger">
			<i class="fa fa-exclamation-triangle"></i>
			<strong>{{ unassigned_table_count }} aktif masa garsona atanmamış.</strong>
			Bu masalardan gelen garson çağrıları hiçbir garsona düşmeyebilir.
		</div>
		{% endif %}


		<div class="panel panel-default">

			<div class="panel-heading">
				<h3 class="panel-title">
					<i class="fa fa-table"></i> Masa Listesi
				</h3>
			</div>

			<div class="panel-body">
				<style>
					.restaurant-table-list > tbody > tr > td { vertical-align: middle; }
					.restaurant-table-list tr.table-unassigned > td {
						background:#fff5f5 !important;
						border-color:#f0c4bf !important;
					}
					.table-assignment-ok {
						display:inline-flex;
						align-items:center;
						gap:6px;
						color:#2f5f49;
						background:#f4faf6;
						border:1px solid #cfe0d5;
						border-radius:999px;
						padding:5px 10px;
						font-weight:700;
					}
					.table-assignment-danger {
						display:inline-flex;
						align-items:center;
						gap:6px;
						color:#a94442;
						background:#fff1f0;
						border:1px solid #efb7b0;
						border-radius:999px;
						padding:5px 10px;
						font-weight:800;
					}
                    .qr-order-toggle {
                        display:inline-flex;
                        align-items:center;
                        gap:8px;
                        border:0;
                        border-radius:999px;
                        padding:6px 12px;
                        font-weight:800;
                    }
                    .qr-order-toggle.is-on { color:#1f6f43; background:#eaf7ee; }
                    .qr-order-toggle.is-off { color:#8a5a00; background:#fff5db; }
				</style>

				<form action="{{ delete }}"
					  method="post"
					  enctype="multipart/form-data"
					  id="form-table">

					<div class="table-responsive">

						<table class="table table-bordered table-hover restaurant-table-list">

							<thead>
								<tr>
									<td style="width:1px;" class="text-center">
										<input type="checkbox"
										 onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" />
									</td>

									<td class="text-left">Masa No</td>
									<td class="text-left">Masa Adı</td>
									<td class="text-left">Kapasite</td>
									<td class="text-left">Bölüm</td>
									<td class="text-left">Atanan Garson</td>
                                    <td class="text-left">QR Sipariş</td>
									<td class="text-left">Sıralama</td>
									<td class="text-left">Durum</td>
									<td class="text-right">İşlem</td>
								</tr>
							</thead>


							<tbody>

							{% if tables %}

								{% for table in tables %}
								<tr class="{% if table.status and not table.waiter_count %}table-unassigned{% endif %}">

									<td class="text-center">
										{% if table.table_id in selected %}
											<input type="checkbox"
											 name="selected[]"
											 value="{{ table.table_id }}"
											 checked="checked"/>
										{% else %}
											<input type="checkbox"
											 name="selected[]"
											 value="{{ table.table_id }}"/>
										{% endif %}
									</td>


									<td class="text-left">
										{{ table.table_no }}
									</td>

									<td class="text-left">
										{{ table.name }}
									</td>

									<td class="text-left">
										{{ table.capacity }}
									</td>

									<td class="text-left">
										{{ table.area }}
									</td>

									<td class="text-left">
										{% if table.waiter_count %}
											<span class="table-assignment-ok"><i class="fa fa-user"></i> {{ table.waiter_names }}</span>
										{% else %}
											<span class="table-assignment-danger"><i class="fa fa-exclamation-triangle"></i> Atanmamış</span>
										{% endif %}
									</td>

                                    <td class="text-left">
                                        <button type="button"
                                                class="qr-order-toggle {% if table.qr_order_enabled %}is-on{% else %}is-off{% endif %}"
                                                data-table-id="{{ table.table_id }}"
                                                data-enabled="{{ table.qr_order_enabled }}">
                                            <i class="fa {% if table.qr_order_enabled %}fa-toggle-on{% else %}fa-toggle-off{% endif %}"></i>
                                            <span>{% if table.qr_order_enabled %}Sipariş Açık{% else %}Sadece Menü{% endif %}</span>
                                        </button>
                                    </td>

									<td class="text-left">
										{{ table.sort_order }}
									</td>

									<td class="text-left">
										{% if table.status %}
											Aktif
										{% else %}
											Pasif
										{% endif %}
									</td>


									<td class="text-right">

										<a href="{{ table.edit }}"
										   data-toggle="tooltip"
										   title="Düzenle"
										   class="btn btn-primary">
											<i class="fa fa-pencil"></i>
										</a>

										<a href="{{ table.qr_view }}"
										   data-toggle="tooltip"
										   title="QR Gör"
										   target="_blank"
										   class="btn btn-info">
											<i class="fa fa-qrcode"></i>
										</a>

									</td>

								</tr>
								{% endfor %}

							{% else %}

								<tr>
									<td class="text-center" colspan="10">
										Kayıt bulunamadı.
									</td>
								</tr>

							{% endif %}

							</tbody>

						</table>

					</div>

				</form>

                <script>
                $('.qr-order-toggle').on('click', function() {
                    var button = $(this);
                    var next = button.data('enabled') ? 0 : 1;
                    button.prop('disabled', true);

                    $.post('{{ toggle_qr_order_url|replace({"&amp;":"&"}) }}', {
                        table_id: button.data('table-id'),
                        enabled: next
                    }, function(json) {
                        button.prop('disabled', false);

                        if (!json || !json.success) {
                            alert(json && json.message ? json.message : 'QR sipariş durumu değiştirilemedi.');
                            return;
                        }

                        button.data('enabled', json.enabled ? 1 : 0)
                            .toggleClass('is-on', !!json.enabled)
                            .toggleClass('is-off', !json.enabled);
                        button.find('i')
                            .toggleClass('fa-toggle-on', !!json.enabled)
                            .toggleClass('fa-toggle-off', !json.enabled);
                        button.find('span').text(json.enabled ? 'Sipariş Açık' : 'Sadece Menü');
                    }, 'json').fail(function() {
                        button.prop('disabled', false);
                        alert('QR sipariş durumu değiştirilemedi.');
                    });
                });
                </script>

			</div>
		</div>
	</div>
</div>

{{ footer }}
