<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<title>QR - Masa {{ table_no }}</title>
	<style>
		body {
			font-family: Arial, sans-serif;
			background: #f5f5f5;
			margin: 0;
			padding: 30px;
			text-align: center;
		}
		.qr-wrap {
			max-width: 560px;
			margin: 0 auto;
			background: #fff;
			border-radius: 12px;
			padding: 30px;
			box-shadow: 0 4px 20px rgba(0,0,0,0.08);
		}
		.qr-wrap h1 {
			margin: 0 0 10px;
			font-size: 36px;
		}
		.qr-wrap p {
			margin: 8px 0;
			font-size: 16px;
			color: #555;
		}
		.qr-img {
			margin: 25px 0;
		}
		.qr-link {
			word-break: break-all;
			font-size: 13px;
			color: #777;
			margin-top: 15px;
		}
		.print-btn {
			display: inline-block;
			margin-top: 25px;
			padding: 12px 24px;
			font-size: 16px;
			border: 0;
			border-radius: 8px;
			background: #2e86de;
			color: #fff;
			cursor: pointer;
		}
		@media print {
			.print-btn {
				display: none;
			}
			body {
				background: #fff;
				padding: 0;
			}
			.qr-wrap {
				box-shadow: none;
				border: 1px solid #ddd;
			}
		}
	</style>
</head>
<body>
	<div class="qr-wrap">
		<h1>Masa {{ table_no }}</h1>
		<p>{{ table_name }}</p>
		<p>{{ table_area }}</p>

		<div class="qr-img">
			<img src="{{ qr_image }}" alt="QR - Masa {{ table_no }}">
		</div>

		<p><strong>Varol Veranda</strong></p>
		<div class="qr-link">{{ qr_link }}</div>

		<button class="print-btn" onclick="window.print();">Yazdır</button>
	</div>
</body>
</html>