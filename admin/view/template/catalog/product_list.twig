  <script type="text/javascript"><!--
// IE and Edge fix!
$('button[form=\'form-product\']').on('click', function(e) {
	$('#form-product').attr('action', $(this).attr('formaction'));
});

function quickUpdateProduct(productId, field, value, done, productDescription, productCategory) {
	var data = {
		product_id: productId,
		field: field,
		value: value
	};

	if (productDescription) {
		data.product_description = productDescription;
	}

	if (productCategory) {
		data.product_category = productCategory;
	}

	$.ajax({
		url: 'index.php?route=catalog/product/quickUpdate&user_token={{ user_token }}',
		type: 'post',
		dataType: 'json',
		data: data,
		success: function(json) {
			if (json.error) {
				alert(json.error);
			}

			if (done) {
				done(json);
			}
		},
		error: function(xhr, ajaxOptions, thrownError) {
			alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
		}
	});
}

$(document).on('dblclick', '.quick-edit-value', function() {
	var $span = $(this);

	if ($span.data('editing')) {
		return;
	}

	var productId = $span.data('product-id');
	var field = $span.data('field');

	if (field == 'name') {
		openQuickName(productId);
		return;
	}

	var originalDisplay = $.trim($span.text());
	var originalValue = field == 'price' ? $span.data('raw') : originalDisplay;
	var $input = $('<input type="text" class="form-control input-sm quick-edit-input" />').val(originalValue);

	$span.data('editing', true).hide().after($input);
	$input.focus().select();

	function finish(save) {
		var value = $input.val();

		if (!save || value == originalValue) {
			$input.remove();
			$span.show().data('editing', false);
			return;
		}

		$input.prop('disabled', true);

		quickUpdateProduct(productId, field, value, function(json) {
			if (json.success) {
				if (field == 'price') {
					$span.text(json.value).data('raw', value);
				} else {
					$span.text(json.value);
				}
			}

			$input.remove();
			$span.show().data('editing', false);
		});
	}

	$input.on('keydown', function(e) {
		if (e.keyCode == 13) {
			e.preventDefault();
			finish(true);
		}

		if (e.keyCode == 27) {
			e.preventDefault();
			finish(false);
		}
	});

	$input.on('blur', function() {
		finish(false);
	});
});

$(document).on('click', '.quick-category-value', function() {
	var productId = $(this).data('product-id');

	$('#quick-category-state').text('Yükleniyor...');
	$('#quick-category-product-id').val(productId);
	$('#quick-category-filter').val('');
	$('#quick-category-fields').html('');
	$('#modal-product-category').modal('show');

	$.ajax({
		url: 'index.php?route=catalog/product/quickCategory&user_token={{ user_token }}&product_id=' + productId,
		dataType: 'json',
		success: function(json) {
			if (json.error) {
				$('#quick-category-state').text(json.error);
				return;
			}

			var html = '';
			var selected = {};

			$.each(json.selected, function(index, categoryId) {
				selected[categoryId] = true;
			});

			$.each(json.categories, function(index, category) {
				html += '<label class="quick-category-option" style="display:block;font-weight:400;margin-bottom:8px;">';
				html += '<input type="checkbox" class="quick-category-checkbox" value="' + category.category_id + '"' + (selected[category.category_id] ? ' checked="checked"' : '') + ' /> ';
				html += $('<div/>').text(category.name).html();
				html += '</label>';
			});

			$('#quick-category-fields').html(html);
			$('#quick-category-state').text('');
		}
	});
});

$('#quick-category-filter').on('keyup', function() {
	var filter = $(this).val().toLowerCase();

	$('.quick-category-option').each(function() {
		$(this).toggle($(this).text().toLowerCase().indexOf(filter) !== -1);
	});
});

$('#button-save-category').on('click', function() {
	var $button = $(this);
	var productId = $('#quick-category-product-id').val();
	var categories = [];

	$('.quick-category-checkbox:checked').each(function() {
		categories.push($(this).val());
	});

	$button.prop('disabled', true);
	$('#quick-category-state').text('Kaydediliyor...');

	quickUpdateProduct(productId, 'category', '', function(json) {
		if (json.success) {
			$('.quick-category-value[data-product-id="' + productId + '"]').text(json.value);
			$('#quick-category-state').text('Kaydedildi.');
			setTimeout(function() {
				$('#modal-product-category').modal('hide');
				$('#quick-category-state').text('');
			}, 450);
		}

		$button.prop('disabled', false);
	}, null, categories);
});

$(document).on('click', '.quick-allergen-trigger', function() {
	var productId = $(this).data('product-id');
	var productName = $(this).data('product-name');

	$('#quick-allergen-state').text('Yukleniyor...');
	$('#quick-allergen-product-id').val(productId);
	$('#quick-allergen-product-name').text(productName);
	$('#quick-allergen-fields').html('');
	$('#modal-product-allergen').modal('show');

	$.ajax({
		url: 'index.php?route=catalog/product/quickAllergen&user_token={{ user_token }}&product_id=' + productId,
		dataType: 'json',
		success: function(json) {
			if (json.error) {
				$('#quick-allergen-state').text(json.error);
				return;
			}

			var selected = {};
			var html = '';

			$.each(json.selected, function(index, allergenId) {
				selected[allergenId] = true;
			});

			if (!json.allergens.length) {
				html = '<div class="alert alert-warning">Alerjen tanimi bulunamadi. Restoran Ayarlari > Alerjen Tanimlari ekranini acarak eski secimleri tasiyabilir veya yeni alerjen ekleyebilirsiniz.</div>';
			}

			$.each(json.allergens, function(index, allergen) {
				html += '<label class="quick-allergen-option">';
				html += '<input type="checkbox" class="quick-allergen-checkbox" value="' + allergen.allergen_id + '"' + (selected[allergen.allergen_id] ? ' checked="checked"' : '') + ' />';
				html += '<img src="' + allergen.thumb + '" alt="">';
				html += '<span>' + $('<div/>').text(allergen.name).html() + '</span>';
				html += '</label>';
			});

			$('#quick-allergen-fields').html(html);
			$('#quick-allergen-state').text('');
		}
	});
});

$('#button-save-allergen').on('click', function() {
	var $button = $(this);
	var productId = $('#quick-allergen-product-id').val();
	var allergens = [];

	$('.quick-allergen-checkbox:checked').each(function() {
		allergens.push($(this).val());
	});

	$button.prop('disabled', true);
	$('#quick-allergen-state').text('Kaydediliyor...');

	$.ajax({
		url: 'index.php?route=catalog/product/quickAllergen&user_token={{ user_token }}',
		type: 'post',
		dataType: 'json',
		data: {
			product_id: productId,
			allergen: allergens
		},
		success: function(json) {
			if (json.error) {
				$('#quick-allergen-state').text(json.error);
			} else if (json.success) {
				$('#product-allergens-' + productId).html(json.html + '<button type="button" class="btn btn-default btn-xs quick-allergen-trigger" data-product-id="' + productId + '" data-product-name="' + $('<div/>').text($('#quick-allergen-product-name').text()).html() + '" title="Alerjen sec"><i class="fa fa-plus"></i></button>');
				$('#quick-allergen-state').text('Kaydedildi.');
				setTimeout(function() {
					$('#modal-product-allergen').modal('hide');
					$('#quick-allergen-state').text('');
				}, 450);
			}

			$button.prop('disabled', false);
		},
		error: function(xhr, ajaxOptions, thrownError) {
			alert(thrownError + "\r\n" + xhr.statusText + "\r\n" + xhr.responseText);
			$button.prop('disabled', false);
		}
	});
});

function loadProductDescriptions(productId, done) {
	$.ajax({
		url: 'index.php?route=catalog/product/quickDescription&user_token={{ user_token }}&product_id=' + productId,
		dataType: 'json',
		success: function(json) {
			if (json.error) {
				alert(json.error);
			} else if (done) {
				done(json);
			}
		}
	});
}

function languageIcon(language) {
	return '<img src="language/' + language.code + '/' + language.code + '.png" title="' + language.name + '" /> ';
}

function decodeHtml(value) {
	var textarea = document.createElement('textarea');
	textarea.innerHTML = value || '';

	return textarea.value;
}

function openQuickName(productId) {
	$('#quick-name-state').text('Yükleniyor...');
	$('#quick-name-product-id').val(productId);
	$('#quick-name-fields').html('');
	$('#modal-product-name').modal('show');

	loadProductDescriptions(productId, function(json) {
		var html = '';

		$.each(json.languages, function(index, language) {
			var description = json.descriptions[language.language_id] || {};

			html += '<div class="input-group" style="margin-bottom:14px;">';
			html += '<span class="input-group-addon">' + languageIcon(language) + '</span>';
			html += '<input type="text" class="form-control quick-name-input" data-language-id="' + language.language_id + '" value="' + $('<div/>').text(decodeHtml(description.name || '')).html() + '" />';
			html += '</div>';
		});

		$('#quick-name-fields').html(html);
		$('#quick-name-state').text('');
		$('#quick-name-fields .quick-name-input:first').focus();
	});
}

$(document).on('click', '.quick-status', function() {
	var $button = $(this);
	var status = $button.data('status') ? 0 : 1;

	$button.prop('disabled', true);

	quickUpdateProduct($button.data('product-id'), 'status', status, function(json) {
		if (json.success) {
			$button.data('status', json.status).text(json.value);
			$button.toggleClass('btn-success', json.status == 1).toggleClass('btn-default', json.status != 1);
		}

		$button.prop('disabled', false);
	});
});

$(document).on('click', '.quick-image', function() {
	$('.quick-image').removeClass('quick-image-active');
	$(this).addClass('quick-image-active');
});

$(document).on('hidden.bs.modal', '#modal-image', function() {
	var $active = $('.quick-image-active');

	if (!$active.length) {
		return;
	}

	var productId = $active.data('product-id');
	var $input = $('#input-product-image-' + productId);
	var value = $input.val();

	$active.removeClass('quick-image-active');

	if (value == $input.data('original')) {
		return;
	}

	quickUpdateProduct(productId, 'image', value, function(json) {
		if (json.success) {
			$input.data('original', value);

			if (json.thumb) {
				$('#thumb-product-' + productId).find('img').attr('src', json.thumb);
			}
		}
	});
});

$(document).on('click', '.quick-description', function() {
	var productId = $(this).data('product-id');

	$('#quick-description-state').text('Yükleniyor...');
	$('#quick-description-product-id').val(productId);
	$('.quick-description-editor').each(function() {
		if ($(this).next('.note-editor').length) {
			$(this).summernote('destroy');
		}
	});
	$('#quick-description-tabs').html('');
	$('#quick-description-content').html('');
	$('#modal-product-description').modal('show');

	loadProductDescriptions(productId, function(json) {
		var tabs = '';
		var content = '';

		$.each(json.languages, function(index, language) {
			var active = index == 0 ? 'active' : '';
			var description = json.descriptions[language.language_id] || {};

			tabs += '<li class="' + active + '"><a href="#quick-description-language-' + language.language_id + '" data-toggle="tab">' + languageIcon(language) + language.name + '</a></li>';
			content += '<div class="tab-pane ' + active + '" id="quick-description-language-' + language.language_id + '">';
			content += '<div class="form-group"><label>Açıklama</label><textarea id="quick-description-editor-' + language.language_id + '" class="form-control quick-description-input quick-description-editor" data-language-id="' + language.language_id + '" data-field="description" rows="10"></textarea></div>';
			content += '<div class="form-group"><label>Meta Başlığı</label><input type="text" class="form-control quick-description-input" data-language-id="' + language.language_id + '" data-field="meta_title" value="' + $('<div/>').text(decodeHtml(description.meta_title || description.name || '')).html() + '" /></div>';
			content += '<div class="form-group"><label>Meta Açıklaması</label><textarea id="quick-meta-description-' + language.language_id + '" class="form-control quick-description-input" data-language-id="' + language.language_id + '" data-field="meta_description" rows="3"></textarea></div>';
			content += '<div class="form-group"><label>Meta Kelimeleri</label><textarea id="quick-meta-keyword-' + language.language_id + '" class="form-control quick-description-input" data-language-id="' + language.language_id + '" data-field="meta_keyword" rows="3"></textarea></div>';
			content += '</div>';
		});

		$('#quick-description-tabs').html(tabs);
		$('#quick-description-content').html(content);

		$.each(json.languages, function(index, language) {
			var description = json.descriptions[language.language_id] || {};

			$('#quick-description-editor-' + language.language_id).val(decodeHtml(description.description || ''));
			$('#quick-meta-description-' + language.language_id).val(decodeHtml(description.meta_description || ''));
			$('#quick-meta-keyword-' + language.language_id).val(decodeHtml(description.meta_keyword || ''));
		});

		$('.quick-description-editor').summernote({
			height: 300,
			disableDragAndDrop: true,
			toolbar: [
				['style', ['style']],
				['font', ['bold', 'underline', 'clear']],
				['fontsize', ['fontsize']],
				['color', ['color']],
				['para', ['ul', 'ol', 'paragraph']],
				['table', ['table']],
				['insert', ['link', 'picture', 'video']],
				['view', ['fullscreen', 'codeview', 'help']]
			]
		});

		$('.quick-description-editor').each(function() {
			$(this).summernote('code', $(this).val());
		});
		$('#quick-description-state').text('');
	});
});

$('#button-save-name').on('click', function() {
	var $button = $(this);
	var productId = $('#quick-name-product-id').val();
	var productDescription = {};

	$('.quick-name-input').each(function() {
		var languageId = $(this).data('language-id');
		productDescription[languageId] = {
			name: $(this).val()
		};
	});

	$button.prop('disabled', true);
	$('#quick-name-state').text('Kaydediliyor...');

	quickUpdateProduct(productId, 'name', '', function(json) {
		if (json.success) {
			$('.quick-edit-value[data-product-id="' + productId + '"][data-field="name"]').text(json.value);
			$('#quick-name-state').text('Kaydedildi.');
			setTimeout(function() {
				$('#modal-product-name').modal('hide');
				$('#quick-name-state').text('');
			}, 450);
		}

		$button.prop('disabled', false);
	}, productDescription);
});

$('#button-save-description').on('click', function() {
	var $button = $(this);
	var productId = $('#quick-description-product-id').val();
	var productDescription = {};

	$('.quick-description-input').each(function() {
		var languageId = $(this).data('language-id');
		var field = $(this).data('field');

		if (!productDescription[languageId]) {
			productDescription[languageId] = {};
		}

		productDescription[languageId][field] = field == 'description' && $(this).next('.note-editor').length ? $(this).summernote('code') : $(this).val();
	});

	$button.prop('disabled', true);
	$('#quick-description-state').text('Kaydediliyor...');

	quickUpdateProduct(productId, 'description', '', function(json) {
		if (json.success) {
			$('#quick-description-state').text('Kaydedildi.');
			setTimeout(function() {
				$('#modal-product-description').modal('hide');
				$('#quick-description-state').text('');
			}, 450);
		}

		$button.prop('disabled', false);
	}, productDescription);
});
  
$('input[name=\'filter_name\']').autocomplete({
	'source': function(request, response) {
		$.ajax({
			url: 'index.php?route=catalog/product/autocomplete&user_token={{ user_token }}&filter_name=' +  encodeURIComponent(request),
			dataType: 'json',
			success: function(json) {
				response($.map(json, function(item) {
					return {
						label: item['name'],
						value: item['product_id']
					}
				}));
			}
		});
	},
	'select': function(item) {
		$('input[name=\'filter_name\']').val(item['label']);
	}
});

