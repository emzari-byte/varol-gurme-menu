  <script type="text/javascript"><!--
var quickProductCategories = [
{% for category in filter_categories %}
	{category_id: {{ category.category_id }}, name: '{{ category.name|escape('js') }}'}{% if not loop.last %},{% endif %}
{% endfor %}
];
var quickProductSelectedCategories = {};

function renderQuickProductSelectedCategories() {
	var html = '';
	var hasSelected = false;

	$.each(quickProductSelectedCategories, function(categoryId, categoryName) {
		hasSelected = true;
		html += '<span class="quick-product-category-chip" data-category-id="' + categoryId + '">';
		html += $('<div/>').text(categoryName).html();
		html += '<input type="hidden" name="product_category[]" value="' + categoryId + '" />';
		html += '<button type="button" class="quick-product-category-remove" data-category-id="' + categoryId + '">&times;</button>';
		html += '</span>';
	});

	if (!hasSelected) {
		html = '<span class="quick-product-category-empty">Henüz kategori seçilmedi.</span>';
	}

	$('#quick-product-category-selected').html(html);
}

function renderQuickProductCategoryResults(query) {
	query = $.trim(query || '').toLowerCase();

	var html = '';
	var count = 0;

	if (query.length < 2) {
		$('#quick-product-category-results').hide().html('');
		return;
	}

	$.each(quickProductCategories, function(index, category) {
		if (count >= 12 || quickProductSelectedCategories[category.category_id]) {
			return;
		}

		if (category.name.toLowerCase().indexOf(query) !== -1) {
			html += '<button type="button" class="quick-product-category-result" data-category-id="' + category.category_id + '">' + $('<div/>').text(category.name).html() + '</button>';
			count++;
		}
	});

	if (!html) {
		html = '<button type="button" disabled="disabled">Sonuç bulunamadı</button>';
	}

	$('#quick-product-category-results').html(html).show();
}

function resetQuickProductForm(mode) {
	$('#form-quick-product')[0].reset();
	$('#quick-product-id').val('');
	$('#input-quick-product-image').val('');
	$('#thumb-quick-product-image img').attr('src', '{{ placeholder }}');
	quickProductSelectedCategories = {};
	renderQuickProductSelectedCategories();
	$('#quick-product-category-search').val('');
	$('#quick-product-category-results').hide().html('');
	$('#quick-product-state').text('');

	if (mode == 'edit') {
		$('#quick-product-side-title').text('Ürünü Düzenle');
		$('#quick-product-side-text').text('Menüdeki ürün bilgilerini hızlıca güncelleyin. Değişiklikler kaydedildiğinde liste yenilenir.');
		$('#quick-product-main-title').text('Ürün Kartı');
		$('#quick-product-main-text').text('Ürün adı, fiyat, kategori ve hazırlık süresini aynı ekranda düzenleyin.');
		$('#quick-product-submit').html('<i class="fa fa-save"></i> Değişiklikleri Kaydet');
	} else {
		$('#quick-product-side-title').text('Hızlı Ürün Ekle');
		$('#quick-product-side-text').text('Menüye yeni ürünü birkaç temel bilgiyle ekleyin. Detay, alerjen ve galeri düzenlemeleri sonradan yapılabilir.');
		$('#quick-product-main-title').text('Yeni Menü Ürünü');
		$('#quick-product-main-text').text('Ürün adı, fiyat, kategori ve hazırlık süresi menüde hemen kullanılacak alanlardır.');
		$('#quick-product-submit').html('<i class="fa fa-check"></i> Ürünü Ekle');
	}
}

function fillQuickProductForm(product) {
	$('#quick-product-id').val(product.product_id);
	$('input[name="model"]').val(product.model);
	$('input[name="price"]').val(product.price);
	$('select[name="status"]').val(product.status);
	$('input[name="sort_order"]').val(product.sort_order);
	$('input[name="prep_time"]').val(product.prep_time || '');
	$('#input-quick-product-image').val(product.image);
	$('#thumb-quick-product-image img').attr('src', product.thumb || '{{ placeholder }}');

	$.each(product.descriptions || {}, function(languageId, description) {
		$('input[name="name[' + languageId + ']"]').val(description.name || '');
		$('textarea[name="description[' + languageId + ']"]').val(description.description || '');
	});

	$.each(product.categories || [], function(index, categoryId) {
		$.each(quickProductCategories, function(categoryIndex, category) {
			if (parseInt(category.category_id, 10) == parseInt(categoryId, 10)) {
				quickProductSelectedCategories[category.category_id] = category.name;
			}
		});
	});

	renderQuickProductSelectedCategories();
}

$('#button-open-quick-product').on('click', function(e) {
	e.preventDefault();
	resetQuickProductForm('add');
	$('#modal-quick-product').modal('show');
});

$('#quick-product-category-search').on('input focus', function() {
	renderQuickProductCategoryResults($(this).val());
});

$(document).on('click', '.quick-product-category-result', function() {
	var categoryId = $(this).data('category-id');

	$.each(quickProductCategories, function(index, category) {
		if (parseInt(category.category_id, 10) == parseInt(categoryId, 10)) {
			quickProductSelectedCategories[category.category_id] = category.name;
		}
	});

	$('#quick-product-category-search').val('');
	$('#quick-product-category-results').hide().html('');
	renderQuickProductSelectedCategories();
});

$(document).on('click', '.quick-product-category-remove', function() {
	delete quickProductSelectedCategories[$(this).data('category-id')];
	renderQuickProductSelectedCategories();
});

$(document).on('click', function(e) {
	if (!$(e.target).closest('.quick-product-category-search').length) {
		$('#quick-product-category-results').hide();
	}
});

$(document).on('click', '.quick-product-edit', function(e) {
	e.preventDefault();

	var productId = $(this).data('product-id');

	resetQuickProductForm('edit');
	$('#quick-product-state').text('Ürün bilgileri yükleniyor...');
	$('#modal-quick-product').modal('show');

	$.ajax({
		url: 'index.php?route=catalog/product/quickForm&user_token={{ user_token }}&product_id=' + productId,
		dataType: 'json',
		success: function(json) {
			if (json.error) {
				$('#quick-product-state').text(json.error);
				return;
			}

			fillQuickProductForm(json.product);
			$('#quick-product-state').text('');
		},
		error: function(xhr, ajaxOptions, thrownError) {
			$('#quick-product-state').text(thrownError + ' - ' + xhr.statusText);
		}
	});
});

$('#form-quick-product').on('submit', function(e) {
	e.preventDefault();

	var $form = $(this);
	var $button = $form.find('button[type="submit"]');

	$('#quick-product-state').text('Kaydediliyor...');
	$button.prop('disabled', true);

	$.ajax({
		url: 'index.php?route=catalog/product/quickAdd&user_token={{ user_token }}',
		type: 'post',
		dataType: 'json',
		data: $form.serialize(),
		success: function(json) {
			if (json.error) {
				$('#quick-product-state').text(json.error);
				return;
			}

			$('#quick-product-state').text((json.message || 'Ürün kaydedildi') + ' Liste yenileniyor...');
			location.reload();
		},
		error: function(xhr, ajaxOptions, thrownError) {
			$('#quick-product-state').text(thrownError + ' - ' + xhr.statusText);
		},
		complete: function() {
			$button.prop('disabled', false);
		}
	});
});

$('#button-filter').on('click', function() {
	var url = '';

	var filter_name = $('input[name=\'filter_name\']').val();

	if (filter_name) {
		url += '&filter_name=' + encodeURIComponent(filter_name);
	}

	var filter_model = $('input[name=\'filter_model\']').val();

	if (filter_model) {
		url += '&filter_model=' + encodeURIComponent(filter_model);
	}

	var filter_category_id = $('select[name=\'filter_category_id\']').val();

	if (filter_category_id && filter_category_id !== '0') {
		url += '&filter_category_id=' + encodeURIComponent(filter_category_id);
	}

	var filter_price = $('input[name=\'filter_price\']').val();

	if (filter_price) {
		url += '&filter_price=' + encodeURIComponent(filter_price);
	}

	var filter_quantity = $('input[name=\'filter_quantity\']').val();

	if (filter_quantity) {
		url += '&filter_quantity=' + encodeURIComponent(filter_quantity);
	}

	var filter_status = $('select[name=\'filter_status\']').val();

	if (filter_status !== '') {
		url += '&filter_status=' + encodeURIComponent(filter_status);
	}

	location = 'index.php?route=catalog/product&user_token={{ user_token }}' + url;
});
