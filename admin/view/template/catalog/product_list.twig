{{ header }}{{ column_left }}
<div id="content">
  <div class="page-header">
    <div class="container-fluid">
      <div class="pull-right">
        <button type="button" data-toggle="tooltip" title="{{ button_filter }}" onclick="$('#filter-product').toggleClass('hidden-sm hidden-xs');" class="btn btn-default hidden-md hidden-lg"><i class="fa fa-filter"></i></button>
        <a href="{{ add }}" id="button-open-quick-product" data-toggle="tooltip" title="Hızlı Ürün Ekle" class="btn btn-primary"><i class="fa fa-plus"></i></a>
        <button type="submit" form="form-product" formaction="{{ copy }}" data-toggle="tooltip" title="{{ button_copy }}" class="btn btn-default"><i class="fa fa-copy"></i></button>
        <button type="button" form="form-product" formaction="{{ delete }}" data-toggle="tooltip" title="{{ button_delete }}" class="btn btn-danger" onclick="confirm('{{ text_confirm }}') ? $('#form-product').submit() : false;"><i class="fa fa-trash-o"></i></button>
      </div>
      <h1>{{ heading_title }}</h1>
      <ul class="breadcrumb">
        {% for breadcrumb in breadcrumbs %}
        <li><a href="{{ breadcrumb.href }}">{{ breadcrumb.text }}</a></li>
        {% endfor %}
      </ul>
    </div>
  </div>
  <div class="container-fluid">{% if error_warning %}
    <div class="alert alert-danger alert-dismissible"><i class="fa fa-exclamation-circle"></i> {{ error_warning }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    {% if success %}
    <div class="alert alert-success alert-dismissible"><i class="fa fa-check-circle"></i> {{ success }}
      <button type="button" class="close" data-dismiss="alert">&times;</button>
    </div>
    {% endif %}
    <div class="row">
      <div id="filter-product" class="col-md-2 col-md-push-10 col-sm-12 hidden-sm hidden-xs product-filter-compact">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-filter"></i> {{ text_filter }}</h3>
          </div>
          <div class="panel-body">
            <div class="form-group">
              <label class="control-label" for="input-name">{{ entry_name }}</label>
              <input type="text" name="filter_name" value="{{ filter_name }}" placeholder="{{ entry_name }}" id="input-name" class="form-control" />
            </div>
            <div class="form-group">
              <label class="control-label" for="input-model">{{ entry_model }}</label>
              <input type="text" name="filter_model" value="{{ filter_model }}" placeholder="{{ entry_model }}" id="input-model" class="form-control" />
            </div>
            <div class="form-group">
              <label class="control-label" for="input-category">Kategori</label>
              <select name="filter_category_id" id="input-category" class="form-control">
                <option value="0">Tüm kategoriler</option>
                {% for category in filter_categories %}
                  <option value="{{ category.category_id }}"{% if category.category_id == filter_category_id %} selected="selected"{% endif %}>{{ category.name }}</option>
                {% endfor %}
              </select>
            </div>
            <div class="form-group">
              <label class="control-label" for="input-price">{{ entry_price }}</label>
              <input type="text" name="filter_price" value="{{ filter_price }}" placeholder="{{ entry_price }}" id="input-price" class="form-control" />
            </div>
            <div class="form-group">
              <label class="control-label" for="input-quantity">{{ entry_quantity }}</label>
              <input type="text" name="filter_quantity" value="{{ filter_quantity }}" placeholder="{{ entry_quantity }}" id="input-quantity" class="form-control" />
            </div>
            <div class="form-group">
              <label class="control-label" for="input-status">{{ entry_status }}</label>
              <select name="filter_status" id="input-status" class="form-control">
                <option value=""></option>
                
                
                
                  
                

                  {% if filter_status == '1' %}

                
                
                  
                
                
                <option value="1" selected="selected">{{ text_enabled }}</option>
                
                
                
                  
                

                  {% else %}

                
                
                  
                
                
                <option value="1">{{ text_enabled }}</option>
                
                
                
                  
                

                  {% endif %}
                  {% if filter_status == '0' %}

                
                
                  
                
                
                <option value="0" selected="selected">{{ text_disabled }}</option>
                
                
                
                  
                

                  {% else %}

                
                
                  
                
                
                <option value="0">{{ text_disabled }}</option>
                
                
                
                  
                

                  {% endif %}


              
              
                
              
              
              </select>
            </div>
            <div class="form-group text-right">
              <button type="button" id="button-filter" class="btn btn-default"><i class="fa fa-filter"></i> {{ button_filter }}</button>
            </div>
          </div>
        </div>
      </div>
      <div class="col-md-10 col-md-pull-2 col-sm-12">
        <div class="panel panel-default">
          <div class="panel-heading">
            <h3 class="panel-title"><i class="fa fa-list"></i> {{ text_list }}</h3>
          </div>
          <div class="panel-body">
            <style>
              .quick-edit-value {
                display:inline-block;
                min-width:70px;
                padding:4px 6px;
                border-radius:4px;
                cursor:text;
              }
              .quick-edit-value:hover {
                background:#f4f8fb;
                box-shadow:inset 0 0 0 1px #d9e6ef;
              }
              .quick-edit-input {
                min-width:120px;
              }
              .quick-image {
                cursor:pointer;
                position:relative;
              }
              .quick-image:after {
                content:"\f040";
                font-family:FontAwesome;
                position:absolute;
                right:-8px;
                bottom:-8px;
                width:22px;
                height:22px;
                line-height:22px;
                border-radius:50%;
                background:#1f6f43;
                color:#fff;
                font-size:11px;
              }
              .quick-status {
                min-width:82px;
              }
              .quick-save-state {
                color:#777;
                font-size:12px;
                margin-left:6px;
              }
              .quick-category-value {
                display:inline-block;
                min-width:110px;
                padding:4px 6px;
                border-radius:4px;
                cursor:pointer;
              }
              .quick-category-value:hover {
                background:#f4f8fb;
                box-shadow:inset 0 0 0 1px #d9e6ef;
              }
              .product-filter-compact .panel-body{padding:12px;}
              .product-filter-compact .form-group{margin-bottom:10px;}
              .product-filter-compact label{font-size:12px;margin-bottom:4px;}
              .product-filter-compact .form-control{height:32px;padding:5px 8px;font-size:12px;}
              .product-allergen-cell{min-width:150px;}
              .product-allergen-icons{display:flex;align-items:center;flex-wrap:wrap;gap:5px;min-height:32px;}
              .product-allergen-icon{display:inline-flex;width:30px;height:30px;align-items:center;justify-content:center;border:1px solid #dfe8e2;border-radius:9px;background:#fff;}
              .product-allergen-icon img{max-width:23px;max-height:23px;object-fit:contain;}
              .product-allergen-empty{font-size:11px;color:#9a9a9a;}
              .quick-allergen-trigger{margin-left:5px;border-radius:50%;width:28px;height:28px;padding:0;}
              .quick-allergen-option{display:flex;align-items:center;gap:10px;padding:10px;border:1px solid #dfe8e2;border-radius:10px;margin-bottom:8px;cursor:pointer;}
              .quick-allergen-option:hover{background:#f7fbf8;border-color:#9dc2ad;}
              .quick-allergen-option input{margin:0;}
              .quick-allergen-option img{width:32px;height:32px;object-fit:contain;border:1px solid #e6eee8;border-radius:9px;padding:4px;background:#fff;}
              .quick-product-modal .modal-dialog{width:min(1100px,calc(100% - 32px));}
              .quick-product-modal .modal-content{border:0;border-radius:22px;overflow:hidden;box-shadow:0 28px 90px rgba(10,35,26,.28);}
              .quick-product-shell{display:grid;grid-template-columns:320px 1fr;min-height:650px;background:#f7faf8;}
              .quick-product-side{padding:28px;background:linear-gradient(155deg,#123629,#1d5b3f);color:#fff;position:relative;overflow:hidden;}
              .quick-product-side:before{content:"";position:absolute;inset:auto -90px -100px auto;width:260px;height:260px;border-radius:50%;background:rgba(205,171,91,.25);}
              .quick-product-side h2{position:relative;margin:0 0 8px;font-size:28px;line-height:1.1;font-weight:900;letter-spacing:0;}
              .quick-product-side p{position:relative;margin:0 0 24px;color:rgba(255,255,255,.76);line-height:1.55;}
              .quick-product-image{position:relative;margin-top:22px;}
              .quick-product-image .img-thumbnail{display:block;width:220px;height:220px;margin:0 auto;border:1px solid rgba(255,255,255,.35);border-radius:28px;background:rgba(255,255,255,.12);padding:10px;box-shadow:0 18px 40px rgba(0,0,0,.18);}
              .quick-product-image img{width:100%;height:100%;object-fit:cover;border-radius:20px;}
              .quick-product-image span{display:block;margin-top:13px;text-align:center;color:rgba(255,255,255,.78);font-weight:700;}
              .quick-product-main{padding:26px 28px;background:#fff;}
              .quick-product-toolbar{display:flex;justify-content:space-between;align-items:flex-start;gap:18px;margin-bottom:22px;}
              .quick-product-toolbar h3{margin:0 0 5px;color:#123629;font-size:21px;font-weight:900;}
              .quick-product-toolbar p{margin:0;color:#728178;}
              .quick-product-close{width:42px;height:42px;border:0;border-radius:50%;background:#eef4f0;color:#123629;font-size:22px;line-height:42px;}
              .quick-product-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:18px;}
              .quick-product-field{margin-bottom:15px;}
              .quick-product-field label{display:block;margin-bottom:8px;color:#203c31;font-weight:900;}
              .quick-product-field .form-control{height:44px;border:1px solid #dce8e1;border-radius:12px;box-shadow:none;}
              .quick-product-field textarea.form-control{height:110px;resize:vertical;}
              .quick-product-field .form-control:focus{border-color:#78a887;box-shadow:0 0 0 4px rgba(120,168,135,.13);}
              .quick-product-language{border:1px solid #e4ece7;border-radius:16px;padding:14px;background:#fbfdfc;margin-bottom:14px;}
              .quick-product-language-title{display:flex;align-items:center;gap:8px;margin-bottom:12px;color:#123629;font-weight:900;}
              .quick-product-category-search{position:relative;}
              .quick-product-category-results{display:none;position:absolute;z-index:5;left:0;right:0;top:50px;max-height:260px;overflow:auto;border:1px solid #dce8e1;border-radius:14px;background:#fff;box-shadow:0 18px 45px rgba(18,54,41,.14);}
              .quick-product-category-results button{display:block;width:100%;border:0;border-bottom:1px solid #edf3ef;background:#fff;padding:12px 14px;text-align:left;color:#203c31;font-weight:800;}
              .quick-product-category-results button:hover{background:#f4faf6;}
              .quick-product-category-selected{display:flex;flex-wrap:wrap;gap:8px;min-height:48px;margin-top:10px;padding:10px;border:1px dashed #cfe0d5;border-radius:14px;background:#f8fbf9;}
              .quick-product-category-chip{display:inline-flex;align-items:center;gap:8px;padding:8px 10px;border-radius:999px;background:#e7f4ec;color:#123629;font-weight:900;}
              .quick-product-category-chip button{border:0;background:transparent;color:#d24a3a;padding:0;line-height:1;}
              .quick-product-category-empty{color:#85938b;font-weight:700;padding:4px 0;}
              .quick-product-actions{display:flex;justify-content:flex-end;align-items:center;gap:10px;margin-top:20px;padding-top:18px;border-top:1px solid #edf3ef;}
              .quick-product-actions .btn{border-radius:12px;padding:11px 18px;font-weight:900;}
              .quick-product-state{margin-right:auto;color:#d24a3a;font-weight:800;}
              @media (max-width:991px){.quick-product-shell{grid-template-columns:1fr;}.quick-product-side{display:none;}.quick-product-grid{grid-template-columns:1fr;}.quick-product-modal .modal-dialog{width:calc(100% - 16px);margin:8px;}}
            </style>
            <form action="{{ delete }}" method="post" enctype="multipart/form-data" id="form-product">
              <div class="table-responsive">
                <table class="table table-bordered table-hover">
                  <thead>
                    <tr>
                      <td style="width: 1px;" class="text-center"><input type="checkbox" onclick="$('input[name*=\'selected\']').prop('checked', this.checked);" /></td>
                      <td class="text-center">{{ column_image }}</td>
                      <td class="text-left">{% if sort == 'category_name' %} <a href="{{ sort_category }}" class="{{ order|lower }}">Kategori</a> {% else %} <a href="{{ sort_category }}">Kategori</a> {% endif %}</td>
                      <td class="text-left">{% if sort == 'pd.name' %} <a href="{{ sort_name }}" class="{{ order|lower }}">{{ column_name }}</a> {% else %} <a href="{{ sort_name }}">{{ column_name }}</a> {% endif %}</td>
                      <td class="text-left">Alerjen</td>
                      <td class="text-left">{% if sort == 'p.model' %} <a href="{{ sort_model }}" class="{{ order|lower }}">{{ column_model }}</a> {% else %} <a href="{{ sort_model }}">{{ column_model }}</a> {% endif %}</td>
                      <td class="text-right">{% if sort == 'p.price' %} <a href="{{ sort_price }}" class="{{ order|lower }}">{{ column_price }}</a> {% else %} <a href="{{ sort_price }}">{{ column_price }}</a> {% endif %}</td>
                      <td class="text-right">{% if sort == 'p.quantity' %} <a href="{{ sort_quantity }}" class="{{ order|lower }}">{{ column_quantity }}</a> {% else %} <a href="{{ sort_quantity }}">{{ column_quantity }}</a> {% endif %}</td>
                      <td class="text-left">{% if sort == 'p.status' %} <a href="{{ sort_status }}" class="{{ order|lower }}">{{ column_status }}</a> {% else %} <a href="{{ sort_status }}">{{ column_status }}</a> {% endif %}</td>
                      <td class="text-right">{{ column_action }}</td>
                    </tr>
                  </thead>
                  <tbody>
                  
                  {% if products %}
                  {% for product in products %}
                  <tr class="{{ product.akinsoft_sync_class }}">
                    <td class="text-center">{% if product.product_id in selected %}
                      <input type="checkbox" name="selected[]" value="{{ product.product_id }}" checked="checked" />
                      {% else %}
                      <input type="checkbox" name="selected[]" value="{{ product.product_id }}" />
                      {% endif %}</td>
                    <td class="text-center">
                      <a href="" id="thumb-product-{{ product.product_id }}" data-toggle="image" class="img-thumbnail quick-image" data-product-id="{{ product.product_id }}">
                        <img src="{{ product.image }}" alt="{{ product.name }}" title="Resmi değiştir" data-placeholder="{{ product.image }}" />
                      </a>
                      <input type="hidden" id="input-product-image-{{ product.product_id }}" value="{{ product.image_path }}" data-product-id="{{ product.product_id }}" data-original="{{ product.image_path }}" />
                    </td>
                    <td class="text-left"><span class="quick-category-value" data-product-id="{{ product.product_id }}">{{ product.category }}</span></td>
                    <td class="text-left"><span class="quick-edit-value" data-product-id="{{ product.product_id }}" data-field="name">{{ product.name }}</span></td>
                    <td class="text-left product-allergen-cell">
                      <div class="product-allergen-icons" id="product-allergens-{{ product.product_id }}">
                        {% if product.allergens %}
                          {% for allergen in product.allergens %}
                            <span class="product-allergen-icon" title="{{ allergen.name }}"><img src="{{ allergen.thumb }}" alt="{{ allergen.name }}"></span>
                          {% endfor %}
                        {% else %}
                          <span class="product-allergen-empty">Alerjen yok</span>
                        {% endif %}
                        <button type="button" class="btn btn-default btn-xs quick-allergen-trigger" data-product-id="{{ product.product_id }}" data-product-name="{{ product.name|e('html_attr') }}" title="Alerjen sec"><i class="fa fa-plus"></i></button>
                      </div>
                    </td>
                    <td class="text-left">
                      <span class="quick-edit-value" data-product-id="{{ product.product_id }}" data-field="model">{{ product.model }}</span>
                      {% if product.akinsoft_sync_label %}
                        <div>
                          <span class="label {% if product.akinsoft_sync_status == 'matched' %}label-success{% else %}label-default{% endif %} akinsoft-sync-label">{{ product.akinsoft_sync_label }}</span>
                        </div>
                      {% endif %}
                    </td>
                    <td class="text-right">{% if product.special %} <span class="quick-edit-value" style="text-decoration: line-through;" data-product-id="{{ product.product_id }}" data-field="price" data-raw="{{ product.price_raw }}">{{ product.price }}</span><br/>
                      <div class="text-danger">{{ product.special }}</div>
                      {% else %}
                      <span class="quick-edit-value" data-product-id="{{ product.product_id }}" data-field="price" data-raw="{{ product.price_raw }}">{{ product.price }}</span>
                      {% endif %}
                      {% if product.akinsoft_sync_status == 'matched' %}
                        <div class="akinsoft-price-note">ERP: {{ product.akinsoft_sync_price }}</div>
                      {% endif %}
                    </td>
                    <td class="text-right">{% if product.quantity <= 0 %} <span class="label label-warning">{{ product.quantity }}</span> {% elseif product.quantity <= 5 %} <span class="label label-danger">{{ product.quantity }}</span> {% else %} <span class="label label-success">{{ product.quantity }}</span> {% endif %}</td>
                    <td class="text-left">
                      <button type="button" class="btn btn-xs quick-status {% if product.status_raw %}btn-success{% else %}btn-default{% endif %}" data-product-id="{{ product.product_id }}" data-status="{{ product.status_raw }}">{{ product.status }}</button>
                    </td>
                    <td class="text-right">
                      <button type="button" class="btn btn-info quick-description" data-toggle="tooltip" title="Açıklama" data-product-id="{{ product.product_id }}"><i class="fa fa-align-left"></i></button>
                      <a href="{{ product.edit }}" data-product-id="{{ product.product_id }}" data-toggle="tooltip" title="{{ button_edit }}" class="btn btn-primary quick-product-edit"><i class="fa fa-pencil"></i></a>
                    </td>
                  </tr>
                  {% endfor %}
                  {% else %}
                  <tr>
                    <td class="text-center" colspan="10">{{ text_no_results }}</td>
                  </tr>
                  {% endif %}
                    </tbody>
                  
                </table>
              </div>
            </form>
            <style>
              .akinsoft-row-matched > td {
                background: #eaf8ee !important;
              }
              .akinsoft-row-missing > td {
                background: #fffdf5 !important;
              }
              .akinsoft-sync-label {
                display: inline-block;
                margin-top: 5px;
                font-size: 11px;
                font-weight: 700;
              }
              .akinsoft-price-note {
                margin-top: 4px;
                color: #2f7d46;
                font-size: 11px;
                font-weight: 700;
              }
            </style>
            <div class="row">
              <div class="col-sm-6 text-left">{{ pagination }}</div>
              <div class="col-sm-6 text-right">{{ results }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="modal fade quick-product-modal" id="modal-quick-product" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
      <div class="modal-content">
        <form id="form-quick-product">
          <input type="hidden" name="product_id" id="quick-product-id" value="" />
          <div class="quick-product-shell">
            <aside class="quick-product-side">
              <h2 id="quick-product-side-title">Hızlı Ürün Ekle</h2>
              <p id="quick-product-side-text">Menüye yeni ürünü birkaç temel bilgiyle ekleyin. Detay, alerjen ve galeri düzenlemeleri sonradan yapılabilir.</p>
              <div class="quick-product-image">
                <a href="" id="thumb-quick-product-image" data-toggle="image" class="img-thumbnail">
                  <img src="{{ placeholder }}" alt="" title="" data-placeholder="{{ placeholder }}" />
                </a>
                <input type="hidden" name="image" value="" id="input-quick-product-image" />
                <span>Ürün görseli seç</span>
              </div>
            </aside>
            <section class="quick-product-main">
              <div class="quick-product-toolbar">
                <div>
                  <h3 id="quick-product-main-title">Yeni Menü Ürünü</h3>
                  <p id="quick-product-main-text">Ürün adı, fiyat, kategori ve hazırlık süresi menüde hemen kullanılacak alanlardır.</p>
                </div>
                <button type="button" class="quick-product-close" data-dismiss="modal" aria-label="Close">&times;</button>
              </div>
              <div class="quick-product-grid">
                <div>
                  {% for language in quick_languages %}
                    <div class="quick-product-language">
                      <div class="quick-product-language-title"><img src="language/{{ language.code }}/{{ language.code }}.png" title="{{ language.name }}" /> {{ language.name }}</div>
                      <div class="quick-product-field">
                        <label>Ürün Adı</label>
                        <input type="text" name="name[{{ language.language_id }}]" class="form-control quick-product-name" placeholder="Örn: Trüflü Dana Bonfile" />
                      </div>
                      <div class="quick-product-field">
                        <label>Açıklama</label>
                        <textarea name="description[{{ language.language_id }}]" class="form-control" placeholder="Kısa, iştah açıcı ürün açıklaması"></textarea>
                      </div>
                    </div>
                  {% endfor %}
                </div>
                <div>
                  <div class="quick-product-field">
                    <label>Ürün Kodu</label>
                    <input type="text" name="model" class="form-control" placeholder="ST02006" />
                  </div>
                  <div class="quick-product-field">
                    <label>Fiyat</label>
                    <input type="text" name="price" class="form-control" placeholder="1200" />
                  </div>
                  <div class="quick-product-field">
                    <label>Durum</label>
                    <select name="status" class="form-control">
                      <option value="1">Menüde aktif</option>
                      <option value="0">Pasif</option>
                    </select>
                  </div>
                  <div class="quick-product-field">
                    <label>Sıralama</label>
                    <input type="text" name="sort_order" class="form-control" value="0" />
                  </div>
                  <div class="quick-product-field">
                    <label>Hazırlık Süresi</label>
                    <input type="text" name="prep_time" class="form-control" placeholder="15-20" />
                  </div>
                  <div class="quick-product-field">
                    <label>Kategoriler</label>
                    <div class="quick-product-category-search">
                      <input type="text" id="quick-product-category-search" class="form-control" placeholder="Kategori ara..." autocomplete="off" />
                      <div id="quick-product-category-results" class="quick-product-category-results"></div>
                    </div>
                    <div id="quick-product-category-selected" class="quick-product-category-selected"></div>
                  </div>
                </div>
              </div>
              <div class="quick-product-actions">
                <span class="quick-product-state" id="quick-product-state"></span>
                <button type="button" class="btn btn-default" data-dismiss="modal">Vazgeç</button>
                <button type="submit" class="btn btn-success" id="quick-product-submit"><i class="fa fa-check"></i> Ürünü Ekle</button>
              </div>
            </section>
          </div>
        </form>
      </div>
    </div>
  </div>
  <div class="modal fade" id="modal-product-description" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
      <div class="modal-content">
        <div class="modal-header">
          <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
          <h4 class="modal-title">Ürün Açıklaması</h4>
        </div>
        <div class="modal-body">
          <input type="hidden" id="quick-description-product-id" value="" />
          <ul class="nav nav-tabs" id="quick-description-tabs"></ul>
          <div class="tab-content" id="quick-description-content"></div>
        </div>
        <div class="modal-footer">
          <span class="quick-save-state pull-left" id="quick-description-state"></span>
          <button type="button" class="btn btn-default" data-dismiss="modal">Kapat</button>
